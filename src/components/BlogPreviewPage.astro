---
import appCssUrl from "@/styles/app.css?url";
import { SITE } from "@/site.config";
import type { Locale } from "@/i18n/ui";
import CursorAura from "@/components/CursorAura.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const copy = locale === "fr"
  ? {
      nav: ["Blog", "Tags", "Archives", "À propos"],
      search: "Rechercher",
      title: "Archives",
      description: "Tous les articles publiés, groupés par année puis par mois, du plus récent au plus ancien.",
      postsCount: "6 articles",
      months: [
        {
          label: "juillet",
          posts: [
            ["17 juil.", "Démo: toutes les fonctionnalités du blog"],
            ["08 juil.", "Concevoir un thème dark first"],
            ["05 juil.", "Comprendre l'architecture en îlots d'Astro"],
            ["01 juil.", "Bienvenue sur le blog"],
          ],
        },
        {
          label: "juin",
          posts: [
            ["20 juin", "Typographie éditoriale sur le web"],
            ["10 juin", "Budget performance pour un blog statique"],
          ],
        },
      ],
      powered: "Propulsé par Astro et Lisible",
    }
  : {
      nav: ["Blog", "Tags", "Archives", "About"],
      search: "Search",
      title: "Archives",
      description: "Every published post, grouped by year and month from newest to oldest.",
      postsCount: "6 posts",
      months: [
        {
          label: "July",
          posts: [
            ["Jul 17", "Demo: every feature of the blog"],
            ["Jul 08", "Designing a dark-first theme"],
            ["Jul 05", "Understanding Astro's islands architecture"],
            ["Jul 01", "Welcome to the blog"],
          ],
        },
        {
          label: "June",
          posts: [
            ["Jun 20", "Editorial typography on the web"],
            ["Jun 10", "A performance budget for a static blog"],
          ],
        },
      ],
      powered: "Powered by Astro and Lisible",
    };
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href={appCssUrl} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{copy.title} | {SITE.title}</title>
    <script is:inline define:vars={{ siteAccent: SITE.accent }}>
      (function () {
        function luminance(rgb) {
          var channels = rgb.map(function (value) {
            value /= 255;
            return value <= 0.03928 ? value / 12.92 : Math.pow((value + 0.055) / 1.055, 2.4);
          });
          return 0.2126 * channels[0] + 0.7152 * channels[1] + 0.0722 * channels[2];
        }
        function contrast(a, b) {
          return (Math.max(a, b) + 0.05) / (Math.min(a, b) + 0.05);
        }
        function applyPreferences() {
          var storedTheme = localStorage.getItem("theme");
          var dark = storedTheme === "dark" || (storedTheme !== "light" && !matchMedia("(prefers-color-scheme: light)").matches);
          document.documentElement.classList.toggle("dark", dark);
          var stored = localStorage.getItem("accent");
          var hex = stored && /^#[0-9a-f]{6}$/i.test(stored) ? stored : siteAccent;
          var value = parseInt(hex.slice(1), 16);
          var rgb = [(value >> 16) & 255, (value >> 8) & 255, value & 255];
          for (var i = 0; i < 60; i++) {
            if (dark ? contrast(luminance(rgb), 0) >= 3 : contrast(luminance(rgb), 1) >= 4.5) break;
            rgb = rgb.map(function (channel) {
              return dark
                ? Math.min(255, Math.round(channel + (255 - channel) * 0.06) + 1)
                : Math.max(0, Math.round(channel * 0.94) - 1);
            });
          }
          var foreground = contrast(luminance(rgb), 0) >= 4.5 ? "#000000" : "#ffffff";
          var accent = "rgb(" + rgb.join(" ") + ")";
          document.documentElement.style.setProperty("--accent", accent);
          document.documentElement.style.setProperty("--accent-foreground", foreground);
          document.documentElement.style.setProperty("--ring", accent);
        }
        applyPreferences();
        addEventListener("storage", applyPreferences);
        addEventListener("message", function (event) {
          if (event.origin === location.origin && event.data && event.data.type === "lisible:preferences") applyPreferences();
        });
      })();
    </script>
  </head>
  <body class="flex min-h-dvh flex-col" data-pagefind-ignore>
    <CursorAura />
    <header class="site-dock-wrap sticky top-0 z-40">
      <div class="site-dock mx-auto flex min-h-16 w-full max-w-4xl flex-wrap items-center justify-between gap-x-4 gap-y-0 px-4 py-2 md:px-6">
        <span class="inline-flex min-h-11 items-center gap-2.5 text-lg font-bold tracking-tight">
          <span class="brand-blob" aria-hidden="true"></span>
          {SITE.title}
        </span>
        <nav class="order-last w-full sm:order-none sm:w-auto" aria-label="Blog">
          <ul class="flex items-center justify-center gap-1">
            {copy.nav.map((item, index) => (
              <li><span class:list={["dock-link inline-flex min-h-11 items-center rounded-full px-3.5 text-sm font-medium", index === 2 ? "text-foreground" : "text-muted-foreground"]} aria-current={index === 2 ? "page" : undefined}>{item}</span></li>
            ))}
          </ul>
        </nav>
        <div class="flex items-center gap-1.5 text-muted-foreground">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-full" aria-label={copy.search}>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          </span>
          <span class="inline-flex h-11 items-center rounded-full px-3 text-sm font-semibold">{locale.toUpperCase()}</span>
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-full text-accent" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z"></path></svg>
          </span>
        </div>
      </div>
    </header>

    <main class="mx-auto w-full max-w-6xl flex-1 px-4 md:px-6">
      <div class="py-12 md:py-16">
        <h1 class="type-mega rise">{copy.title}</h1>
        <p class="rise rise-2 mt-5 max-w-2xl text-muted-foreground md:ml-[8%]">{copy.description}</p>

        <div class="archive-timeline mt-14">
          <section class="archive-year" aria-labelledby="preview-archive-2026">
            <div class="archive-year-head">
              <h2 id="preview-archive-2026" class="year-big" aria-label="2026">2026</h2>
              <span class="archive-year-count">{copy.postsCount}</span>
            </div>
            <div class="archive-months">
              {copy.months.map((month) => (
                <div class="archive-month">
                  <h3 class="archive-month-label">{month.label}</h3>
                  <ul class="archive-list">
                    {month.posts.map(([date, title]) => (
                      <li>
                        <span class="archive-row">
                          <time class="archive-date">{date}</time>
                          <span class="archive-title">{title}</span>
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>
        </div>
      </div>
    </main>

    <footer class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-8 text-sm text-muted-foreground">
      <span>© {new Date().getFullYear()} Lisible</span>
      <span>{copy.powered}</span>
    </footer>
  </body>
</html>
