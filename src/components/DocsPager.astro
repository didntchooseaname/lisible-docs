---
import type { DocEntry } from "@/lib/docs";
import { docUrl } from "@/lib/docs";
import { t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  previous?: DocEntry;
  next?: DocEntry;
}

const { locale, previous, next } = Astro.props;
const dict = t(locale).page;
---

<nav class="docs-pager" aria-label={`${dict.previous} / ${dict.next}`}>
  {
    previous ? (
      <a href={docUrl(previous)} rel="prev" class="docs-pager-prev">
        <span>← {dict.previous}</span>
        <strong>{previous.data.title}</strong>
      </a>
    ) : <span />
  }
  {
    next && (
      <a href={docUrl(next)} rel="next" class="docs-pager-next">
        <span>{dict.next} →</span>
        <strong>{next.data.title}</strong>
      </a>
    )
  }
</nav>
