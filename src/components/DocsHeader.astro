---
import AccentPicker from "@/components/AccentPicker.astro";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { SITE } from "@/site.config";

interface Props {
  locale: Locale;
  alternates: Partial<Record<Locale, string>>;
}

const { locale, alternates } = Astro.props;
const dict = t(locale);
---

<header class="docs-header">
  <div class="docs-header-inner">
    <button type="button" class="docs-icon-button lg:hidden" data-docs-nav-open aria-label={dict.sidebar.open}>
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <a href={localeUrl(locale, "docs")} class="docs-brand" aria-label={dict.header.home}>
      <span class="brand-blob" aria-hidden="true"></span>
      <strong>{SITE.title}</strong>
      <span>{dict.header.documentation}</span>
    </a>

    <button type="button" class="docs-search-trigger" data-search-open aria-label={dict.a11y.openSearch}>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.3-4.3" />
      </svg>
      <span>{dict.search.placeholder}</span>
      <kbd>⌘ K</kbd>
    </button>

    <div class="docs-header-actions">
      <a href={SITE.repo} class="docs-icon-button hidden sm:inline-flex" target="_blank" rel="noopener noreferrer" aria-label={dict.header.repository}>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5A4.8 4.8 0 0 0 9 18v4" />
          <path d="M9 18c-4.5 2-5-2-7-2" />
        </svg>
      </a>
      <LanguageSwitcher locale={locale} alternates={alternates} />
      <AccentPicker locale={locale} />
      <ThemeToggle locale={locale} />
    </div>
  </div>
</header>
