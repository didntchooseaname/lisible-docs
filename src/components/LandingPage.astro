    highlights: ["18 chapitres", "Français et anglais", "Recherche instantanée"],
    previewLabel: "Aperçu fidèle de la page Archives du thème Organique",
    featureEyebrow: "Pensée pour avancer",
    featureTitle: "Tout le nécessaire, sans perdre le fil.",
