        steps: ["Clone the repository", "Install dependencies", "Run initialization"],
      },
      {
        label: "Write",
        title: "Keep content at the center.",
        body: "Structure mirrored files, use MDX by default and make every media asset understandable.",
        path: "authoring/content",
        action: "Open the authoring guide",
        steps: ["Create mirrored files", "Complete frontmatter", "Preview both languages"],
      },
      {
        label: "Deploy",
        title: "Publish with concrete checks.",
        body: "Build every route, verify public outputs and serve the exact build you validated.",
        path: "operations/build-deploy",
        action: "Open deployment",
        steps: ["Run the checks", "Build the site", "Verify the served build"],
      },
    ],
    finalEyebrow: "Your next chapter",
    finalTitle: "Start with structure. Customize after that.",
    finalBody: "The recommended path takes only a few steps and always provides a clear route to the next chapter.",
    finalPrimary: "Read the introduction",
    finalSecondary: "View configuration",
    footer: "Official Lisible documentation.",
  },
} as const;

const copy = content[locale];
const landingUrl = locale === "fr" ? "/fr/" : "/en/";
const canonicalUrl = new URL(autoLocale ? "/" : landingUrl, SITE.url);
const docsUrl = localeUrl(locale, "docs");
const docUrl = (slug: string) => localeUrl(locale, `docs/${slug}`);
const previewUrl = locale === "fr" ? "/preview/" : "/en/preview/";
const alternates = { fr: "/fr/", en: "/en/" };
const social = {
  fr: {
    image: new URL("/open-graph/landing-fr.png", SITE.url).toString(),
    alt: content.fr.ogAlt,
  },
  en: {
    image: new URL("/open-graph/landing-en.png", SITE.url).toString(),
    alt: content.en.ogAlt,
  },
};
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    {autoLocale && (
      <script is:inline>
        (() => {
          const stored = localStorage.getItem("lisible-locale");
          const detected = navigator.languages?.find((language) => /^(fr|en)(-|$)/i.test(language))
            ?? navigator.language;
          const preferred = stored === "fr" || stored === "en"
            ? stored
            : /^fr(-|$)/i.test(detected ?? "") ? "fr" : "en";
          document.documentElement.lang = preferred;
          document.documentElement.dataset.landingLocale = preferred;
          if (preferred === "fr") document.documentElement.style.visibility = "hidden";
        })();
      </script>
    )}
    <link rel="stylesheet" href={appCssUrl} />
    <script is:inline define:vars={{ siteAccent: SITE.accent }}>
      (function () {
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        function luminance(rgb) {
          var channels = rgb.map(function (value) {
            value /= 255;
            return value <= 0.03928 ? value / 12.92 : Math.pow((value + 0.055) / 1.055, 2.4);
          });
          return 0.2126 * channels[0] + 0.7152 * channels[1] + 0.0722 * channels[2];
        }
        function contrast(a, b) {
          return (Math.max(a, b) + 0.05) / (Math.min(a, b) + 0.05);
        }
        function applyPreferences() {
          const storedTheme = localStorage.getItem("theme");
          const theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : "system";
          const dark = theme === "dark" || (theme === "system" && media.matches);
          document.documentElement.classList.toggle("dark", dark);
          document.documentElement.dataset.theme = theme;
          document.documentElement.dataset.resolvedTheme = dark ? "dark" : "light";
          document.documentElement.style.colorScheme = dark ? "dark" : "light";
          const storedAccent = localStorage.getItem("accent");
          const hex = storedAccent && /^#[0-9a-f]{6}$/i.test(storedAccent) ? storedAccent : siteAccent;
          const value = parseInt(hex.slice(1), 16);
          let rgb = [(value >> 16) & 255, (value >> 8) & 255, value & 255];
          for (let i = 0; i < 60; i++) {
            if (dark ? contrast(luminance(rgb), 0) >= 3 : contrast(luminance(rgb), 1) >= 4.5) break;
            rgb = rgb.map(function (channel) {
              return dark
                ? Math.min(255, Math.round(channel + (255 - channel) * 0.06) + 1)
                : Math.max(0, Math.round(channel * 0.94) - 1);
            });
          }
          const foreground = contrast(luminance(rgb), 0) >= 4.5 ? "#000000" : "#ffffff";
          const accent = "rgb(" + rgb.join(" ") + ")";
          document.documentElement.style.setProperty("--accent", accent);
          document.documentElement.style.setProperty("--accent-foreground", foreground);
          document.documentElement.style.setProperty("--ring", accent);
        }
        window.__applyAccent = applyPreferences;
        function syncPreferences(event) {
          if (event.key === "theme" || event.key === "accent" || event.key === null) applyPreferences();
        }
        function syncSystemTheme() {
          const stored = localStorage.getItem("theme");
          if (stored !== "light" && stored !== "dark") applyPreferences();
        }
        applyPreferences();
        media.addEventListener("change", syncSystemTheme);
        window.addEventListener("storage", syncPreferences);
        document.addEventListener("astro:after-swap", applyPreferences);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SeoMeta
      title={copy.metaTitle}
      description={copy.description}
      canonical={canonicalUrl}
      locale={locale}
      alternates={alternates}
      xDefault="/"
      image={social[locale].image}
      imageAlt={social[locale].alt}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": `${canonicalUrl}#website`,
      name: SITE.product,
      alternateName: "Lisible Docs",
      description: copy.description,
      inLanguage: locale,
      url: canonicalUrl.toString(),
      image: social[locale].image,
      publisher: {
        "@type": "Organization",
        "@id": `${SITE.url}/#organization`,
        name: SITE.title,
        url: SITE.url,
      },
    })} />
    <ClientRouter />
  </head>
  <body class="landing-body" data-landing-auto={autoLocale ? "true" : undefined}>
    <CursorAura />
    <a href="#main" class="docs-skip-link">{dict.a11y.skipToContent}</a>

    <header class="landing-header">
      <div class="landing-header__inner">
        <a href={landingUrl} class="landing-brand" aria-label={copy.home} data-locale-link>
          <span class="brand-blob" aria-hidden="true"></span>
          <strong>{SITE.title}</strong>
          <span>{copy.docs}</span>
        </a>

        <nav class="landing-nav" aria-label={copy.docs}>
          <a class="landing-nav__preview" href={previewUrl} data-locale-link aria-label={copy.previewer}>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="4" width="18" height="14" rx="2" />
              <path d="M8 22h8M12 18v4M15.5 8.5l-4.25 4.25L9 10.5" />
            </svg>
            <span>{copy.previewer}</span>
          </a>
          <a href={SITE.repo} target="_blank" rel="noopener noreferrer" aria-label={copy.repository}>
            <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5A4.8 4.8 0 0 0 9 18v4" />
              <path d="M9 18c-4.5 2-5-2-7-2" />
            </svg>
          </a>
        </nav>

        <div class="landing-header__actions">
          <LanguageSwitcher locale={locale} alternates={alternates} />
          <AccentPicker locale={locale} />
          <ThemeToggle locale={locale} />
        </div>
      </div>
    </header>

    <main id="main">
      <section class="landing-hero" aria-labelledby="landing-title">
        <div class="landing-grid" aria-hidden="true">
          <InteractiveGridPattern
            client:load
            width={44}
            height={44}
            squares={[30, 20]}
            className="landing-grid-pattern"
            squaresClassName="landing-grid-square"
          />
        </div>

        <div class="landing-container landing-hero__inner">
          <div class="landing-hero__copy landing-enter">
            <p class="landing-eyebrow">{copy.eyebrow}</p>
            <h1 id="landing-title">{copy.title}</h1>
            <p class="landing-hero__intro">{copy.intro}</p>
            <div class="landing-hero__actions">
              <a class="landing-button landing-button--primary" href={docsUrl} data-locale-link>
                <span>{copy.primary}</span>
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
              <button type="button" class="landing-button landing-button--secondary" data-search-open aria-label={`${copy.search}: ${dict.a11y.openSearch}`}>
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <circle cx="11" cy="11" r="8" />
                  <path d="m21 21-4.3-4.3" />
                </svg>
                <span>{copy.search}</span>
              </button>
            </div>
            <ul class="landing-highlights" aria-label={copy.eyebrow}>
              {copy.highlights.map((item) => (
                <li><span aria-hidden="true"></span>{item}</li>
              ))}
            </ul>
          </div>

          <a class="landing-preview landing-enter landing-enter--delay" data-pointer-card aria-label={copy.previewLabel} href={previewUrl} data-locale-link>
            <BorderBeam client:load duration={8} size={130} borderWidth={3} colorFrom="var(--accent)" colorTo="var(--accent)" />
            <div class="landing-preview__bar" aria-hidden="true">
              <span></span><span></span><span></span>
              <div>lisible.xsec.fr/preview</div>
            </div>
            <div class="landing-preview__viewport">
              <div class="landing-preview__site" aria-hidden="true">
                <div class="landing-preview__site-nav"><strong>Lisible</strong><span>Blog</span><span>Tags</span><span>About</span></div>
                <div class="landing-preview__site-copy"><span>THE INDEPENDENT WEB</span><strong>Ideas made<br />readable.</strong><i></i><i></i><i></i></div>
              </div>
              <div class="landing-preview__settings" aria-hidden="true">
                <strong>SETTINGS</strong>
                <span>Organique <i></i></span>
                <small>APPEARANCE</small>
                <span>Dark <i class="is-on"></i></span>
                <span>Accent <b></b></span>
                <small>CONTENT</small>
                <span>Covers <i class="is-on"></i></span>
              </div>
              <div class="landing-preview__cta">
                <div><strong>{copy.previewTitle}</strong><p>{copy.previewBody}</p></div>
                <span>{copy.previewAction}<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg></span>
              </div>
            </div>
          </a>
        </div>
      </section>

      <section class="landing-section landing-features" aria-labelledby="features-title">
        <div class="landing-container">
          <div class="landing-section__heading">
            <div>
              <p class="landing-eyebrow">{copy.featureEyebrow}</p>
              <h2 id="features-title">{copy.featureTitle}</h2>
            </div>
            <p>{copy.featureIntro}</p>
          </div>
          <div class="landing-card-grid">
            {copy.cards.map((card, index) => (
              <a class:list={["landing-card", { "landing-card--wide": index === 0 }]} href={docUrl(card.slug)} data-pointer-card data-locale-link>
                <span class="landing-card__number">{card.number}</span>
                <div>
                  <h3>{card.title}</h3>
                  <p>{card.body}</p>
                </div>
                <span class="landing-card__link">
                  <span>{card.label}</span>
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="landing-section landing-flow" aria-labelledby="flow-title">
        <div class="landing-container">
          <div class="landing-flow__heading">
            <p class="landing-eyebrow">{copy.flowEyebrow}</p>
            <h2 id="flow-title">{copy.flowTitle}</h2>
            <p>{copy.flowIntro}</p>
          </div>

          <div class="landing-workflow" data-landing-tabs>
            <div class="landing-tablist" role="tablist" aria-label={copy.flowLabel}>
              {copy.tabs.map((tab, index) => (
                <button
                  type="button"
                  role="tab"
                  id={`landing-tab-${locale}-${index}`}
                  aria-controls={`landing-panel-${locale}-${index}`}
                  aria-selected={index === 0 ? "true" : "false"}
                  tabindex={index === 0 ? 0 : -1}
                >
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <span>{tab.label}</span>
                </button>
              ))}
            </div>

            <div class="landing-panels">
              {copy.tabs.map((tab, index) => (
                <section
                  role="tabpanel"
                  id={`landing-panel-${locale}-${index}`}
                  aria-labelledby={`landing-tab-${locale}-${index}`}
                  hidden={index !== 0}
                >
                  <div class="landing-panel__copy">
                    <p>{String(index + 1).padStart(2, "0")}</p>
                    <h3>{tab.title}</h3>
                    <div>{tab.body}</div>
                    <a href={docUrl(tab.path)} data-locale-link>
                      <span>{tab.action}</span>
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M5 12h14M13 6l6 6-6 6" />
                      </svg>
                    </a>
                  </div>
                  <ol class="landing-panel__steps">
                    {tab.steps.map((step, stepIndex) => (
                      <li>
                        <span>{String(stepIndex + 1).padStart(2, "0")}</span>
                        <strong>{step}</strong>
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path d="m5 12 4 4L19 6" />
                        </svg>
                      </li>
                    ))}
                  </ol>
                </section>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="landing-section landing-final" aria-labelledby="final-title">
        <div class="landing-container">
          <div class="landing-final__inner" data-pointer-card>
            <div>
              <p class="landing-eyebrow">{copy.finalEyebrow}</p>
              <h2 id="final-title">{copy.finalTitle}</h2>
              <p>{copy.finalBody}</p>
            </div>
            <div class="landing-final__actions">
              <a class="landing-button landing-button--primary" href={docsUrl} data-locale-link>{copy.finalPrimary}</a>
              <a class="landing-button landing-button--secondary" href={docUrl("getting-started/configuration")} data-locale-link>{copy.finalSecondary}</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="landing-footer">
      <div class="landing-container">
        <p>{copy.footer}</p>
        <div>
          <a href={docsUrl} data-locale-link>{copy.docs}</a>
          <a href={previewUrl} data-locale-link>{copy.previewer}</a>
          <a href={SITE.repo} target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </footer>

    <DocsSearch locale={locale} />
    {autoLocale && (
      <script
        is:inline
        define:vars={{
          landingContent: content,
          landingUi: { fr: t("fr"), en: t("en") },
          landingOgLocales: ogLocales,
          landingSocial: social,
          siteTitle: SITE.title,
          siteProduct: SITE.product,
          siteUrl: SITE.url,
          canonical: canonicalUrl.toString(),
        }}
      >
        (() => {
          const text = (selector, value, root = document) => {
            const element = root.querySelector(selector);
            if (element) element.textContent = value;
          };
          const attribute = (selector, name, value, root = document) => {
            root.querySelector(selector)?.setAttribute(name, value);
          };
          const localizedPath = (raw, locale) => {
            const url = new URL(raw, location.origin);
            const unprefixed = url.pathname.replace(/^\/en(?=\/|$)/, "") || "/";
            const pathname = locale === "en"
              ? unprefixed === "/" ? "/en/" : `/en${unprefixed}`
              : unprefixed;
            return `${pathname}${url.search}${url.hash}`;
          };

          function applyLocale(locale, persist = false) {
            const next = locale === "fr" ? "fr" : "en";
            const copy = landingContent[next];
            const ui = landingUi[next];
            const other = next === "fr" ? "en" : "fr";

            document.documentElement.lang = next;
            document.documentElement.dataset.landingLocale = next;
            if (persist) localStorage.setItem("lisible-locale", next);

            document.title = copy.metaTitle;
            attribute('meta[name="description"]', "content", copy.description);
            attribute('meta[property="og:title"]', "content", document.title);
            attribute('meta[property="og:description"]', "content", copy.description);
            attribute('meta[property="og:locale"]', "content", landingOgLocales[next]);
            attribute('meta[property="og:locale:alternate"]', "content", landingOgLocales[other]);
            attribute('meta[property="og:image"]', "content", landingSocial[next].image);
            attribute('meta[property="og:image:secure_url"]', "content", landingSocial[next].image);
            attribute('meta[property="og:image:alt"]', "content", landingSocial[next].alt);
            attribute('meta[name="twitter:title"]', "content", document.title);
            attribute('meta[name="twitter:description"]', "content", copy.description);
            attribute('meta[name="twitter:image"]', "content", landingSocial[next].image);
            attribute('meta[name="twitter:image:alt"]', "content", landingSocial[next].alt);
            const jsonLd = document.querySelector('script[type="application/ld+json"]');
            if (jsonLd) {
              jsonLd.textContent = JSON.stringify({
                "@context": "https://schema.org",
                "@type": "WebSite",
                "@id": `${canonical}#website`,
                name: siteProduct,
                alternateName: "Lisible Docs",
                description: copy.description,
                inLanguage: next,
                url: canonical,
                image: landingSocial[next].image,
                publisher: {
                  "@type": "Organization",
                  "@id": `${siteUrl}/#organization`,
                  name: siteTitle,
                  url: siteUrl,
                },
              });
            }

            text(".docs-skip-link", ui.a11y.skipToContent);
            attribute(".landing-brand", "aria-label", copy.home);
            text(".landing-brand > span:last-child", copy.docs);
            attribute(".landing-nav", "aria-label", copy.docs);
            text(".landing-nav > a:first-child", copy.docs);
            text(".landing-nav__preview span", copy.previewer);
            attribute(".landing-nav__preview", "aria-label", copy.previewer);
            attribute(".landing-nav > a:last-child", "aria-label", copy.repository);

            const languageNav = document.querySelector(".landing-header__actions nav");
            languageNav?.setAttribute("aria-label", ui.a11y.languageSwitcher);
            const frenchLink = languageNav?.querySelector('a[hreflang="fr"]');
            const englishLink = languageNav?.querySelector('a[hreflang="en"]');
            frenchLink?.setAttribute("aria-label", ui.a11y.frenchVersion);
            englishLink?.setAttribute("aria-label", ui.a11y.englishVersion);
            if (next === "fr") {
              frenchLink?.setAttribute("aria-current", "true");
              englishLink?.removeAttribute("aria-current");
            } else {
              englishLink?.setAttribute("aria-current", "true");
              frenchLink?.removeAttribute("aria-current");
            }

            attribute("[data-accent-open]", "aria-label", ui.accent.open);
            attribute("#accent-popover", "aria-label", ui.accent.title);
            attribute("[data-accent-sv]", "aria-label", ui.accent.svLabel);
            attribute("[data-accent-sv]", "data-valuetext", ui.accent.svValueText);
            attribute("[data-accent-hue]", "aria-label", ui.accent.hueLabel);
            attribute("[data-accent-hue]", "data-valuetext", ui.accent.hueValueText);
            text("[data-accent-reset]", ui.accent.reset);
            attribute("[data-theme-toggle]", "aria-label", ui.a11y.toggleTheme);

            text(".landing-hero .landing-eyebrow", copy.eyebrow);
            text("#landing-title", copy.title);
            text(".landing-hero__intro", copy.intro);
            text(".landing-hero__actions > a span", copy.primary);
            text("[data-search-open] span", copy.search);
            attribute("[data-search-open]", "aria-label", `${copy.search}: ${ui.a11y.openSearch}`);
            attribute(".landing-highlights", "aria-label", copy.eyebrow);
            document.querySelectorAll(".landing-highlights li").forEach((item, index) => {
              const dot = item.querySelector("span");
              if (dot) item.replaceChildren(dot, document.createTextNode(copy.highlights[index]));
            });

            attribute(".landing-preview", "aria-label", copy.previewLabel);
            text(".landing-preview__cta strong", copy.previewTitle);
            text(".landing-preview__cta p", copy.previewBody);
            const previewAction = document.querySelector(".landing-preview__cta > span");
            const previewActionIcon = previewAction?.querySelector("svg");
            if (previewAction && previewActionIcon) previewAction.replaceChildren(document.createTextNode(copy.previewAction), previewActionIcon);
            text(".landing-features .landing-eyebrow", copy.featureEyebrow);
            text("#features-title", copy.featureTitle);
            text(".landing-section__heading > p", copy.featureIntro);
            document.querySelectorAll(".landing-card").forEach((card, index) => {
              const item = copy.cards[index];
              if (!item) return;
              text("h3", item.title, card);
              text("p", item.body, card);
              text(".landing-card__link > span", item.label, card);
            });

            text(".landing-flow .landing-eyebrow", copy.flowEyebrow);
            text("#flow-title", copy.flowTitle);
            text(".landing-flow__heading > p:last-child", copy.flowIntro);
            attribute(".landing-tablist", "aria-label", copy.flowLabel);
            document.querySelectorAll('.landing-tablist [role="tab"]').forEach((tab, index) => {
              if (copy.tabs[index]) text("span:last-child", copy.tabs[index].label, tab);
            });
            document.querySelectorAll('.landing-panels [role="tabpanel"]').forEach((panel, index) => {
              const item = copy.tabs[index];
              if (!item) return;
              text(".landing-panel__copy h3", item.title, panel);
              text(".landing-panel__copy > div", item.body, panel);
              text(".landing-panel__copy > a span", item.action, panel);
              panel.querySelectorAll(".landing-panel__steps strong").forEach((step, stepIndex) => {
                if (item.steps[stepIndex]) step.textContent = item.steps[stepIndex];
              });
            });

            text(".landing-final .landing-eyebrow", copy.finalEyebrow);
            text("#final-title", copy.finalTitle);
            text(".landing-final__inner > div:first-child > p:last-child", copy.finalBody);
            text(".landing-final__actions > a:first-child", copy.finalPrimary);
            text(".landing-final__actions > a:last-child", copy.finalSecondary);
            text(".landing-footer p", copy.footer);
            text(".landing-footer a:first-child", copy.docs);
            text(".landing-footer a:nth-child(2)", copy.previewer);

            document.querySelectorAll("[data-locale-link]").forEach((link) => {
              const href = link.getAttribute("href");
              if (href) link.setAttribute("href", localizedPath(href, next));
            });

            const modal = document.querySelector("[data-search-modal]");
            if (modal) {
              modal.dataset.otherHome = next === "fr" ? "/en/" : "/fr/";
              modal.dataset.noResults = ui.search.noResults;
              modal.dataset.devNotice = ui.search.devNotice;
              modal.dataset.copied = ui.search.copied;
            }
            attribute("[data-search-input]", "placeholder", ui.search.placeholder);
            attribute("[data-search-input]", "aria-label", ui.search.title);
            attribute("[data-search-close]", "aria-label", ui.a11y.closeSearch);
            text("[data-search-actions] h2", ui.search.actions);
            text("[data-search-pages] h2", ui.search.pages);
            text("[data-search-message]", ui.search.hint);
            const actionLabels = [ui.search.toggleTheme, ui.search.switchLanguage, ui.search.copyUrl];
            document.querySelectorAll(".docs-command__label").forEach((label, index) => {
              if (actionLabels[index]) label.textContent = actionLabels[index];
            });

          }

          const initial = document.documentElement.dataset.landingLocale === "fr" ? "fr" : "en";
          try {
            applyLocale(initial);
          } finally {
            document.documentElement.style.removeProperty("visibility");
          }

          window.__setLandingLocale = applyLocale;
          window.__landingLocaleController?.abort();
          const controller = new AbortController();
          window.__landingLocaleController = controller;
          document.addEventListener("click", (event) => {
            if (location.pathname !== "/") return;
            const target = event.target instanceof Element ? event.target : null;
            const languageLink = target?.closest('a[hreflang="fr"], a[hreflang="en"]');
            const languageCommand = target?.closest('[data-command="language"]');
            if (!languageLink && !languageCommand) return;
            event.preventDefault();
            event.stopImmediatePropagation();
            const next = languageLink?.getAttribute("hreflang")
              ?? (document.documentElement.lang === "fr" ? "en" : "fr");
            applyLocale(next, true);
            document.querySelector("[data-search-modal]")?.close();
          }, { capture: true, signal: controller.signal });
          document.addEventListener("astro:before-swap", () => controller.abort(), { once: true, signal: controller.signal });
        })();
      </script>
    )}
    <script>import "@/scripts/landing";</script>
  </body>
</html>
