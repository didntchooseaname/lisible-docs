---
import appCssUrl from "@/styles/app.css?url";
import "@/styles/landing.css";
import { ClientRouter } from "astro:transitions";
import DocsSearch from "@/components/DocsSearch.astro";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import AccentPicker from "@/components/AccentPicker.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import CursorAura from "@/components/CursorAura.astro";
import { BorderBeam } from "@/components/ui/border-beam";
import { InteractiveGridPattern } from "@/components/ui/interactive-grid-pattern";
import { localeUrl, ogLocales, otherLocale, t, type Locale } from "@/i18n/ui";
import { SITE } from "@/site.config";

interface Props {
