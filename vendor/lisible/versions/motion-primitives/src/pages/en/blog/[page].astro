---
import BlogIndexPage from "@/components/pages/BlogIndexPage.astro";
import { FEATURES } from "@/site.config";
import { getPublishedPosts, pageCount } from "@/lib/posts";

export async function getStaticPaths() {
  if (!FEATURES.pagination.enabled) return [];
  const posts = await getPublishedPosts("en");
  const total = pageCount(posts.length, FEATURES.pagination.pageSize);
  const paths = [];
  for (let n = 2; n <= total; n++) paths.push({ params: { page: String(n) }, props: { page: n } });
  return paths;
}

const { page } = Astro.props;
---

<BlogIndexPage locale="en" page={page} />
