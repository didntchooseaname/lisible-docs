---
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { postSlug, postUrl, type SeriesInfo } from "@/lib/posts";
import { readingTime } from "@/lib/utils";

interface Props {
  series: SeriesInfo;
  locale: Locale;
  class?: string;
  footer?: boolean;
}

const { series, locale, class: className, footer = false } = Astro.props;
const dict = t(locale).series;
const seriesHref = localeUrl(locale, `series/${series.slug}`);
const position = series.index + 1;
const cumulative = series.posts.reduce((sum, post) => sum + readingTime(post.body ?? ""), 0);
---

{
  !footer && (
    <aside class={`rounded-lg border border-border border-l-4 border-l-accent bg-card p-4 ${className ?? ""}`}>
      <p class="text-xs font-semibold uppercase tracking-wider text-accent">{dict.label}</p>
      <p class="mt-1 font-medium">
        <a href={seriesHref} class="hover:text-accent">{series.name}</a>
      </p>
      <p class="mt-0.5 text-sm text-muted-foreground">{dict.position(position, series.total)}</p>
    </aside>
  )
}

{
  footer && (
    <section aria-label={dict.label} class={`rounded-lg border border-border bg-card p-4 ${className ?? ""}`}>
      <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
        <p class="text-xs font-semibold uppercase tracking-wider text-accent">{dict.label}</p>
        <p class="text-sm text-muted-foreground">{dict.cumulativeTime(cumulative)}</p>
      </div>
      <p class="mt-1 font-medium">
        <a href={seriesHref} class="hover:text-accent">{series.name}</a>
        <span class="ml-2 text-sm font-normal text-muted-foreground">{dict.position(position, series.total)}</span>
      </p>

      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        {series.prev ? (
          <a
            href={postUrl(series.prev)}
            class="group flex flex-col gap-1 rounded-md border border-border p-3 transition-colors hover:border-accent"
          >
            <span class="text-xs text-muted-foreground">{dict.prev}</span>
            <span class="text-sm font-medium transition-colors group-hover:text-accent">{series.prev.data.title}</span>
          </a>
        ) : (
          <span aria-hidden="true" />
        )}
        {series.next && (
          <a
            href={postUrl(series.next)}
            class="group flex flex-col gap-1 rounded-md border border-border p-3 text-right transition-colors hover:border-accent sm:col-start-2"
          >
            <span class="text-xs text-muted-foreground">{dict.next}</span>
            <span class="text-sm font-medium transition-colors group-hover:text-accent">{series.next.data.title}</span>
          </a>
        )}
      </div>

      <details class="mt-4 group">
        <summary class="cursor-pointer list-none text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
          <span class="inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform group-open:rotate-90">
              <path d="m9 18 6-6-6-6" />
            </svg>
            {dict.toggleList}
          </span>
        </summary>
        <ol class="mt-3 flex flex-col gap-1">
          {series.posts.map((post, i) => {
            const isCurrent = postSlug(post) === postSlug(series.posts[series.index]);
            return (
              <li>
                <a
                  href={postUrl(post)}
                  aria-current={isCurrent ? "true" : undefined}
                  class:list={[
                    "flex items-baseline gap-2 rounded-md px-2 py-1.5 text-sm transition-colors hover:bg-secondary",
                    isCurrent ? "font-semibold text-accent" : "text-foreground",
                  ]}
                >
                  <span class="w-5 shrink-0 font-mono text-xs text-muted-foreground">{i + 1}.</span>
                  <span>{post.data.title}</span>
                </a>
              </li>
            );
          })}
        </ol>
      </details>
    </section>
  )
}
