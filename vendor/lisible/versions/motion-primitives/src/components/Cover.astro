---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  cover: ImageMetadata | string;
  alt: string;
  class?: string;
  eager?: boolean;
}

const { cover, alt, class: className, eager = false } = Astro.props;
const isString = typeof cover === "string";
const loading = eager ? "eager" : "lazy";
---

<div class:list={["cover", className]} data-preview-cover>
  {
    isString ? (
      <img
        src={cover}
        alt={alt}
        class="cover-img"
        loading={loading}
        decoding="async"
      />
    ) : (
      <Image
        src={cover}
        alt={alt}
        class="cover-img"
        widths={[400, 800, 1200]}
        sizes="(max-width: 768px) 100vw, 800px"
        loading={loading}
        decoding="async"
      />
    )
  }
</div>
