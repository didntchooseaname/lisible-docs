---
import { t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  basePath: string;
  current: number;
  total: number;
}

const { locale, basePath, current, total } = Astro.props;
const dict = t(locale).pagination;

function pageHref(n: number): string {
  return n <= 1 ? basePath : `${basePath}${n}/`;
}

const hasPrev = current > 1;
const hasNext = current < total;
---

{
  total > 1 && (
    <nav aria-label={dict.nav} class="mt-12 flex items-center justify-between gap-4 border-t border-border pt-6">
      {hasPrev ? (
        <a
          href={pageHref(current - 1)}
          rel="prev"
          class="group inline-flex min-h-11 items-center gap-2 rounded-md border border-border px-3 text-sm font-medium text-muted-foreground transition-colors hover:border-accent hover:text-foreground"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6" />
          </svg>
          {dict.prev}
        </a>
      ) : (
        <span aria-hidden="true" />
      )}

      <span class="text-sm text-muted-foreground" aria-current="page">
        {dict.page(current, total)}
      </span>

      {hasNext ? (
        <a
          href={pageHref(current + 1)}
          rel="next"
          class="group inline-flex min-h-11 items-center gap-2 rounded-md border border-border px-3 text-sm font-medium text-muted-foreground transition-colors hover:border-accent hover:text-foreground"
        >
          {dict.next}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </a>
      ) : (
        <span aria-hidden="true" />
      )}
    </nav>
  )
}
