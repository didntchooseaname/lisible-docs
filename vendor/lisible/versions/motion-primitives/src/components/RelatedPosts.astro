---
import { t, type Locale } from "@/i18n/ui";
import { postUrl, type Post } from "@/lib/posts";
import { formatDate, isoDate } from "@/lib/utils";

interface Props {
  posts: Post[];
  locale: Locale;
}

const { posts, locale } = Astro.props;
const dict = t(locale);
---

{
  posts.length > 0 && (
    <section aria-labelledby="related-title" class="mt-14 border-t border-border pt-8" data-preview-related>
      <h2 id="related-title" class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">
        {dict.post.related}
      </h2>
      <ul class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((related) => (
          <li class="h-full">
            <a
              href={postUrl(related)}
              class="group flex h-full flex-col rounded-lg border border-border bg-card p-4 transition-colors hover:border-accent"
            >
              <h3 class="font-semibold leading-snug tracking-tight transition-colors group-hover:text-accent">
                {related.data.title}
              </h3>
              <p class="mt-2 line-clamp-2 text-sm text-muted-foreground">
                {related.data.description}
              </p>
              <time
                datetime={isoDate(related.data.pubDate)}
                class="mt-3 text-xs text-muted-foreground"
              >
                {formatDate(related.data.pubDate, locale, "short")}
              </time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
