---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { getAllSeries } from "@/lib/posts";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const dict = t(locale);
const series = await getAllSeries(locale);
const description = locale === "fr" ? "Tous les parcours éditoriaux, regroupés dans leur ordre de lecture." : "Every editorial path, grouped in reading order.";
---

<BaseLayout locale={locale} title={dict.nav.series} description={description} alternates={{ fr: localeUrl("fr", "series"), en: localeUrl("en", "series") }}>
  <div class="py-10 md:py-14">
    <p class="text-xs font-semibold uppercase tracking-wider text-accent">{dict.series.label}</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">{dict.nav.series}</h1>
    <p class="mt-3 max-w-2xl text-muted-foreground">{description}</p>
    <ul class="mt-10 grid gap-4 sm:grid-cols-2">
      {series.map((entry) => (
        <li><a href={localeUrl(locale, `series/${entry.slug}`)} class="block rounded-lg border border-border p-5 transition-colors hover:border-accent"><strong class="block text-lg">{entry.name}</strong><span class="mt-2 block text-sm text-muted-foreground">{dict.archives.count(entry.posts.length)}</span></a></li>
      ))}
    </ul>
  </div>
</BaseLayout>
