---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pagination from "@/components/Pagination.astro";
import { PostRowsList, type PostRowData } from "@/components/react/PostRowsList";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { FEATURES } from "@/site.config";
import {
  getPublishedPosts,
  groupByYear,
  pageCount,
  paginate,
  postUrl,
  type Post,
} from "@/lib/posts";
import { formatDate, isoDate } from "@/lib/utils";

interface Props {
  locale: Locale;
  page?: number;
}

const { locale, page = 1 } = Astro.props;
const dict = t(locale);

const allPosts = await getPublishedPosts(locale);
const pageSize = FEATURES.pagination.enabled ? FEATURES.pagination.pageSize : allPosts.length || 1;
const current = FEATURES.pagination.enabled ? paginate(allPosts, page, pageSize) : { items: allPosts, current: 1, total: 1 };
const years = groupByYear(current.items);

const basePath = localeUrl(locale, "blog");
const pageHref = (loc: Locale, n: number) => (n <= 1 ? localeUrl(loc, "blog") : `${localeUrl(loc, "blog")}${n}/`);
const prevPath = current.current > 1 ? pageHref(locale, current.current - 1) : undefined;
const nextPath = current.current < current.total ? pageHref(locale, current.current + 1) : undefined;

const alternates: Partial<Record<Locale, string>> = {};
for (const loc of ["fr", "en"] as const) {
  const count = pageCount((await getPublishedPosts(loc)).length, pageSize);
  alternates[loc] = current.current <= count ? pageHref(loc, current.current) : localeUrl(loc, "blog");
}

function toRowData(post: Post): PostRowData {
  return {
    url: postUrl(post),
    title: post.data.title,
    dateISO: isoDate(post.data.pubDate),
    dateLabel: formatDate(post.data.pubDate, locale, "short"),
    draftLabel: post.data.draft ? dict.post.draft : undefined,
  };
}
---

<BaseLayout
  locale={locale}
  title={dict.blog.title}
  description={dict.blog.description}
  alternates={alternates}
  prevPath={prevPath}
  nextPath={nextPath}
>
  <div class="py-10 md:py-14">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{dict.blog.title}</h1>
    <p class="mt-3 max-w-2xl text-muted-foreground">{dict.blog.description}</p>

    <div class="mt-10 flex flex-col gap-10">
      {
        years.map(([year, yearPosts]) => (
          <section aria-labelledby={`year-${year}`}>
            <h2
              id={`year-${year}`}
              class="border-b border-border pb-2 text-sm font-semibold uppercase tracking-wider text-muted-foreground"
            >
              {year}
            </h2>
            <PostRowsList client:visible posts={yearPosts.map(toRowData)} />
          </section>
        ))
      }
    </div>

    <Pagination locale={locale} basePath={basePath} current={current.current} total={current.total} />
  </div>
</BaseLayout>
