---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pagination from "@/components/Pagination.astro";
import { PostCardsGrid, type PostCardData } from "@/components/react/PostCardsGrid";
import { localeUrl, otherLocale, t, type Locale } from "@/i18n/ui";
import { FEATURES } from "@/site.config";
import { getAllTags, getPostsByTag, pageCount, paginate, postUrl, type Post } from "@/lib/posts";
import { formatDate, isoDate, readingTime } from "@/lib/utils";

interface Props {
  locale: Locale;
  tagSlug: string;
  tagName: string;
  posts: Post[];
  page?: number;
}

const { locale, tagSlug, tagName, posts, page = 1 } = Astro.props;
const dict = t(locale);

const pageSize = FEATURES.pagination.enabled ? FEATURES.pagination.pageSize : posts.length || 1;
const current = FEATURES.pagination.enabled ? paginate(posts, page, pageSize) : { items: posts, current: 1, total: 1 };

const basePath = localeUrl(locale, `tags/${tagSlug}`);
const pageHref = (base: string, n: number) => (n <= 1 ? base : `${base}${n}/`);
const prevPath = current.current > 1 ? pageHref(basePath, current.current - 1) : undefined;
const nextPath = current.current < current.total ? pageHref(basePath, current.current + 1) : undefined;

const alternates: Partial<Record<Locale, string>> = {
  [locale]: pageHref(basePath, current.current),
};
const other = otherLocale(locale);
const otherTags = await getAllTags(other);
if (otherTags.some((tag) => tag.slug === tagSlug)) {
  const otherBase = localeUrl(other, `tags/${tagSlug}`);
  const otherCount = pageCount((await getPostsByTag(other, tagSlug)).length, pageSize);
  alternates[other] = current.current <= otherCount ? pageHref(otherBase, current.current) : otherBase;
}

const cards: PostCardData[] = current.items.map((post) => ({
  url: postUrl(post),
  title: post.data.title,
  description: post.data.description,
  dateISO: isoDate(post.data.pubDate),
  dateLabel: formatDate(post.data.pubDate, locale),
  readingLabel: dict.post.readingTime(readingTime(post.body ?? "")),
  draftLabel: post.data.draft ? dict.post.draft : undefined,
}));
---

<BaseLayout
  locale={locale}
  title={dict.tags.taggedWith(tagName)}
  description={dict.tags.tagDescription(tagName)}
  alternates={alternates}
  prevPath={prevPath}
  nextPath={nextPath}
>
  <div class="py-10 md:py-14">
    <p class="text-sm font-medium text-muted-foreground">
      <a
        href={localeUrl(locale, "tags")}
        class="underline decoration-accent underline-offset-4 transition-colors hover:text-accent"
      >
        {dict.tags.title}
      </a>
    </p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">
      {dict.tags.taggedWith(tagName)}
    </h1>
    <p class="mt-3 text-muted-foreground">{dict.tags.postsCount(posts.length)}</p>

    <div class="mt-3">
      <PostCardsGrid client:visible posts={cards} />
    </div>

    <Pagination locale={locale} basePath={basePath} current={current.current} total={current.total} />
  </div>
</BaseLayout>
