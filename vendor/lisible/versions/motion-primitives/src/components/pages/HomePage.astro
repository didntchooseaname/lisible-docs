---
import BaseLayout from "@/layouts/BaseLayout.astro";
import JsonLd from "@/components/JsonLd.astro";
import { PostCardsGrid, type PostCardData } from "@/components/react/PostCardsGrid";
import DemoProfileHero from "@shared/components/DemoProfileHero.astro";
import { SITE, FEATURES } from "@/site.config";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import {
  getFeaturedPosts,
  getPublishedPosts,
  postUrl,
  type Post,
} from "@/lib/posts";
import { formatDate, isoDate, readingTime } from "@/lib/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

let featured: Post[];
let latest: Post[];
if (FEATURES.pinned) {
  const result = await getFeaturedPosts(locale, SITE.featuredCount);
  featured = result.featured;
  latest = result.rest.slice(0, SITE.postsPerPage);
} else {
  const posts = await getPublishedPosts(locale);
  featured = posts.slice(0, SITE.featuredCount);
  latest = posts.slice(SITE.featuredCount, SITE.featuredCount + SITE.postsPerPage);
}

function coverUrl(post: Post): string | undefined {
  if (!FEATURES.covers) return undefined;
  const cover = post.data.cover;
  if (!cover) return undefined;
  return typeof cover === "string" ? cover : cover.src;
}

function toCardData(post: Post): PostCardData {
  return {
    url: postUrl(post),
    title: post.data.title,
    description: post.data.description,
    dateISO: isoDate(post.data.pubDate),
    dateLabel: formatDate(post.data.pubDate, locale),
    readingLabel: dict.post.readingTime(readingTime(post.body ?? "")),
    draftLabel: post.data.draft ? dict.post.draft : undefined,
    coverUrl: coverUrl(post),
    coverAlt: post.data.coverAlt ?? post.data.title,
  };
}

const featuredCards = featured.map(toCardData);
const latestCards = latest.map(toCardData);

const alternates = { fr: localeUrl("fr"), en: localeUrl("en") };

const jsonLd = {
  "@type": "WebSite",
  name: SITE.title,
  description: dict.site.description,
  url: new URL(localeUrl(locale), SITE.url).toString(),
  inLanguage: locale,
  author: { "@type": "Person", name: SITE.author },
};
---

<BaseLayout
  locale={locale}
  title={dict.home.metaTitle}
  description={dict.site.description}
  alternates={alternates}
  isHome
>
  <JsonLd slot="head" data={jsonLd} />

  <section class="py-14 md:py-20">
    <DemoProfileHero
      locale={locale}
      variant="motion-primitives"
      title={SITE.title}
      actions={[
        { href: localeUrl(locale, "blog"), label: dict.nav.blog },
        { href: localeUrl(locale, "series"), label: dict.nav.series },
        { href: localeUrl(locale, "about"), label: dict.nav.about },
      ]}
    />
  </section>

  {
    featuredCards.length > 0 && (
      <section aria-labelledby="featured-title" class="py-8" data-preview-featured>
        <h2 id="featured-title" class="text-xl font-bold tracking-tight">
          {dict.home.featured}
        </h2>
        <PostCardsGrid client:visible posts={featuredCards} />
      </section>
    )
  }

  {
    latestCards.length > 0 && (
      <section aria-labelledby="latest-title" class="py-8">
        <div class="flex items-baseline justify-between gap-4">
          <h2 id="latest-title" class="text-xl font-bold tracking-tight">
            {dict.home.latest}
          </h2>
          <a
            href={localeUrl(locale, "blog")}
            class="inline-flex min-h-11 items-center text-sm font-medium underline decoration-accent underline-offset-4 transition-colors hover:text-accent"
          >
            {dict.home.allPosts}
          </a>
        </div>
        <PostCardsGrid client:visible posts={latestCards} />
      </section>
    )
  }
</BaseLayout>
