---
import appCssUrl from "@/styles/app.css?url";
import { ClientRouter } from "astro:transitions";
import LandingLocaleBootstrap from "@shared/components/LandingLocaleBootstrap.astro";
import ExpressiveCodeLabelSpacing from "@shared/components/ExpressiveCodeLabelSpacing.astro";
import PreviewBridge from "@shared/components/PreviewBridge.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SearchModal from "@/components/SearchModal.astro";
import CommandPalette from "@/components/CommandPalette.astro";
import { EdgeBlur } from "@/components/ui/edge-blur";
import { SITE, FEATURES } from "@/site.config";
import { ensureTrailingSlash, localeUrl, ogLocales, otherLocale, t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  ogType?: "website" | "article";
  alternates?: Partial<Record<Locale, string>>;
  isHome?: boolean;
  image?: string;
  prev?: string;
  next?: string;
}

const {
  locale,
  title,
  description,
  ogType = "website",
  alternates,
  isHome = false,
  image = "/og-default.png",
  prev,
  next,
} = Astro.props;

const dict = t(locale);
const pageTitle = isHome ? title : `${title} | ${SITE.title}`;
const canonicalPath = ensureTrailingSlash(Astro.url.pathname);
const canonicalUrl = new URL(canonicalPath, SITE.url);
const ogImage = new URL(image, SITE.url);
const rssPath = localeUrl(locale, "rss.xml");
const hasBothAlternates = Boolean(alternates?.fr && alternates?.en);
const other = otherLocale(locale);
---

<html lang={locale}>
  <head>
    <LandingLocaleBootstrap />
    <ExpressiveCodeLabelSpacing />
    <meta charset="utf-8" />
    <link rel="stylesheet" href={appCssUrl} />
    <script is:inline define:vars={{ defaultAccent: SITE.accent }}>
      (function () {
        function applyTheme() {
          const stored = localStorage.getItem("theme");
          const theme = stored === "light" || stored === "dark"
            ? stored
            : (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
          document.documentElement.classList.toggle("dark", theme === "dark");
        }
        function applyAccent() {
          let hex = localStorage.getItem("accent");
          if (!hex || !/^#[0-9a-fA-F]{6}$/.test(hex)) hex = defaultAccent;
          const lum = (c) => {
            const [r, g, b] = c.map((v) => {
              v /= 255;
              return v <= 0.04045 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
            });
            return 0.2126 * r + 0.7152 * g + 0.0722 * b;
          };
          const dark = document.documentElement.classList.contains("dark");
          let c = [1, 3, 5].map((i) => parseInt(hex.slice(i, i + 2), 16));
          for (let i = 0; i < 60; i++) {
            const L = lum(c);
            if (dark ? (L + 0.05) / 0.05 >= 3 : 1.05 / (L + 0.05) >= 4.5) break;
            c = c.map((v) => v + ((dark ? 255 : 0) - v) * 0.05);
          }
          const L = lum(c);
          const fg = (L + 0.05) / 0.05 >= 1.05 / (L + 0.05) ? "#000000" : "#ffffff";
          const accent = "rgb(" + c.map(Math.round).join(" ") + ")";
          const s = document.documentElement.style;
          s.setProperty("--accent", accent);
          s.setProperty("--accent-foreground", fg);
          s.setProperty("--ring", accent);
        }
        window.__applyAccent = applyAccent;
        applyTheme();
        applyAccent();
        document.addEventListener("astro:after-swap", () => {
          applyTheme();
          applyAccent();
        });
        document.addEventListener("astro:page-load", applyAccent);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <PreviewBridge />
    <link rel="canonical" href={canonicalUrl} />
    {prev && <link rel="prev" href={new URL(prev, SITE.url)} />}
    {next && <link rel="next" href={new URL(next, SITE.url)} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL(rssPath, SITE.url)}
    />


    {
      hasBothAlternates && (
        <>
          <link rel="alternate" hreflang="fr" href={new URL(ensureTrailingSlash(alternates!.fr!), SITE.url)} />
          <link rel="alternate" hreflang="en" href={new URL(ensureTrailingSlash(alternates!.en!), SITE.url)} />
          <link rel="alternate" hreflang="x-default" href={new URL(ensureTrailingSlash(alternates!.fr!), SITE.url)} />
        </>
      )
    }

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocales[locale]} />
    {hasBothAlternates && <meta property="og:locale:alternate" content={ogLocales[other]} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body
    class="flex min-h-dvh flex-col"
    data-gh-stars-label={dict.github.stars}
    data-gh-forks-label={dict.github.forks}
    data-gh-language-label={dict.github.language}
  >
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:border focus:border-border focus:bg-background focus:px-4 focus:py-3 focus:font-medium"
    >
      {dict.a11y.skipToContent}
    </a>
    <Header locale={locale} alternates={alternates} />
    <main id="main" class="mx-auto w-full max-w-6xl flex-1 px-4 md:px-6">
      <slot />
    </main>
    <Footer locale={locale} />
    
    <div aria-hidden="true">
      <EdgeBlur position="bottom" height={48} />
    </div>
    {
      FEATURES.commandPalette ? (
        <CommandPalette locale={locale} alternates={alternates} />
      ) : (
        <SearchModal locale={locale} />
      )
    }
    
    <script>
      import "@/scripts/search-runtime";
    </script>
    <script>import "@shared/scripts/locale-preference";</script>
  </body>
</html>
