---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { GradientHeading } from "@/components/ui/gradient-heading";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { FEATURES } from "@/site.config";
import { getPublishedPosts, groupByYear, paginate } from "@/lib/posts";

interface Props {
  locale: Locale;
  page?: number;
}

const { locale, page = 1 } = Astro.props;
const dict = t(locale);

const allPosts = await getPublishedPosts(locale);

const paginated = FEATURES.pagination.enabled;
const pageData = paginate(
  allPosts,
  paginated ? FEATURES.pagination.pageSize : allPosts.length || 1,
  page,
);
const years = groupByYear(pageData.items);

const base = `/${locale === "fr" ? "" : `${locale}/`}blog`.replace(/\/$/, "");
const alternates =
  page === 1
    ? { fr: localeUrl("fr", "blog"), en: localeUrl("en", "blog") }
    : { fr: localeUrl("fr", `blog/${page}`), en: localeUrl("en", `blog/${page}`) };

const prev =
  paginated && pageData.currentPage > 1
    ? pageData.currentPage - 1 <= 1
      ? `${base}/`
      : `${base}/${pageData.currentPage - 1}/`
    : undefined;
const next =
  paginated && pageData.currentPage < pageData.totalPages
    ? `${base}/${pageData.currentPage + 1}/`
    : undefined;
---

<BaseLayout
  locale={locale}
  title={dict.blog.title}
  description={dict.blog.description}
  alternates={alternates}
  prev={prev}
  next={next}
>
  <div class="py-10 md:py-14">
    <GradientHeading as="h1" size="lg" weight="bold" className="tracking-tight">
      {dict.blog.title}
    </GradientHeading>
    <p class="mt-1 max-w-2xl text-muted-foreground">{dict.blog.description}</p>

    <div class="mt-10 flex flex-col gap-10">
      {
        years.map(([year, yearPosts]) => (
          <section aria-labelledby={`year-${year}`}>
            <h2
              id={`year-${year}`}
              class="border-b border-border pb-2 text-sm font-semibold uppercase tracking-wider text-muted-foreground"
            >
              {year}
            </h2>
            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              {yearPosts.map((post) => (
                <PostCard post={post} headingLevel="h3" />
              ))}
            </div>
          </section>
        ))
      }
    </div>

    {
      paginated && (
        <Pagination
          locale={locale}
          currentPage={pageData.currentPage}
          totalPages={pageData.totalPages}
          base={base}
        />
      )
    }
  </div>
</BaseLayout>
