---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { cn } from "@/lib/utils";

interface Props {
  cover: ImageMetadata | string;
  alt: string;
  class?: string;
  priority?: boolean;
  width?: number;
  sizes?: string;
}

const {
  cover,
  alt,
  class: className,
  priority = false,
  width = 1200,
  sizes = "(min-width: 768px) 72ch, 100vw",
} = Astro.props;

const isPublicPath = typeof cover === "string";
const loading = priority ? "eager" : "lazy";
---

<figure class={cn("cover-frame", className)} data-preview-cover>
  {
    isPublicPath ? (
      <img
        src={cover}
        alt={alt}
        width={width}
        height={Math.round(width / 2)}
        loading={loading}
        decoding="async"
      />
    ) : (
      <Image
        src={cover}
        alt={alt}
        widths={[480, 800, width]}
        sizes={sizes}
        loading={loading}
        decoding="async"
      />
    )
  }
</figure>
