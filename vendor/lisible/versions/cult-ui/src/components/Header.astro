---
import AccentPicker from "@/components/react/AccentPicker";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import SearchButton from "@/components/react/SearchButton";
import ThemeToggleIsland from "@/components/react/ThemeToggleIsland";
import { SITE, FEATURES } from "@/site.config";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { cn } from "@/lib/utils";
import { getPublishedPosts } from "@/lib/posts";

interface Props {
  locale: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const { locale, alternates } = Astro.props;
const dict = t(locale);
const hasSeries = FEATURES.series && (await getPublishedPosts(locale)).some((post) => Boolean(post.data.series));

const navItems = [
  { href: localeUrl(locale, "blog"), label: dict.nav.blog },
  { href: localeUrl(locale, "tags"), label: dict.nav.tags },
  ...(FEATURES.archives
    ? [{ href: localeUrl(locale, "archives"), label: dict.nav.archives }]
    : []),
  ...(hasSeries
    ? [{ href: localeUrl(locale, "series"), label: dict.nav.series }]
    : []),
  { href: localeUrl(locale, "about"), label: dict.nav.about },
];

const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-40 border-b border-border bg-background/85 backdrop-blur">
  <div class="mx-auto flex min-h-16 w-full max-w-6xl flex-wrap items-center justify-between gap-x-4 gap-y-0 px-4 py-2 md:px-6">
    <a
      href={localeUrl(locale)}
      class="inline-flex min-h-11 items-center text-lg font-bold tracking-tight hover:text-accent"
    >
      <span data-preview-site-title>{SITE.title}</span>
    </a>

    <nav aria-label={dict.nav.main} class="order-last w-full sm:order-none sm:w-auto">
      <ul class="flex items-center gap-1">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class={cn(
                  "relative inline-flex min-h-11 items-center rounded-md px-3 text-sm font-medium text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground",
                  isActive(item.href) &&
                    "text-foreground after:absolute after:inset-x-3 after:bottom-1 after:h-0.5 after:rounded-full after:bg-accent",
                )}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <SearchButton label={dict.a11y.openSearch} />
      <LanguageSwitcher locale={locale} alternates={alternates} />
      <AccentPicker
        client:load
        transition:persist="accent-picker"
        defaultAccent={SITE.accent}
        labels={dict.accent}
      />
      <ThemeToggleIsland
        client:load
        transition:persist="theme-toggle"
        label={dict.a11y.toggleTheme}
      />
    </div>
  </div>
</header>
