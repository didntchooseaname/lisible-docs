---
import { FEATURES } from "@/site.config";
import {
  ensureTrailingSlash,
  localeUrl,
  otherLocale,
  t,
  type Locale,
} from "@/i18n/ui";

interface Props {
  locale: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const { locale, alternates } = Astro.props;
const dict = t(locale);
const other = otherLocale(locale);
const switchLangHref = ensureTrailingSlash(
  alternates?.[other] ?? localeUrl(other, "blog"),
);
const rssHref = localeUrl(locale, "rss.xml");

const navItems = [
  { href: localeUrl(locale), label: dict.palette.navHome },
  { href: localeUrl(locale, "blog"), label: dict.palette.navBlog },
  { href: localeUrl(locale, "tags"), label: dict.palette.navTags },
  ...(FEATURES.archives
    ? [{ href: localeUrl(locale, "archives"), label: dict.palette.navArchives }]
    : []),
  { href: localeUrl(locale, "about"), label: dict.palette.navAbout },
];
---

<dialog
  data-search-modal
  data-command-palette
  aria-label={dict.search.title}
  data-hint={dict.palette.hint}
  data-no-results={dict.palette.noResults}
  data-dev-notice={dict.search.devNotice}
  data-copied={dict.palette.actionCopied}
  data-switch-lang-href={switchLangHref}
  data-rss-href={rssHref}
>
  <div class="flex items-center gap-2 border-b border-border px-4">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="shrink-0 text-muted-foreground"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <input
      type="text"
      id="command-palette-input"
      name="command-palette-search"
      role="combobox"
      aria-expanded="true"
      aria-controls="cp-listbox"
      aria-autocomplete="list"
      data-cp-input
      placeholder={dict.palette.placeholder}
      aria-label={dict.search.title}
      autocomplete="off"
      class="h-12 w-full bg-transparent text-base outline-none placeholder:text-muted-foreground"
    />
    <button
      type="button"
      data-search-close
      aria-label={dict.a11y.closeSearch}
      class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>

  <div
    id="cp-listbox"
    role="listbox"
    aria-label={dict.search.title}
    data-cp-list
    class="max-h-[min(60vh,32rem)] overflow-y-auto p-2"
  >
    
    <section data-cp-section="results" hidden>
      <p class="px-3 pb-1 pt-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        {dict.palette.sectionResults}
      </p>
      <div data-cp-results></div>
    </section>

    
    <section data-cp-section="actions">
      <p class="px-3 pb-1 pt-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        {dict.palette.sectionActions}
      </p>
      <button
        type="button"
        role="option"
        id="cp-action-theme"
        data-cp-item
        data-cp-action="toggle-theme"
        aria-selected="false"
        class="flex w-full items-center gap-3 rounded-md px-3 py-2 text-left text-sm transition-colors hover:bg-secondary aria-selected:bg-secondary aria-selected:text-foreground"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4"></path></svg>
        <span>{dict.palette.actionToggleTheme}</span>
      </button>
      <button
        type="button"
        role="option"
        id="cp-action-lang"
        data-cp-item
        data-cp-action="switch-lang"
        aria-selected="false"
        class="flex w-full items-center gap-3 rounded-md px-3 py-2 text-left text-sm transition-colors hover:bg-secondary aria-selected:bg-secondary aria-selected:text-foreground"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground"><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"></path></svg>
        <span>{dict.palette.actionSwitchLang}</span>
      </button>
      <button
        type="button"
        role="option"
        id="cp-action-accent"
        data-cp-item
        data-cp-action="reset-accent"
        aria-selected="false"
        class="flex w-full items-center gap-3 rounded-md px-3 py-2 text-left text-sm transition-colors hover:bg-secondary aria-selected:bg-secondary aria-selected:text-foreground"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground"><path d="M3 3v5h5"></path><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"></path></svg>
        <span>{dict.palette.actionResetAccent}</span>
      </button>
      <button
        type="button"
        role="option"
        id="cp-action-copy"
        data-cp-item
        data-cp-action="copy-url"
        aria-selected="false"
        class="flex w-full items-center gap-3 rounded-md px-3 py-2 text-left text-sm transition-colors hover:bg-secondary aria-selected:bg-secondary aria-selected:text-foreground"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path></svg>
        <span data-cp-copy-label>{dict.palette.actionCopyUrl}</span>
      </button>
    </section>

    
    <section data-cp-section="nav">
      <p class="px-3 pb-1 pt-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        {dict.palette.sectionNav}
      </p>
      {
        navItems.map((item, index) => (
          <a
            href={item.href}
            role="option"
            id={`cp-nav-${index}`}
            data-cp-item
            data-cp-nav
            aria-selected="false"
            class="flex w-full items-center gap-3 rounded-md px-3 py-2 text-left text-sm transition-colors hover:bg-secondary aria-selected:bg-secondary aria-selected:text-foreground"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
            <span>{item.label}</span>
          </a>
        ))
      }
      <a
        href={rssHref}
        role="option"
        id="cp-nav-rss"
        data-cp-item
        data-cp-nav
        aria-selected="false"
        class="flex w-full items-center gap-3 rounded-md px-3 py-2 text-left text-sm transition-colors hover:bg-secondary aria-selected:bg-secondary aria-selected:text-foreground"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
        <span>{dict.palette.openRss}</span>
      </a>
    </section>

    <p data-cp-empty hidden class="px-3 py-6 text-center text-sm text-muted-foreground">
      {dict.palette.noResults}
    </p>
  </div>
</dialog>
