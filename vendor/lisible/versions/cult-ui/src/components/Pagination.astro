---
import { t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  currentPage: number;
  totalPages: number;
  base: string;
}

const { locale, currentPage, totalPages, base } = Astro.props;
const dict = t(locale);

function pageHref(page: number): string {
  return page <= 1 ? `${base}/` : `${base}/${page}/`;
}

const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
---

{
  totalPages > 1 && (
    <nav
      aria-label={dict.paginate.label}
      class="mt-12 flex items-center justify-between gap-4 border-t border-border pt-6"
    >
      {hasPrev ? (
        <a
          href={pageHref(currentPage - 1)}
          rel="prev"
          class="inline-flex min-h-11 items-center gap-1.5 rounded-md border border-border px-3 text-sm font-medium text-muted-foreground transition-colors hover:border-accent hover:text-accent"
        >
          <span aria-hidden="true">&larr;</span>
          {dict.paginate.prev}
        </a>
      ) : (
        <span />
      )}

      <span class="text-sm tabular-nums text-muted-foreground">
        {dict.paginate.pageOf(currentPage, totalPages)}
      </span>

      {hasNext ? (
        <a
          href={pageHref(currentPage + 1)}
          rel="next"
          class="inline-flex min-h-11 items-center gap-1.5 rounded-md border border-border px-3 text-sm font-medium text-muted-foreground transition-colors hover:border-accent hover:text-accent"
        >
          {dict.paginate.next}
          <span aria-hidden="true">&rarr;</span>
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}
