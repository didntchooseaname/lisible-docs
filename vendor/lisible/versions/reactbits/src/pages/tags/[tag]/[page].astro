---
import TagPage from "@/components/pages/TagPage.astro";
import { getAllTags, getPostsByTag } from "@/lib/posts";
import { FEATURES } from "@/site.config";

export async function getStaticPaths() {
  if (!FEATURES.pagination.enabled) return [];
  const tags = await getAllTags("fr");
  const paths = [];
  for (const tag of tags) {
    const posts = await getPostsByTag("fr", tag.slug);
    const total = Math.ceil(posts.length / FEATURES.pagination.pageSize);
    for (let n = 2; n <= total; n++) {
      paths.push({
        params: { tag: tag.slug, page: String(n) },
        props: { tagName: tag.name, posts, page: n },
      });
    }
  }
  return paths;
}

const { tag } = Astro.params;
const { tagName, posts, page } = Astro.props;
---

<TagPage locale="fr" tagSlug={tag!} tagName={tagName} posts={posts} page={page} />
