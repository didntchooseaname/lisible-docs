---
import { render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TOC from "@/components/TOC.astro";
import TagBadge from "@/components/TagBadge.astro";
import JsonLd from "@/components/JsonLd.astro";
import Cover from "@/components/Cover.astro";
import RelatedPosts from "@/components/RelatedPosts.astro";
import EditOnGithub from "@/components/EditOnGithub.astro";
import ImageLightbox from "@/components/ImageLightbox.astro";
import FadeContent from "@/components/ui/FadeContent";
import GradualBlur from "@/components/ui/GradualBlur";
import { SITE, FEATURES } from "@/site.config";
import { ensureTrailingSlash, otherLocale, t, type Locale } from "@/i18n/ui";
import {
  getAdjacentPosts,
  getRelatedPosts,
  getSeries,
  getTranslation,
  postFilePath,
  postLocale,
  postOgPath,
  postUrl,
  type Post,
} from "@/lib/posts";
import PostActions from "@/components/PostActions.astro";
import SeriesNav from "@/components/SeriesNav.astro";
import Webmentions from "@/components/Webmentions.astro";
import Comments from "@/components/Comments.astro";
import DiscussionPlaceholders from "@shared/components/DiscussionPlaceholders.astro";
import { formatDate, isoDate, readingTime } from "@/lib/utils";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const locale = postLocale(post);
const dict = t(locale);
const { Content, headings } = await render(post);
const { older, newer } = await getAdjacentPosts(post);
const translation = await getTranslation(post);
const minutes = readingTime(post.body ?? "");

const related = FEATURES.relatedPosts ? await getRelatedPosts(post, 3) : [];
const series = FEATURES.series ? await getSeries(post) : undefined;

const ogImagePath = FEATURES.ogPerPost ? postOgPath(post) : undefined;

const hasMath =
  FEATURES.math &&
  /\$\$[\s\S]+?\$\$|\$[^\s$][^$\n]*\$/.test(post.body ?? "");

const editPath = postFilePath(post);

const currentPath = ensureTrailingSlash(Astro.url.pathname);
const shareUrl = new URL(currentPath, SITE.url).toString();
const alternates: Partial<Record<Locale, string>> = { [locale]: currentPath };
if (translation) {
  alternates[otherLocale(locale)] = postUrl(translation);
}

const jsonLd = {
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: isoDate(post.data.pubDate),
  dateModified: isoDate(post.data.updatedDate ?? post.data.pubDate),
  author: { "@type": "Person", name: SITE.author },
  inLanguage: locale,
  image: new URL("/og-default.png", SITE.url).toString(),
  mainEntityOfPage: new URL(currentPath, SITE.url).toString(),
};
---

<BaseLayout
  locale={locale}
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  alternates={alternates}
  ogImagePath={ogImagePath}
>
  <Fragment slot="head">
    <JsonLd data={jsonLd} />
    {hasMath && <link rel="stylesheet" href="/katex/katex.min.css" />}
  </Fragment>

  
  <div
    data-progress-bar
    aria-hidden="true"
    class="fixed inset-x-0 top-0 z-50 h-0.5 origin-left scale-x-0 bg-accent"
  >
  </div>

  <div class="py-10 md:py-14 lg:grid lg:grid-cols-[minmax(0,1fr)_15rem] lg:gap-12">
    <article data-pagefind-body class="min-w-0 max-w-[72ch]">
      {
        FEATURES.covers && post.data.cover && SITE.coverPosition === "up" && (
          <Cover
            cover={post.data.cover}
            alt={post.data.coverAlt ?? post.data.title}
            class="post-cover"
            loading="eager"
          />
        )
      }
      <header>
        <h1 class="text-balance text-3xl font-bold tracking-tight md:text-4xl">
          {post.data.title}
        </h1>
        <p class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-muted-foreground">
          <span>
            {dict.post.publishedOn}{" "}
            <time datetime={isoDate(post.data.pubDate)}>
              {formatDate(post.data.pubDate, locale)}
            </time>
          </span>
          <span aria-hidden="true">&middot;</span>
          <span>{dict.post.readingTime(minutes)}</span>
          {
            post.data.draft && (
              <>
                <span aria-hidden="true">&middot;</span>
                <span class="inline-flex items-center rounded-md border border-border px-1.5 py-0.5 text-xs font-medium">
                  {dict.post.draft}
                </span>
              </>
            )
          }
        </p>
        {
          post.data.updatedDate && (
            <p class="mt-1 text-sm text-muted-foreground">
              {dict.post.updatedOn}{" "}
              <time datetime={isoDate(post.data.updatedDate)}>
                {formatDate(post.data.updatedDate, locale)}
              </time>
            </p>
          )
        }
        {
          post.data.tags.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-2" aria-label={dict.post.tags}>
              {post.data.tags.map((tag) => (
                <li>
                  <TagBadge tag={tag} locale={locale} />
                </li>
              ))}
            </ul>
          )
        }
      </header>

      {
        FEATURES.covers && post.data.cover && SITE.coverPosition === "down" && (
          <Cover
            cover={post.data.cover}
            alt={post.data.coverAlt ?? post.data.title}
            class="post-cover"
            loading="eager"
          />
        )
      }

      {series && <SeriesNav series={series} current={post} locale={locale} class="mt-8" />}

      <div class="prose mt-10">
        <Content />
      </div>

      {
        FEATURES.aiButtons || FEATURES.socialShare ? (
          <PostActions
            locale={locale}
            title={post.data.title}
            url={shareUrl}
            markdown={post.body ?? ""}
          />
        ) : null
      }

      {
        SITE.repo.url && (
          <div class="mt-10 flex justify-end border-t border-border pt-6">
            <EditOnGithub locale={locale} path={editPath} />
          </div>
        )
      }

      {
        FEATURES.relatedPosts && related.length > 0 && (
          <RelatedPosts posts={related} locale={locale} />
        )
      }

      {
        (older || newer) && (
          <FadeContent client:visible duration={500} threshold={0.05}>
          <nav
            aria-label={dict.post.pagination}
            class="mt-14 grid gap-4 border-t border-border pt-8 sm:grid-cols-2"
          >
            {older ? (
              <a
                href={postUrl(older)}
                class="group flex flex-col gap-1 rounded-lg border border-border p-4 transition-colors hover:border-accent"
              >
                <span class="text-xs text-muted-foreground">{dict.post.prev}</span>
                <span class="font-medium transition-colors group-hover:text-accent">
                  {older.data.title}
                </span>
              </a>
            ) : (
              <span aria-hidden="true" />
            )}
            {newer && (
              <a
                href={postUrl(newer)}
                class="group flex flex-col gap-1 rounded-lg border border-border p-4 text-right transition-colors hover:border-accent sm:col-start-2"
              >
                <span class="text-xs text-muted-foreground">{dict.post.next}</span>
                <span class="font-medium transition-colors group-hover:text-accent">
                  {newer.data.title}
                </span>
              </a>
            )}
          </nav>
          </FadeContent>
        )
      }

      {FEATURES.webmentions && <Webmentions url={shareUrl} locale={locale} class="mt-14" />}
      {FEATURES.comments && <Comments post={post} locale={locale} url={shareUrl} class="mt-14" />}
      {FEATURES.demoPlaceholders && <DiscussionPlaceholders locale={locale} />}
    </article>

    <aside class="hidden lg:block">
      
      <div class="sticky top-24 relative">
        <div class="max-h-[calc(100vh-7rem)] overflow-y-auto pb-8">
          <TOC headings={headings} locale={locale} />
        </div>
        <GradualBlur position="bottom" height="2.5rem" strength={1} divCount={4} opacity={0.9} />
      </div>
    </aside>
  </div>

  
  <button
    type="button"
    data-back-to-top
    aria-label={dict.a11y.backToTop}
    class="fixed bottom-6 right-6 z-40 inline-flex h-11 w-11 items-center justify-center rounded-md border border-border bg-card text-muted-foreground shadow-sm transition-colors hover:text-foreground"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m18 15-6-6-6 6"></path>
    </svg>
  </button>

  
  {FEATURES.imageZoom && <ImageLightbox locale={locale} />}

  
  <script>
    import "@/scripts/github-card";
  </script>

  
  <script>
    import "@/scripts/lecture";
  </script>

  <script>
    let ticking = false;

    function update() {
      const doc = document.documentElement;

      const bar = document.querySelector<HTMLElement>("[data-progress-bar]");
      if (bar) {
        const max = doc.scrollHeight - doc.clientHeight;
        const progress = max > 0 ? Math.min(1, doc.scrollTop / max) : 0;
        bar.style.transform = `scaleX(${progress})`;
      }

      const backToTop = document.querySelector<HTMLElement>("[data-back-to-top]");
      if (backToTop) {
        backToTop.classList.toggle("is-visible", doc.scrollTop > 500);
      }
    }

    document.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
      },
      { passive: true },
    );

    document.addEventListener("astro:page-load", update);

    document.addEventListener("click", (event) => {
      const target = event.target as HTMLElement | null;
      if (!target?.closest("[data-back-to-top]")) return;
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      window.scrollTo({ top: 0, behavior: reduceMotion ? "auto" : "smooth" });
    });
  </script>
</BaseLayout>
