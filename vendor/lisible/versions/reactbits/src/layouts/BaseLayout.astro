---
import appCssUrl from "@/styles/app.css?url";
import { ClientRouter } from "astro:transitions";
import LandingLocaleBootstrap from "@shared/components/LandingLocaleBootstrap.astro";
import ExpressiveCodeLabelSpacing from "@shared/components/ExpressiveCodeLabelSpacing.astro";
import PreviewBridge from "@shared/components/PreviewBridge.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SearchModal from "@/components/SearchModal.astro";
import ClickSpark from "@/components/ui/ClickSpark";
import Noise from "@/components/ui/Noise";
import { SITE } from "@/site.config";
import { ensureTrailingSlash, localeUrl, ogLocales, otherLocale, t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  ogType?: "website" | "article";
  alternates?: Partial<Record<Locale, string>>;
  isHome?: boolean;
  ogImagePath?: string;
}

const {
  locale,
  title,
  description,
  ogType = "website",
  alternates,
  isHome = false,
  ogImagePath = "/og-default.png",
} = Astro.props;

const dict = t(locale);
const pageTitle = isHome ? title : `${title} | ${SITE.title}`;
const canonicalPath = ensureTrailingSlash(Astro.url.pathname);
const canonicalUrl = new URL(canonicalPath, SITE.url);
const ogImage = new URL(ogImagePath, SITE.url);
const rssPath = localeUrl(locale, "rss.xml");
const hasBothAlternates = Boolean(alternates?.fr && alternates?.en);
const other = otherLocale(locale);
---

<html lang={locale}>
  <head>
    <LandingLocaleBootstrap />
    <ExpressiveCodeLabelSpacing />
    <meta charset="utf-8" />
    <link rel="stylesheet" href={appCssUrl} />
    <script is:inline define:vars={{ defaultAccent: SITE.accent }}>
      (function () {
        function applyTheme() {
          const stored = localStorage.getItem("theme");
          const theme = stored === "light" || stored === "dark"
            ? stored
            : (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
          document.documentElement.classList.toggle("dark", theme === "dark");
        }
        function lum(c) {
          const f = (v) => {
            v /= 255;
            return v <= 0.04045 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
          };
          return 0.2126 * f(c[0]) + 0.7152 * f(c[1]) + 0.0722 * f(c[2]);
        }
        function contrast(a, b) {
          return (Math.max(a, b) + 0.05) / (Math.min(a, b) + 0.05);
        }
        function applyAccent() {
          const stored = localStorage.getItem("accent");
          const raw = /^#[0-9a-fA-F]{6}$/.test(stored || "") ? stored : defaultAccent;
          let c = [1, 3, 5].map((i) => parseInt(raw.slice(i, i + 2), 16));
          const dark = document.documentElement.classList.contains("dark");
          for (let i = 0; i < 60; i++) {
            if (dark ? contrast(lum(c), 0) >= 3 : contrast(lum(c), 1) >= 4.5) break;
            c = c.map((v) => (dark ? v + (255 - v) * 0.08 + 0.5 : v * 0.92));
          }
          const hex = "#" + c.map((v) => Math.round(v).toString(16).padStart(2, "0")).join("");
          const fg = contrast(lum(c), 0) >= 4.5 ? "#000000" : "#ffffff";
          const s = document.documentElement.style;
          s.setProperty("--accent", hex);
          s.setProperty("--accent-foreground", fg);
          s.setProperty("--ring", hex);
        }
        window.__applyAccent = applyAccent;
        applyTheme();
        applyAccent();
        document.addEventListener("astro:after-swap", () => {
          applyTheme();
          applyAccent();
        });
        document.addEventListener("astro:page-load", applyAccent);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <PreviewBridge />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL(rssPath, SITE.url)}
    />


    {
      hasBothAlternates && (
        <>
          <link rel="alternate" hreflang="fr" href={new URL(ensureTrailingSlash(alternates!.fr!), SITE.url)} />
          <link rel="alternate" hreflang="en" href={new URL(ensureTrailingSlash(alternates!.en!), SITE.url)} />
          <link rel="alternate" hreflang="x-default" href={new URL(ensureTrailingSlash(alternates!.fr!), SITE.url)} />
        </>
      )
    }

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocales[locale]} />
    {hasBothAlternates && <meta property="og:locale:alternate" content={ogLocales[other]} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="flex min-h-dvh flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:border focus:border-border focus:bg-background focus:px-4 focus:py-3 focus:font-medium"
    >
      {dict.a11y.skipToContent}
    </a>
    <Header locale={locale} alternates={alternates} />
    <main id="main" class="mx-auto w-full max-w-6xl flex-1 px-4 md:px-6">
      <slot />
    </main>
    <Footer locale={locale} />
    <SearchModal locale={locale} />

    
    <Noise client:idle patternAlpha={7} />
    
    <ClickSpark client:idle />
    <script>import "@shared/scripts/locale-preference";</script>
  </body>
</html>
