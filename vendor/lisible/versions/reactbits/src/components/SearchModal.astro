---
import { FEATURES } from "@/site.config";
import { localeUrl, t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const palette = FEATURES.commandPalette;

const icon = (paths: string) =>
  `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${paths}</svg>`;

type Cmd = { cmd: string; label: string; href?: string; keywords: string; icon: string };

const actions: Cmd[] = [
  { cmd: "theme", label: dict.palette.toggleTheme, keywords: "theme dark light clair sombre mode", icon: icon('<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>') },
  { cmd: "lang", label: dict.palette.switchLanguage, keywords: "language langue fr en english français traduction", icon: icon('<path d="m5 8 6 6M4 14l6-6 2-3M2 5h12M7 2h1M22 22l-5-10-5 10M14 18h6"/>') },
  { cmd: "accent-reset", label: dict.palette.resetAccent, keywords: "accent color couleur reset reinitialiser theme", icon: icon('<path d="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z"/><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/>') },
  { cmd: "copy-url", label: dict.palette.copyUrl, keywords: "copy url link lien copier partager", icon: icon('<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>') },
];

const navCommands: Cmd[] = [
  { cmd: "nav", label: dict.palette.goHome, href: localeUrl(locale), keywords: "home accueil index", icon: icon('<path d="M3 9.5 12 3l9 6.5V20a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1z"/>') },
  { cmd: "nav", label: dict.palette.goBlog, href: localeUrl(locale, "blog"), keywords: "blog articles posts", icon: icon('<path d="M4 4h11l5 5v11a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z"/><path d="M14 4v5h5M8 13h8M8 17h5"/>') },
  { cmd: "nav", label: dict.palette.goTags, href: localeUrl(locale, "tags"), keywords: "tags mots-cles categories", icon: icon('<path d="M3 7v5.2a2 2 0 0 0 .6 1.4l7 7a2 2 0 0 0 2.8 0l5.4-5.4a2 2 0 0 0 0-2.8l-7-7A2 2 0 0 0 10.2 5H5a2 2 0 0 0-2 2z"/><circle cx="7.5" cy="9.5" r="1"/>') },
  ...(FEATURES.archives
    ? [{ cmd: "nav", label: dict.palette.goArchives, href: localeUrl(locale, "archives"), keywords: "archives timeline historique", icon: icon('<rect x="3" y="4" width="18" height="4" rx="1"/><path d="M5 8v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V8M10 12h4"/>') }]
    : []),
  { cmd: "nav", label: dict.palette.goAbout, href: localeUrl(locale, "about"), keywords: "about a propos auteur", icon: icon('<circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>') },
  { cmd: "nav", label: dict.palette.openRss, href: localeUrl(locale, "rss.xml"), keywords: "rss flux feed abonnement", icon: icon('<path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>') },
];
---

<dialog
  data-search-modal
  data-palette={palette ? "on" : undefined}
  aria-label={dict.search.title}
  data-hint={dict.search.hint}
  data-no-results={dict.search.noResults}
  data-dev-notice={dict.search.devNotice}
  data-url-copied={dict.palette.urlCopied}
  data-search-section={dict.palette.searchSection}
>
  <div class="flex items-center gap-2 border-b border-border px-4">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <input
      type="search"
      id="search-input"
      name="search"
      data-search-input
      placeholder={dict.search.placeholder}
      aria-label={dict.search.title}
      autocomplete="off"
      class="h-12 w-full bg-transparent text-base outline-none placeholder:text-muted-foreground"
    />
    <button
      type="button"
      data-search-close
      aria-label={dict.a11y.closeSearch}
      class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>

  <div class="max-h-[55vh] overflow-y-auto p-2">
    
    <div data-search-results>
      <p class="palette-empty">{dict.search.hint}</p>
    </div>

    {
      palette && (
        <div data-palette-commands>
          <section class="palette-section" data-palette-group>
            <p class="palette-section__title">{dict.palette.actionsSection}</p>
            <ul>
              {actions.map((a) => (
                <li>
                  <button type="button" class="palette-item" data-palette-item data-cmd={a.cmd} data-keywords={a.keywords}>
                    <span class="palette-item__icon" set:html={a.icon} />
                    <span class="palette-item__label">{a.label}</span>
                  </button>
                </li>
              ))}
            </ul>
          </section>
          <section class="palette-section" data-palette-group>
            <p class="palette-section__title">{dict.palette.navSection}</p>
            <ul>
              {navCommands.map((n) => (
                <li>
                  <a class="palette-item" href={n.href} data-palette-item data-cmd={n.cmd} data-keywords={n.keywords}>
                    <span class="palette-item__icon" set:html={n.icon} />
                    <span class="palette-item__label">{n.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        </div>
      )
    }
  </div>

  {palette && <p class="palette-footer">{dict.palette.hint}</p>}
</dialog>

<script>
  import { navigate } from "astro:transitions/client";

  type PagefindResult = {
    data: () => Promise<{
      url: string;
      excerpt: string;
      meta: { title?: string };
    }>;
  };

  type PagefindModule = {
    options: (options: Record<string, unknown>) => Promise<void>;
    init: () => void;
    debouncedSearch: (
      query: string,
    ) => Promise<{ results: PagefindResult[] } | null>;
  };

  let pagefind: PagefindModule | null = null;
  let loadFailed = false;
  let activeIndex = -1;

  function getModal(): HTMLDialogElement | null {
    return document.querySelector<HTMLDialogElement>("[data-search-modal]");
  }

  function isPalette(modal: HTMLDialogElement): boolean {
    return modal.dataset.palette === "on";
  }

  function getInput(modal: HTMLDialogElement): HTMLInputElement | null {
    return modal.querySelector<HTMLInputElement>("[data-search-input]");
  }

  function resultsBox(modal: HTMLDialogElement): HTMLElement | null {
    return modal.querySelector<HTMLElement>("[data-search-results]");
  }

  function renderMessage(modal: HTMLDialogElement, message: string) {
    const container = resultsBox(modal);
    if (!container) return;
    container.innerHTML = "";
    const p = document.createElement("p");
    p.className = "palette-empty";
    p.textContent = message;
    container.appendChild(p);
  }

  function navigable(modal: HTMLDialogElement): HTMLElement[] {
    return Array.from(
      modal.querySelectorAll<HTMLElement>("[data-palette-item], [data-result]"),
    ).filter((el) => el.offsetParent !== null);
  }

  function setActive(modal: HTMLDialogElement, index: number) {
    const items = navigable(modal);
    items.forEach((el) => el.classList.remove("is-active"));
    if (items.length === 0) {
      activeIndex = -1;
      return;
    }
    activeIndex = ((index % items.length) + items.length) % items.length;
    const el = items[activeIndex];
    el.classList.add("is-active");
    el.scrollIntoView({ block: "nearest" });
  }

  function filterCommands(modal: HTMLDialogElement, query: string) {
    const commands = modal.querySelector<HTMLElement>("[data-palette-commands]");
    if (!commands) return;
    const q = query.trim().toLowerCase();
    commands.querySelectorAll<HTMLElement>("[data-palette-group]").forEach((group) => {
      let visible = 0;
      group.querySelectorAll<HTMLElement>("[data-palette-item]").forEach((item) => {
        const label = item.querySelector(".palette-item__label")?.textContent ?? "";
        const hay = `${label} ${item.dataset.keywords ?? ""}`.toLowerCase();
        const match = q === "" || hay.includes(q);
        (item.closest("li") as HTMLElement).hidden = !match;
        if (match) visible += 1;
      });
      group.hidden = visible === 0;
    });
  }

  async function ensurePagefind(): Promise<void> {
    if (pagefind || loadFailed) return;
    try {
      const module = (await import(
        /* @vite-ignore */ "/pagefind/pagefind.js"
      )) as PagefindModule;
      await module.options({ excerptLength: 25 });
      module.init();
      pagefind = module;
    } catch {
      loadFailed = true;
    }
  }

  async function openSearch(): Promise<void> {
    const modal = getModal();
    if (!modal || modal.open) return;
    modal.showModal();
    const input = getInput(modal);
    if (input) input.value = "";
    filterCommands(modal, "");
    renderResultsHint(modal);
    input?.focus();
    setActive(modal, 0);
    await ensurePagefind();
  }

  function renderResultsHint(modal: HTMLDialogElement) {
    const container = resultsBox(modal);
    if (!container) return;
    if (isPalette(modal)) {
      container.innerHTML = "";
    } else {
      renderMessage(modal, modal.dataset.hint ?? "");
    }
    if (loadFailed && !isPalette(modal)) {
      renderMessage(modal, modal.dataset.devNotice ?? "");
    }
  }

  async function runSearch(modal: HTMLDialogElement, query: string): Promise<void> {
    const container = resultsBox(modal);
    if (!container) return;
    const q = query.trim();

    if (!q) {
      renderResultsHint(modal);
      setActive(modal, 0);
      return;
    }
    if (loadFailed) {
      renderMessage(modal, modal.dataset.devNotice ?? "");
      setActive(modal, 0);
      return;
    }
    if (!pagefind) return;

    const search = await pagefind.debouncedSearch(q);
    if (!search) return;

    const results = await Promise.all(
      search.results.slice(0, 6).map((result) => result.data()),
    );

    container.innerHTML = "";
    if (results.length === 0) {
      if (!isPalette(modal)) renderMessage(modal, modal.dataset.noResults ?? "");
      setActive(modal, 0);
      return;
    }

    if (isPalette(modal)) {
      const title = document.createElement("p");
      title.className = "palette-section__title";
      title.textContent = modal.dataset.searchSection ?? "";
      container.appendChild(title);
    }

    const list = document.createElement("ul");
    for (const result of results) {
      const item = document.createElement("li");
      const link = document.createElement("a");
      link.href = result.url;
      link.className = "palette-item palette-item--result";
      link.setAttribute("data-result", "");
      const body = document.createElement("span");
      body.className = "palette-item__label";
      const title = document.createElement("span");
      title.className = "palette-result__title";
      title.textContent = result.meta.title ?? result.url;
      const excerpt = document.createElement("span");
      excerpt.className = "palette-result__excerpt";
      excerpt.innerHTML = result.excerpt;
      body.append(title, excerpt);
      link.appendChild(body);
      item.appendChild(link);
      list.appendChild(item);
    }
    container.appendChild(list);
    setActive(modal, 0);
  }

  async function copyText(text: string): Promise<boolean> {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      return false;
    }
  }

  function otherLangHref(): string | null {
    const anchors = document.querySelectorAll<HTMLAnchorElement>(
      'header a[hreflang]',
    );
    for (const a of anchors) {
      if (a.getAttribute("aria-current") !== "true") return a.getAttribute("href");
    }
    return null;
  }

  function runCommand(modal: HTMLDialogElement, item: HTMLElement): void {
    const cmd = item.dataset.cmd;

    if (cmd === "theme") {
      modal.close();
      document.querySelector<HTMLElement>("[data-theme-toggle]")?.click();
      return;
    }
    if (cmd === "lang") {
      const href = otherLangHref();
      modal.close();
      if (href) {
        localStorage.setItem("lisible-locale", href.startsWith("/en") ? "en" : "fr");
        void navigate(href);
      }
      return;
    }
    if (cmd === "accent-reset") {
      localStorage.removeItem("accent");
      (window as unknown as { __applyAccent?: () => void }).__applyAccent?.();
      modal.close();
      return;
    }
    if (cmd === "copy-url") {
      void copyText(window.location.href).then((ok) => {
        if (!ok) return;
        const label = item.querySelector<HTMLElement>(".palette-item__label");
        if (!label) return;
        const previous = label.textContent;
        label.textContent = modal.dataset.urlCopied ?? "";
        item.classList.add("is-done");
        window.setTimeout(() => {
          label.textContent = previous;
          item.classList.remove("is-done");
        }, 1400);
      });
      return;
    }
    if (item instanceof HTMLAnchorElement) {
      item.click();
    }
  }

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;
    if (target?.closest("[data-search-open]")) {
      void openSearch();
      return;
    }
    if (target?.closest("[data-search-close]")) {
      getModal()?.close();
      return;
    }
    const modal = getModal();
    if (!modal) return;

    const item = target?.closest<HTMLElement>("[data-palette-item], [data-result]");
    if (item && modal.contains(item)) {
      const cmd = item.dataset.cmd;
      if (cmd && cmd !== "nav") {
        event.preventDefault();
        runCommand(modal, item);
      }
      return;
    }

    if (modal.open && event.target === modal) {
      modal.close();
    }
  });

  document.addEventListener("keydown", (event) => {
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      const modal = getModal();
      if (modal?.open) modal.close();
      else void openSearch();
      return;
    }

    const modal = getModal();
    if (!modal?.open) return;

    if (event.key === "ArrowDown") {
      event.preventDefault();
      setActive(modal, activeIndex + 1);
    } else if (event.key === "ArrowUp") {
      event.preventDefault();
      setActive(modal, activeIndex - 1);
    } else if (event.key === "Enter") {
      const items = navigable(modal);
      const el = items[activeIndex];
      if (el) {
        event.preventDefault();
        runCommand(modal, el);
      }
    }
  });

  document.addEventListener("input", (event) => {
    const input = event.target as HTMLInputElement | null;
    if (!input?.matches("[data-search-input]")) return;
    const modal = getModal();
    if (!modal) return;
    filterCommands(modal, input.value);
    void runSearch(modal, input.value);
  });

  document.addEventListener("mousemove", (event) => {
    const modal = getModal();
    if (!modal?.open) return;
    const target = event.target as HTMLElement | null;
    const item = target?.closest<HTMLElement>("[data-palette-item], [data-result]");
    if (!item) return;
    const items = navigable(modal);
    const index = items.indexOf(item);
    if (index >= 0 && index !== activeIndex) setActive(modal, index);
  });

  document.addEventListener("astro:before-swap", () => {
    getModal()?.close();
  });
</script>
