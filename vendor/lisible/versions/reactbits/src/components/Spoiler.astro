---
import { FEATURES } from "@/site.config";
import { t, defaultLocale, type Locale } from "@/i18n/ui";

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const dict = t(locale).mdx;
---

{
  FEATURES.mdxComponents ? (
    <button
      type="button"
      class="spoiler"
      data-spoiler
      aria-expanded="false"
      aria-label={dict.spoilerShow}
      data-label-show={dict.spoilerShow}
      data-label-hide={dict.spoilerHide}
    >
      <span class="spoiler__content"><slot /></span>
    </button>
  ) : (
    <span class="spoiler spoiler--plain"><slot /></span>
  )
}

{
  FEATURES.mdxComponents && (
    <script>import "@/scripts/spoiler";</script>
  )
}
