---
import { SITE } from "@/site.config";
import { t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
const dict = t(locale);
const repo = SITE.repo;
const repoPath = [path.startsWith("/") ? "" : repo.contentBase, path]
  .filter(Boolean)
  .map((part) => part.replace(/^\/+|\/+$/g, ""))
  .join("/");
const href = repo.url
  ? `${repo.url.replace(/\/$/, "")}/edit/${repo.branch}/${repoPath}`
  : null;
---

{
  href && (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer external"
      class="inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-accent"
      aria-label={dict.post.editOnGithub}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 20h9" />
        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z" />
      </svg>
      <span>{dict.post.editOnGithub}</span>
    </a>
  )
}
