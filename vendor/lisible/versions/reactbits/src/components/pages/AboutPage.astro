---
import BaseLayout from "@/layouts/BaseLayout.astro";
import GradientText from "@/components/ui/GradientText";
import DecryptedText from "@/components/ui/DecryptedText";
import FadeContent from "@/components/ui/FadeContent";
import CountUp from "@/components/ui/CountUp";
import TechLogoLoop from "@/components/TechLogoLoop";
import EditOnGithub from "@/components/EditOnGithub.astro";
import { SITE } from "@/site.config";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { getAllTags, getPublishedPosts } from "@/lib/posts";
import { readingTime } from "@/lib/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

const alternates = { fr: localeUrl("fr", "about"), en: localeUrl("en", "about") };

const posts = await getPublishedPosts(locale);
const tags = await getAllTags(locale);
const totalMinutes = posts.reduce((sum, post) => sum + readingTime(post.body ?? ""), 0);

const stats = [
  { value: posts.length, label: dict.about.statPosts },
  { value: tags.length, label: dict.about.statTags },
  { value: 2, label: dict.about.statLanguages },
  { value: totalMinutes, label: dict.about.statMinutes },
];

const [intro, ...rest] = dict.about.paragraphs;
---

<BaseLayout
  locale={locale}
  title={dict.about.title}
  description={dict.about.description}
  alternates={alternates}
>
  <div class="py-10 md:py-14">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">
      
      <GradientText
        client:visible
        colors={[
          "var(--color-accent)",
          "color-mix(in oklab, var(--color-accent) 55%, var(--color-foreground))",
          "var(--color-accent)",
        ]}
        animationSpeed={6}
      >
        {dict.about.title}
      </GradientText>
    </h1>

    <div class="prose mt-8">
      <p>
        
        <DecryptedText
          client:visible
          text={intro}
          animateOn="view"
          sequential
          speed={12}
          revealDirection="start"
          encryptedClassName="text-muted-foreground"
        />
      </p>
      {rest.map((paragraph) => <p>{paragraph}</p>)}
      <p>
        {SITE.social.github && (
          <Fragment>
            <a href={SITE.social.github}>GitHub</a> &middot;{" "}
          </Fragment>
        )}
        <a href={localeUrl(locale, "rss.xml")}>RSS</a>
      </p>
    </div>

    
    <section aria-label={dict.about.statsTitle} class="mt-12">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        {dict.about.statsTitle}
      </h2>
      <FadeContent client:visible duration={500} className="mt-4">
        <dl class="grid grid-cols-2 gap-4 sm:grid-cols-4">
          {
            stats.map((stat) => (
              <div class="flex flex-col-reverse rounded-lg border border-border bg-card p-4">
                <dt class="mt-1 text-xs text-muted-foreground">{stat.label}</dt>
                <dd class="text-2xl font-bold tabular-nums tracking-tight text-foreground">
                  <CountUp client:visible locale={locale} to={stat.value} duration={1.2} />
                </dd>
              </div>
            ))
          }
        </dl>
      </FadeContent>
    </section>

    
    <section aria-label={dict.about.stackAria} class="mt-12">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        {dict.about.stackTitle}
      </h2>
      <div class="mt-4 border-y border-border py-4">
        <TechLogoLoop client:visible ariaLabel={dict.about.stackAria} />
      </div>
    </section>

    {
      SITE.repo.url && (
        <div class="mt-12 flex justify-end border-t border-border pt-6">
          <EditOnGithub locale={locale} path="src/components/pages/AboutPage.astro" />
        </div>
      )
    }
  </div>
</BaseLayout>
