---
import { postLocale, postUrl, type Post } from "@/lib/posts";
import { formatDate, isoDate, readingTime } from "@/lib/utils";
import { t } from "@/i18n/ui";

interface Props {
  posts: Post[];
  locale: import("@/i18n/ui").Locale;
}

const { posts, locale } = Astro.props;
const dict = t(locale);
---

{
  posts.length > 0 && (
    <section aria-labelledby="related-title" class="mt-14 border-t border-border pt-8" data-preview-related>
      <h2 id="related-title" class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        {dict.post.related}
      </h2>
      <ul class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post: Post) => {
          const minutes = readingTime(post.body ?? "");
          return (
            <li>
              <a
                href={postUrl(post)}
                class="group flex h-full flex-col gap-2 rounded-lg border border-border p-4 transition-colors hover:border-accent"
              >
                <span class="font-medium leading-snug transition-colors group-hover:text-accent">
                  {post.data.title}
                </span>
                <span class="mt-auto flex flex-wrap items-center gap-x-2 text-xs text-muted-foreground">
                  <time datetime={isoDate(post.data.pubDate)}>
                    {formatDate(post.data.pubDate, postLocale(post), "short")}
                  </time>
                  <span aria-hidden="true">&middot;</span>
                  <span>{dict.post.readingTime(minutes)}</span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )
}
