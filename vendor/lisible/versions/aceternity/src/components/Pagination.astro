---
import { t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  current: number;
  total: number;
  prevUrl?: string;
  nextUrl?: string;
}

const { locale, current, total, prevUrl, nextUrl } = Astro.props;
const dict = t(locale);

const linkClass =
  "inline-flex min-h-11 items-center gap-1.5 rounded-md border border-border px-4 text-sm font-medium transition-colors hover:border-accent hover:text-accent";
const disabledClass =
  "inline-flex min-h-11 items-center gap-1.5 rounded-md border border-border/50 px-4 text-sm font-medium text-muted-foreground/40";
---

{
  total > 1 && (
    <nav
      class="mt-10 flex items-center justify-between gap-4 border-t border-border pt-6"
      aria-label={dict.pagination.nav}
    >
      {prevUrl ? (
        <a href={prevUrl} rel="prev" class={linkClass}>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6" />
          </svg>
          <span>{dict.pagination.previous}</span>
        </a>
      ) : (
        <span class={disabledClass} aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6" />
          </svg>
          <span>{dict.pagination.previous}</span>
        </span>
      )}

      <span class="text-sm tabular-nums text-muted-foreground">
        {dict.pagination.pageLabel(current, total)}
      </span>

      {nextUrl ? (
        <a href={nextUrl} rel="next" class={linkClass}>
          <span>{dict.pagination.next}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </a>
      ) : (
        <span class={disabledClass} aria-hidden="true">
          <span>{dict.pagination.next}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </span>
      )}
    </nav>
  )
}
