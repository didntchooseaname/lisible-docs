---
import { t, defaultLocale, type Locale } from "@/i18n/ui";

const locale = ((Astro.currentLocale as Locale) ?? defaultLocale) satisfies Locale;
const dict = t(locale);
---

<details class="spoiler not-prose">
  <summary class="spoiler__summary">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path>
      <circle cx="12" cy="12" r="3"></circle>
    </svg>
    <span>{dict.spoiler.show}</span>
  </summary>
  <div class="spoiler__content">
    <slot />
  </div>
</details>
