---
import NewsletterSignup from "@/components/react/NewsletterSignup";
import { GridDotBackground } from "@/components/ui/grid-dot-background";
import { t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---



<section
  aria-labelledby="newsletter-title"
  class="relative overflow-hidden rounded-lg border border-border bg-card p-6 md:p-8"
>
  <GridDotBackground variant="dots" withFade={false} className="opacity-40" />
  <div class="relative">
    <h2 id="newsletter-title" class="text-xl font-bold tracking-tight">
      {dict.newsletter.title}
    </h2>
    <p class="mt-2 max-w-prose text-sm leading-relaxed text-muted-foreground">
      {dict.newsletter.description}
    </p>
    <div class="mt-5">
      <NewsletterSignup
        client:visible
        placeholders={dict.newsletter.placeholders}
        emailLabel={dict.newsletter.emailLabel}
        submitLabel={dict.newsletter.submit}
        buttonLabel={dict.newsletter.button}
      />
    </div>
    <p class="mt-3 text-xs text-muted-foreground">{dict.newsletter.note}</p>
  </div>
</section>
