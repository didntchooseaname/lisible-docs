---
import { t, type Locale } from "@/i18n/ui";

interface Props {
  targetUrl: string;
  locale: Locale;
}

const { targetUrl, locale } = Astro.props;
const dict = t(locale);

interface Jf2Author {
  name?: string;
  photo?: string;
  url?: string;
}
interface Jf2Entry {
  "wm-property"?: string;
  author?: Jf2Author;
  url?: string;
  content?: { text?: string };
}

let likes: Jf2Entry[] = [];
let reposts: Jf2Entry[] = [];
let mentions: Jf2Entry[] = [];

try {
  const endpoint = `https://webmention.io/api/mentions.jf2?target=${encodeURIComponent(targetUrl)}&per-page=100`;
  const response = await fetch(endpoint);
  if (response.ok) {
    const data = (await response.json()) as { children?: Jf2Entry[] };
    for (const entry of data.children ?? []) {
      const kind = entry["wm-property"];
      if (kind === "like-of") likes.push(entry);
      else if (kind === "repost-of") reposts.push(entry);
      else mentions.push(entry);
    }
  }
} catch {
}

const hasAny = likes.length + reposts.length + mentions.length > 0;
---

<section class="mt-14 border-t border-border pt-8" aria-labelledby="webmentions-title">
  <h2 id="webmentions-title" class="text-lg font-bold tracking-tight">
    {dict.webmentions.title}
  </h2>

  {
    !hasAny && (
      <p class="mt-3 text-sm text-muted-foreground">{dict.webmentions.empty}</p>
    )
  }

  {
    likes.length > 0 && (
      <div class="mt-4">
        <p class="text-sm font-medium text-muted-foreground">
          {dict.webmentions.likes} · {likes.length}
        </p>
        <ul class="mt-2 flex flex-wrap gap-2">
          {likes.map((entry) => (
            <li>
              <a href={entry.author?.url ?? entry.url ?? "#"} rel="nofollow noopener" title={entry.author?.name}>
                <img
                  src={entry.author?.photo}
                  alt={entry.author?.name ?? ""}
                  width="36"
                  height="36"
                  loading="lazy"
                  decoding="async"
                  class="h-9 w-9 rounded-full border border-border object-cover"
                />
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  {
    reposts.length > 0 && (
      <div class="mt-4">
        <p class="text-sm font-medium text-muted-foreground">
          {dict.webmentions.reposts} · {reposts.length}
        </p>
        <ul class="mt-2 flex flex-wrap gap-2">
          {reposts.map((entry) => (
            <li>
              <a href={entry.author?.url ?? entry.url ?? "#"} rel="nofollow noopener" title={entry.author?.name}>
                <img
                  src={entry.author?.photo}
                  alt={entry.author?.name ?? ""}
                  width="36"
                  height="36"
                  loading="lazy"
                  decoding="async"
                  class="h-9 w-9 rounded-full border border-border object-cover"
                />
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  {
    mentions.length > 0 && (
      <div class="mt-4">
        <p class="text-sm font-medium text-muted-foreground">
          {dict.webmentions.mentions} · {mentions.length}
        </p>
        <ul class="mt-2 space-y-3">
          {mentions.map((entry) => (
            <li class="flex gap-3 rounded-lg border border-border p-3">
              <img
                src={entry.author?.photo}
                alt={entry.author?.name ?? ""}
                width="32"
                height="32"
                loading="lazy"
                decoding="async"
                class="h-8 w-8 shrink-0 rounded-full border border-border object-cover"
              />
              <div class="min-w-0 text-sm">
                <a href={entry.author?.url ?? entry.url ?? "#"} rel="nofollow noopener" class="font-medium hover:text-accent">
                  {entry.author?.name ?? entry.url}
                </a>
                {entry.content?.text && (
                  <p class="mt-0.5 text-muted-foreground">{entry.content.text}</p>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</section>
