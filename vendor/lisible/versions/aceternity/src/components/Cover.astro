---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  cover: ImageMetadata | string;
  alt: string;
  ratio?: string;
  class?: string;
  loading?: "eager" | "lazy";
  widths?: number[];
  sizes?: string;
}

const {
  cover,
  alt,
  ratio = "16 / 9",
  class: className,
  loading = "lazy",
  widths = [480, 768, 1024, 1280],
  sizes = "(min-width: 1024px) 768px, 100vw",
} = Astro.props;

const isString = typeof cover === "string";
---

<figure class:list={["cover", className]} style={`aspect-ratio:${ratio}`} data-preview-cover>
  {
    isString ? (
      <img
        src={cover as string}
        alt={alt}
        loading={loading}
        decoding="async"
        class="cover__img"
      />
    ) : (
      <Image
        src={cover as ImageMetadata}
        alt={alt}
        widths={widths}
        sizes={sizes}
        loading={loading}
        decoding="async"
        class="cover__img"
      />
    )
  }
</figure>
