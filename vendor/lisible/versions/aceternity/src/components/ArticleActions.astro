---
import { FEATURES } from "@/site.config";
import { t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  title: string;
  pageUrl: string;
  markdownUrl: string;
  markdownAbsoluteUrl: string;
}

const { locale, title, pageUrl, markdownUrl, markdownAbsoluteUrl } =
  Astro.props;
const dict = t(locale);

const showAi = FEATURES.aiButtons;
const showShare = FEATURES.socialShare;

const aiPrompt = `${dict.ai.promptPrefix}${markdownAbsoluteUrl}`;
const claudeUrl = `https://claude.ai/new?q=${encodeURIComponent(aiPrompt)}`;
const chatGptUrl = `https://chatgpt.com/?q=${encodeURIComponent(aiPrompt)}`;

const shareText = `${title}`;
const xUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(pageUrl)}`;
const blueskyUrl = `https://bsky.app/intent/compose?text=${encodeURIComponent(`${shareText} ${pageUrl}`)}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;

const itemClass =
  "inline-flex min-h-9 items-center gap-2 rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground focus-visible:bg-secondary focus-visible:text-foreground";
const iconBtnClass =
  "inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground focus-visible:bg-secondary focus-visible:text-foreground";
---

{
  (showAi || showShare) && (
    <div
      class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-border pt-6"
      data-article-actions
      data-mastodon-prompt={showShare ? dict.share.mastodonPrompt : undefined}
    >
      {showAi && (
        <details class="group relative" data-ai-menu>
          <summary
            class={`${itemClass} cursor-pointer list-none border border-border`}
            aria-label={dict.ai.label}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z" />
            </svg>
            <span>{dict.ai.label}</span>
          </summary>
          <div class="absolute left-0 z-30 mt-2 w-60 rounded-lg border border-border bg-popover p-1 shadow-md">
            <button
              type="button"
              class={`${itemClass} w-full justify-start`}
              data-copy-markdown
              data-md-url={markdownUrl}
              data-label={dict.ai.copyMarkdown}
              data-copied={dict.ai.copied}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
              </svg>
              <span data-copy-label>{dict.ai.copyMarkdown}</span>
            </button>
            <a href={claudeUrl} target="_blank" rel="noopener noreferrer" class={`${itemClass} w-full justify-start`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M4.7 15.3 8.9 4.5h2.2l4.2 10.8h-2.2l-.9-2.5H7.8l-.9 2.5zm3.7-4.2h3.2L10 6.6zM16.8 15.3V4.5h2v10.8z" />
              </svg>
              <span>{dict.ai.openClaude}</span>
            </a>
            <a href={chatGptUrl} target="_blank" rel="noopener noreferrer" class={`${itemClass} w-full justify-start`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 8V4H8" />
                <rect width="16" height="12" x="4" y="8" rx="2" />
                <path d="M2 14h2" /><path d="M20 14h2" /><path d="M15 13v2" /><path d="M9 13v2" />
              </svg>
              <span>{dict.ai.openChatGpt}</span>
            </a>
            <a href={markdownUrl} class={`${itemClass} w-full justify-start`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <path d="M14 2v6h6" /><path d="M10 13h1v4" /><path d="M13 13v4h1" />
              </svg>
              <span>{dict.ai.viewMarkdown}</span>
            </a>
          </div>
        </details>
      )}

      {showShare && (
        <div class="flex flex-wrap items-center gap-1" role="group" aria-label={dict.share.label}>
          <span class="mr-1 text-sm text-muted-foreground">{dict.share.label}</span>
          <a href={xUrl} target="_blank" rel="noopener noreferrer" class={iconBtnClass} aria-label={dict.share.x}>
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <a href={blueskyUrl} target="_blank" rel="noopener noreferrer" class={iconBtnClass} aria-label={dict.share.bluesky}>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.335 5.144c2.248 1.688 4.665 5.11 5.665 6.945.999-1.836 3.417-5.257 5.665-6.945C19.284 3.94 22 3.01 22 6.11c0 .618-.355 5.195-.563 5.938-.727 2.583-3.36 3.244-5.702 2.845 4.093.696 5.135 3.004 2.886 5.312-4.271 4.383-6.14-1.1-6.62-2.506-.088-.257-.129-.377-.13-.275-.001-.102-.042.018-.13.275-.48 1.406-2.349 6.889-6.62 2.506-2.249-2.308-1.207-4.616 2.886-5.312-2.343.399-4.975-.262-5.702-2.845C1.855 11.305 1.5 6.728 1.5 6.11c0-3.1 2.716-2.17 3.635-.966z" />
            </svg>
          </a>
          <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class={iconBtnClass} aria-label={dict.share.linkedin}>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z" />
            </svg>
          </a>
          <button type="button" class={iconBtnClass} aria-label={dict.share.mastodon} data-share-mastodon data-title={title} data-url={pageUrl}>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z" />
            </svg>
          </button>
          <button
            type="button"
            class={iconBtnClass}
            aria-label={dict.share.copyLink}
            data-copy-link
            data-url={pageUrl}
            data-label={dict.share.copyLink}
            data-copied={dict.share.copied}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
            </svg>
          </button>
        </div>
      )}
    </div>
  )
}

{
  (showAi || showShare) && (
    <script>
      import "@/scripts/article-actions";
    </script>
  )
}
