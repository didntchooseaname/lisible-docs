---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { getPublishedPosts, groupByYear, postUrl } from "@/lib/posts";
import { isoDate } from "@/lib/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const intlLocale = locale === "fr" ? "fr-FR" : "en-US";
const monthFmt = new Intl.DateTimeFormat(intlLocale, { month: "long" });
const dayFmt = new Intl.DateTimeFormat(intlLocale, { day: "2-digit" });

const posts = await getPublishedPosts(locale);

const years = groupByYear(posts).map(([year, yearPosts]) => {
  const months = new Map<number, typeof yearPosts>();
  for (const post of yearPosts) {
    const month = post.data.pubDate.getMonth();
    const list = months.get(month) ?? [];
    list.push(post);
    months.set(month, list);
  }
  return {
    year,
    months: [...months.entries()]
      .sort((a, b) => b[0] - a[0])
      .map(([month, monthPosts]) => ({
        label: monthFmt.format(new Date(year, month, 1)),
        posts: monthPosts,
      })),
  };
});

const alternates = {
  fr: localeUrl("fr", "archives"),
  en: localeUrl("en", "archives"),
};
---

<BaseLayout
  locale={locale}
  title={dict.archives.title}
  description={dict.archives.description}
  alternates={alternates}
>
  <div class="py-10 md:py-14">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{dict.archives.title}</h1>
    <p class="mt-3 max-w-2xl text-muted-foreground">{dict.archives.description}</p>

    {
      posts.length === 0 && (
        <p class="mt-8 text-muted-foreground">{dict.archives.empty}</p>
      )
    }

    <div class="mt-10 space-y-12">
      {
        years.map((group) => (
          <section aria-labelledby={`year-${group.year}`}>
            <h2
              id={`year-${group.year}`}
              class="text-2xl font-bold tracking-tight text-muted-foreground"
            >
              {group.year}
            </h2>
            <div class="mt-4 space-y-6 border-l border-border pl-5">
              {group.months.map((month) => (
                <div>
                  <h3 class="text-xs font-semibold uppercase tracking-wide text-accent">
                    {month.label}
                  </h3>
                  <ul class="mt-2 space-y-1.5">
                    {month.posts.map((post) => (
                      <li class="flex items-baseline gap-3">
                        <time
                          datetime={isoDate(post.data.pubDate)}
                          class="w-7 shrink-0 tabular-nums text-sm text-muted-foreground"
                        >
                          {dayFmt.format(post.data.pubDate)}
                        </time>
                        <a
                          href={postUrl(post)}
                          class="text-pretty transition-colors hover:text-accent"
                        >
                          {post.data.title}
                          {post.data.draft && (
                            <span class="ml-1.5 text-xs text-muted-foreground">
                              ({dict.post.draft})
                            </span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
