---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { localeUrl, otherLocale, t, type Locale } from "@/i18n/ui";
import { postUrl } from "@/lib/posts";
import {
  cumulativeReadingTime,
  getAllSeries,
  getSeriesPosts,
  seriesDescription,
  seriesTitle,
  seriesUrl,
} from "@/lib/series";
import { formatDate, isoDate, readingTime } from "@/lib/utils";

interface Props {
  locale: Locale;
  slug: string;
}

const { locale, slug } = Astro.props;
const dict = t(locale);
const title = seriesTitle(slug, locale);
const description =
  seriesDescription(slug, locale) || dict.series.indexDescription(title);

const posts = await getSeriesPosts(locale, slug);
const totalMinutes = cumulativeReadingTime(posts);

const other = otherLocale(locale);
const otherSeries = await getAllSeries(other);
const alternates: Partial<Record<Locale, string>> = {
  [locale]: seriesUrl(locale, slug),
};
if (otherSeries.includes(slug)) alternates[other] = seriesUrl(other, slug);
---

<BaseLayout
  locale={locale}
  title={title}
  description={description}
  alternates={alternates}
>
  <div class="py-10 md:py-14">
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">
      {dict.series.label}
    </p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">{title}</h1>
    <p class="mt-3 max-w-2xl text-muted-foreground">{description}</p>
    <p class="mt-2 text-sm text-muted-foreground">
      {dict.tags.postsCount(posts.length)} · {dict.series.cumulativeTime(totalMinutes)}
    </p>

    <ol class="mt-8 space-y-3">
      {
        posts.map((post, index) => (
          <li>
            <a
              href={postUrl(post)}
              class="group flex gap-4 rounded-lg border border-border p-4 transition-colors hover:border-accent"
            >
              <span
                class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-border text-sm font-semibold tabular-nums text-muted-foreground transition-colors group-hover:border-accent group-hover:text-accent"
                aria-hidden="true"
              >
                {index + 1}
              </span>
              <span class="min-w-0">
                <span class="block font-semibold tracking-tight transition-colors group-hover:text-accent">
                  {post.data.title}
                </span>
                <span class="mt-1 block text-sm text-muted-foreground">
                  {post.data.description}
                </span>
                <span class="mt-1.5 block text-xs text-muted-foreground">
                  <time datetime={isoDate(post.data.pubDate)}>
                    {formatDate(post.data.pubDate, locale, "short")}
                  </time>
                  {" · "}
                  {dict.post.readingTime(readingTime(post.body ?? ""))}
                </span>
              </span>
            </a>
          </li>
        ))
      }
    </ol>

    <p class="mt-8">
      <a
        href={localeUrl(locale, "blog")}
        class="text-sm font-medium text-accent underline-offset-4 hover:underline"
      >
        {dict.home.allPosts}
      </a>
    </p>
  </div>
</BaseLayout>
