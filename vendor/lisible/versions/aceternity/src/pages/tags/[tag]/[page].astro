---
import TagPage from "@/components/pages/TagPage.astro";
import { FEATURES } from "@/site.config";
import { getAllTags, getPostsByTag, paginate } from "@/lib/posts";

export async function getStaticPaths() {
  if (!FEATURES.pagination.enabled) return [];
  const tags = await getAllTags("fr");
  const paths = [];
  for (const tag of tags) {
    const posts = await getPostsByTag("fr", tag.slug);
    const pages = paginate(posts, FEATURES.pagination.pageSize);
    for (const p of pages) {
      if (p.current > 1) {
        paths.push({
          params: { tag: tag.slug, page: String(p.current) },
          props: { tagName: tag.name, page: p.current },
        });
      }
    }
  }
  return paths;
}

const { tag } = Astro.params;
const { tagName, page } = Astro.props;
---

<TagPage locale="fr" tagSlug={tag} tagName={tagName} page={page} />
