---
import appCssUrl from "@/styles/app.css?url";
import { ClientRouter } from "astro:transitions";
import LandingLocaleBootstrap from "@shared/components/LandingLocaleBootstrap.astro";
import ExpressiveCodeLabelSpacing from "@shared/components/ExpressiveCodeLabelSpacing.astro";
import PreviewBridge from "@shared/components/PreviewBridge.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SearchModal from "@/components/SearchModal.astro";
import { SITE } from "@/site.config";
import { ensureTrailingSlash, localeUrl, ogLocales, otherLocale, t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  ogType?: "website" | "article";
  alternates?: Partial<Record<Locale, string>>;
  isHome?: boolean;
  ogImage?: string;
  prevUrl?: string;
  nextUrl?: string;
}

const {
  locale,
  title,
  description,
  ogType = "website",
  alternates,
  isHome = false,
  ogImage: ogImageProp,
  prevUrl,
  nextUrl,
} = Astro.props;

const dict = t(locale);
const pageTitle = isHome ? title : `${title} | ${SITE.title}`;
const canonicalPath = ensureTrailingSlash(Astro.url.pathname);
const canonicalUrl = new URL(canonicalPath, SITE.url);
const ogImage = ogImageProp
  ? new URL(ogImageProp, SITE.url)
  : new URL("/og-default.png", SITE.url);
const rssPath = localeUrl(locale, "rss.xml");
const hasBothAlternates = Boolean(alternates?.fr && alternates?.en);
const other = otherLocale(locale);
---

<html lang={locale}>
  <head>
    <LandingLocaleBootstrap />
    <ExpressiveCodeLabelSpacing />
    <meta charset="utf-8" />
    <link rel="stylesheet" href={appCssUrl} />
    <script is:inline define:vars={{ defaultAccent: SITE.accent }}>
      (function () {
        function applyTheme() {
          const stored = localStorage.getItem("theme");
          const theme = stored === "light" || stored === "dark"
            ? stored
            : (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
          document.documentElement.classList.toggle("dark", theme === "dark");
        }
        function applyAccent() {
          var hex = "";
          try { hex = localStorage.getItem("accent") || ""; } catch (e) {}
          if (!/^#[0-9a-fA-F]{6}$/.test(hex)) hex = defaultAccent;
          var c = [1, 3, 5].map(function (i) { return parseInt(hex.slice(i, i + 2), 16); });
          function lum(rgb) {
            var a = rgb.map(function (v) {
              v /= 255;
              return v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
            });
            return 0.2126 * a[0] + 0.7152 * a[1] + 0.0722 * a[2];
          }
          var dark = document.documentElement.classList.contains("dark");
          for (var i = 0; i < 32; i++) {
            var L = lum(c);
            if (dark ? (L + 0.05) / 0.05 >= 3 : 1.05 / (L + 0.05) >= 4.5) break;
            c = c.map(function (v) {
              return dark
                ? Math.min(255, Math.round(v + (255 - v) * 0.1) + 1)
                : Math.max(0, Math.round(v * 0.9) - 1);
            });
          }
          var fg = (lum(c) + 0.05) / 0.05 >= 4.5 ? "#000000" : "#ffffff";
          var s = document.documentElement.style;
          s.setProperty("--accent", "rgb(" + c.join(" ") + ")");
          s.setProperty("--accent-foreground", fg);
          s.setProperty("--ring", "rgb(" + c.join(" ") + ")");
        }
        applyTheme();
        applyAccent();
        window.applyAccent = applyAccent;
        document.addEventListener("astro:after-swap", function () {
          applyTheme();
          applyAccent();
        });
        document.addEventListener("astro:page-load", applyAccent);
        new MutationObserver(applyAccent).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <PreviewBridge />
    <link rel="canonical" href={canonicalUrl} />
    {prevUrl && <link rel="prev" href={new URL(prevUrl, SITE.url)} />}
    {nextUrl && <link rel="next" href={new URL(nextUrl, SITE.url)} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL(rssPath, SITE.url)}
    />


    {
      hasBothAlternates && (
        <>
          <link rel="alternate" hreflang="fr" href={new URL(ensureTrailingSlash(alternates!.fr!), SITE.url)} />
          <link rel="alternate" hreflang="en" href={new URL(ensureTrailingSlash(alternates!.en!), SITE.url)} />
          <link rel="alternate" hreflang="x-default" href={new URL(ensureTrailingSlash(alternates!.fr!), SITE.url)} />
        </>
      )
    }

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocales[locale]} />
    {hasBothAlternates && <meta property="og:locale:alternate" content={ogLocales[other]} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body
    class="flex min-h-dvh flex-col"
    data-gh-stars-label={dict.githubCard.stars}
    data-gh-forks-label={dict.githubCard.forks}
    data-gh-language-label={dict.githubCard.language}
  >
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:border focus:border-border focus:bg-background focus:px-4 focus:py-3 focus:font-medium"
    >
      {dict.a11y.skipToContent}
    </a>
    <Header locale={locale} alternates={alternates} />
    <main id="main" class="mx-auto w-full max-w-6xl flex-1 px-4 md:px-6">
      <slot />
    </main>
    <Footer locale={locale} />
    <SearchModal locale={locale} alternates={alternates} />
    <script>import "@shared/scripts/locale-preference";</script>
  </body>
</html>
