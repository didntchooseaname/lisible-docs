---
import { FEATURES } from "@/site.config";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { getPublishedPosts } from "@/lib/posts";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const palette = FEATURES.commandPalette;
const hasSeries = FEATURES.series && (await getPublishedPosts(locale)).some(
  (post) => Boolean(post.data.series),
);

const actions = [
  { cmd: "theme", label: dict.palette.toggleTheme, keywords: "theme dark light sombre clair mode" },
  { cmd: "language", label: dict.palette.switchLanguage, keywords: "language langue fr en locale" },
  { cmd: "accent", label: dict.palette.resetAccent, keywords: "accent couleur color reset reinitialiser" },
  { cmd: "copy-url", label: dict.palette.copyUrl, keywords: "url lien copier copy partage" },
] as const;

const navLinks = [
  { href: localeUrl(locale, "blog"), label: dict.palette.goBlog, keywords: "blog articles posts" },
  { href: localeUrl(locale, "tags"), label: dict.palette.goTags, keywords: "tags mots-cles" },
  FEATURES.archives && {
    href: localeUrl(locale, "archives"),
    label: dict.palette.goArchives,
    keywords: "archives timeline historique",
  },
  hasSeries && {
    href: localeUrl(locale, "series"),
    label: dict.series.listTitle,
    keywords: "series serie dossiers",
  },
  { href: localeUrl(locale, "about"), label: dict.palette.goAbout, keywords: "about a propos" },
  { href: localeUrl(locale, "rss.xml"), label: dict.palette.openRss, keywords: "rss feed flux abonnement" },
].filter(Boolean) as { href: string; label: string; keywords: string }[];

function svg(inner: string): string {
  return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">${inner}</svg>`;
}

function paletteIcon(cmd: string): string {
  switch (cmd) {
    case "theme":
      return svg('<circle cx="12" cy="12" r="9"/><path d="M12 3a9 9 0 0 0 0 18Z" fill="currentColor" stroke="none"/>');
    case "language":
      return svg('<circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a15 15 0 0 1 0 18 15 15 0 0 1 0-18"/>');
    case "accent":
      return svg('<path d="M12 3s6 5.5 6 10a6 6 0 0 1-12 0c0-4.5 6-10 6-10Z"/>');
    case "copy-url":
      return svg('<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>');
    default:
      return svg('<circle cx="12" cy="12" r="9"/>');
  }
}

function navArrowIcon(): string {
  return svg('<path d="M7 7h10v10"/><path d="M7 17 17 7"/>');
}
---

<dialog
  data-search-modal
  data-palette={palette ? "1" : undefined}
  aria-label={dict.search.title}
  data-hint={palette ? dict.palette.hint : dict.search.hint}
  data-no-results={palette ? dict.palette.empty : dict.search.noResults}
  data-dev-notice={dict.search.devNotice}
  data-url-copied={dict.palette.urlCopied}
  data-search-label={dict.palette.searchGroup}
>
  <div class="flex items-center gap-2 border-b border-border px-4">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="shrink-0 text-muted-foreground"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <input
      type="search"
      id="search-input"
      name="search"
      data-search-input
      placeholder={palette ? dict.palette.placeholder : dict.search.placeholder}
      aria-label={dict.search.title}
      role="combobox"
      aria-expanded="true"
      aria-controls="palette-listbox"
      aria-autocomplete="list"
      autocomplete="off"
      class="h-12 w-full bg-transparent text-base outline-none placeholder:text-muted-foreground"
    />
    <button
      type="button"
      data-search-close
      aria-label={dict.a11y.closeSearch}
      class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>

  <div id="palette-listbox" role="listbox" aria-label={dict.search.title} class="palette-scroll">
    {
      palette && (
        <div data-palette-static>
          <div class="palette-group" data-group>
            <p class="palette-group-label">{dict.palette.actionsGroup}</p>
            <ul>
              {actions.map((action) => (
                <li>
                  <button
                    type="button"
                    class="cmd-item"
                    role="option"
                    aria-selected="false"
                    data-cmd={action.cmd}
                    data-keywords={action.keywords}
                  >
                    <span class="cmd-icon" aria-hidden="true" set:html={paletteIcon(action.cmd)} />
                    <span class="cmd-label">{action.label}</span>
                  </button>
                </li>
              ))}
            </ul>
          </div>
          <div class="palette-group" data-group>
            <p class="palette-group-label">{dict.palette.navGroup}</p>
            <ul>
              {navLinks.map((link) => (
                <li>
                  <a
                    class="cmd-item"
                    role="option"
                    aria-selected="false"
                    href={link.href}
                    data-keywords={link.keywords}
                  >
                    <span class="cmd-icon" aria-hidden="true" set:html={navArrowIcon()} />
                    <span class="cmd-label">{link.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )
    }
    <div data-search-results>
      {
        !palette && (
          <p class="px-3 py-6 text-center text-sm text-muted-foreground">{dict.search.hint}</p>
        )
      }
    </div>
  </div>
</dialog>

<script>
  type PagefindResult = {
    data: () => Promise<{
      url: string;
      excerpt: string;
      meta: { title?: string };
    }>;
  };

  type PagefindModule = {
    options: (options: Record<string, unknown>) => Promise<void>;
    init: () => void;
    debouncedSearch: (
      query: string,
    ) => Promise<{ results: PagefindResult[] } | null>;
  };

  let pagefind: PagefindModule | null = null;
  let loadFailed = false;
  let activeIndex = -1;

  function getModal(): HTMLDialogElement | null {
    return document.querySelector<HTMLDialogElement>("[data-search-modal]");
  }

  function isPalette(modal: HTMLDialogElement): boolean {
    return modal.dataset.palette === "1";
  }

  function getInput(): HTMLInputElement | null {
    return document.querySelector<HTMLInputElement>("[data-search-input]");
  }

  function visibleItems(modal: HTMLDialogElement): HTMLElement[] {
    return Array.from(
      modal.querySelectorAll<HTMLElement>(".cmd-item"),
    ).filter((el) => el.offsetParent !== null && !el.hasAttribute("hidden"));
  }

  function setActive(modal: HTMLDialogElement, index: number): void {
    const items = visibleItems(modal);
    const input = getInput();
    items.forEach((el) => {
      el.classList.remove("is-active");
      el.setAttribute("aria-selected", "false");
    });
    if (items.length === 0) {
      activeIndex = -1;
      input?.removeAttribute("aria-activedescendant");
      return;
    }
    activeIndex = ((index % items.length) + items.length) % items.length;
    const el = items[activeIndex];
    el.classList.add("is-active");
    el.setAttribute("aria-selected", "true");
    if (!el.id) el.id = `cmd-item-${activeIndex}`;
    input?.setAttribute("aria-activedescendant", el.id);
    el.scrollIntoView({ block: "nearest" });
  }

  function renderMessage(modal: HTMLDialogElement, message: string): void {
    const container = modal.querySelector("[data-search-results]");
    if (!container) return;
    container.innerHTML = "";
    if (!message) return;
    const p = document.createElement("p");
    p.className = "px-3 py-6 text-center text-sm text-muted-foreground";
    p.textContent = message;
    container.appendChild(p);
  }

  function filterStatic(modal: HTMLDialogElement, query: string): void {
    const staticWrap = modal.querySelector<HTMLElement>("[data-palette-static]");
    if (!staticWrap) return;
    const q = query.toLowerCase();
    staticWrap.querySelectorAll<HTMLElement>(".cmd-item").forEach((el) => {
      const label = (el.querySelector(".cmd-label")?.textContent ?? "").toLowerCase();
      const keywords = (el.dataset.keywords ?? "").toLowerCase();
      const match = q === "" || label.includes(q) || keywords.includes(q);
      el.closest("li")?.toggleAttribute("hidden", !match);
    });
    staticWrap.querySelectorAll<HTMLElement>("[data-group]").forEach((group) => {
      const anyVisible = group.querySelector("li:not([hidden])");
      group.toggleAttribute("hidden", !anyVisible);
    });
  }

  async function ensurePagefind(): Promise<void> {
    if (pagefind || loadFailed) return;
    try {
      const module = (await import(
        /* @vite-ignore */ "/pagefind/pagefind.js"
      )) as PagefindModule;
      await module.options({ excerptLength: 25 });
      module.init();
      pagefind = module;
    } catch {
      loadFailed = true;
    }
  }

  async function openSearch(): Promise<void> {
    const modal = getModal();
    if (!modal || modal.open) return;
    modal.showModal();
    const input = getInput();
    if (input) input.value = "";
    filterStatic(modal, "");
    if (isPalette(modal)) {
      renderMessage(modal, "");
    } else {
      renderMessage(modal, modal.dataset.hint ?? "");
    }
    input?.focus();
    setActive(modal, 0);
    await ensurePagefind();
    if (loadFailed && !isPalette(modal)) {
      renderMessage(modal, modal.dataset.devNotice ?? "");
    }
  }

  function makeResultItem(url: string, title: string, excerpt: string): HTMLLIElement {
    const item = document.createElement("li");
    const link = document.createElement("a");
    link.href = url;
    link.className = "cmd-item cmd-result";
    link.setAttribute("role", "option");
    link.setAttribute("aria-selected", "false");
    const wrap = document.createElement("span");
    wrap.className = "cmd-result-text";
    const heading = document.createElement("span");
    heading.className = "cmd-label";
    heading.textContent = title;
    const sub = document.createElement("span");
    sub.className = "cmd-result-excerpt";
    sub.innerHTML = excerpt;
    wrap.append(heading, sub);
    link.appendChild(wrap);
    item.appendChild(link);
    return item;
  }

  async function runSearch(input: HTMLInputElement): Promise<void> {
    const modal = getModal();
    if (!modal) return;
    const query = input.value.trim();
    const paletteMode = isPalette(modal);

    filterStatic(modal, query);

    const container = modal.querySelector("[data-search-results]");
    if (!container) return;

    if (!query) {
      renderMessage(modal, paletteMode ? "" : modal.dataset.hint ?? "");
      setActive(modal, 0);
      return;
    }

    if (loadFailed) {
      const anyStatic = paletteMode && visibleItems(modal).length > 0;
      renderMessage(modal, anyStatic ? "" : modal.dataset.devNotice ?? "");
      setActive(modal, 0);
      return;
    }
    if (!pagefind) return;

    const search = await pagefind.debouncedSearch(query);
    if (!search) return;

    const results = await Promise.all(
      search.results.slice(0, 8).map((result) => result.data()),
    );

    container.innerHTML = "";
    if (results.length === 0) {
      if (!paletteMode || visibleItems(modal).length === 0) {
        renderMessage(modal, modal.dataset.noResults ?? "");
      }
      setActive(modal, 0);
      return;
    }

    const group = document.createElement("div");
    group.className = "palette-group";
    if (paletteMode) {
      const label = document.createElement("p");
      label.className = "palette-group-label";
      label.textContent = modal.dataset.searchLabel ?? "";
      group.appendChild(label);
    }
    const list = document.createElement("ul");
    for (const result of results) {
      list.appendChild(makeResultItem(result.url, result.meta.title ?? result.url, result.excerpt));
    }
    group.appendChild(list);
    container.appendChild(group);
    setActive(modal, 0);
  }

  function flashCopied(el: HTMLElement, modal: HTMLDialogElement): void {
    const label = el.querySelector<HTMLElement>(".cmd-label");
    if (!label) return;
    const original = label.textContent ?? "";
    label.textContent = modal.dataset.urlCopied ?? original;
    el.classList.add("is-copied");
    window.setTimeout(() => {
      label.textContent = original;
      el.classList.remove("is-copied");
    }, 1400);
  }

  function runCommand(cmd: string, el: HTMLElement, modal: HTMLDialogElement): void {
    switch (cmd) {
      case "theme":
        modal.close();
        document.querySelector<HTMLElement>("[data-theme-toggle]")?.click();
        break;
      case "language": {
        const link = document.querySelector<HTMLAnchorElement>(
          'a[hreflang][aria-current="true"]',
        );
        const other = Array.from(
          document.querySelectorAll<HTMLAnchorElement>("a[hreflang]"),
        ).find((a) => a !== link && a.getAttribute("aria-current") !== "true");
        modal.close();
        if (other) other.click();
        break;
      }
      case "accent":
        localStorage.removeItem("accent");
        (window as { __applyAccent?: () => void }).__applyAccent?.();
        modal.close();
        break;
      case "copy-url":
        void navigator.clipboard?.writeText(location.href).then(() => flashCopied(el, modal));
        break;
      default:
        break;
    }
  }

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;
    if (target?.closest("[data-search-open]")) {
      void openSearch();
      return;
    }
    if (target?.closest("[data-search-close]")) {
      getModal()?.close();
      return;
    }
    const modal = getModal();
    if (!modal) return;

    const cmdEl = target?.closest<HTMLElement>(".cmd-item[data-cmd]");
    if (cmdEl && modal.open) {
      event.preventDefault();
      runCommand(cmdEl.dataset.cmd ?? "", cmdEl, modal);
      return;
    }

    if (modal.open && event.target === modal) {
      modal.close();
    }
  });

  document.addEventListener("keydown", (event) => {
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      const modal = getModal();
      if (modal?.open) modal.close();
      else void openSearch();
      return;
    }

    const modal = getModal();
    if (!modal?.open) return;

    if (event.key === "ArrowDown") {
      event.preventDefault();
      setActive(modal, activeIndex + 1);
    } else if (event.key === "ArrowUp") {
      event.preventDefault();
      setActive(modal, activeIndex - 1);
    } else if (event.key === "Enter") {
      const items = visibleItems(modal);
      const el = items[activeIndex];
      if (el) {
        event.preventDefault();
        el.click();
      }
    }
  });

  document.addEventListener("input", (event) => {
    const input = event.target as HTMLInputElement | null;
    if (!input?.matches("[data-search-input]")) return;
    void runSearch(input);
  });

  document.addEventListener("astro:before-swap", () => {
    getModal()?.close();
  });
</script>
