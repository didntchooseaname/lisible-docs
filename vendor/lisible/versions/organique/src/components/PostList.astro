---
import { postLocale, postUrl, type Post } from "@/lib/posts";
import { formatDate, isoDate } from "@/lib/utils";
import { t } from "@/i18n/ui";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<ul class="organic-rows">
  {
    posts.map((post) => {
      const locale = postLocale(post);
      const dict = t(locale);
      return (
        <li>
          <a href={postUrl(post)} class="row-link">
            <span class="row-title">
              {post.data.title}
              {post.data.draft && (
                <span class="ml-2 inline-flex items-center rounded-full border border-border px-2 py-0.5 align-middle text-xs font-medium text-muted-foreground">
                  {dict.post.draft}
                </span>
              )}
            </span>
            <time datetime={isoDate(post.data.pubDate)} class="row-date">
              {formatDate(post.data.pubDate, locale, "short")}
            </time>
          </a>
        </li>
      );
    })
  }
</ul>
