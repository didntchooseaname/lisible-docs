---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  cover: ImageMetadata | string;
  alt: string;
  variant?: "head" | "card";
  class?: string;
}

const { cover, alt, variant = "head", class: className } = Astro.props;
const isString = typeof cover === "string";
const sizes = variant === "head" ? "(min-width: 768px) 72ch, 100vw" : "12rem";

---

<figure class:list={["post-cover", `post-cover-${variant}`, isString && "post-cover-raw", className]} data-preview-cover>
  {
    isString ? (
      <img src={cover} alt={alt} loading={variant === "head" ? "eager" : "lazy"} decoding="async" />
    ) : (
      <Image
        src={cover as ImageMetadata}
        alt={alt}
        widths={variant === "head" ? [480, 768, 1024] : [240, 480]}
        sizes={sizes}
        loading={variant === "head" ? "eager" : "lazy"}
        decoding="async"
      />
    )
  }
</figure>
