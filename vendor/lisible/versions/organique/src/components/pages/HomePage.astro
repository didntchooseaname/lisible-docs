---
import BaseLayout from "@/layouts/BaseLayout.astro";
import KnowledgeGraph from "@/components/KnowledgeGraph.astro";
import JsonLd from "@/components/JsonLd.astro";
import PostCard from "@/components/PostCard.astro";
import DemoProfileHero from "@shared/components/DemoProfileHero.astro";
import { SITE, FEATURES } from "@/site.config";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { getPublishedPosts } from "@/lib/posts";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

const posts = await getPublishedPosts(locale);

const featured = (
  FEATURES.pinned
    ? [...posts.filter((p) => p.data.featured), ...posts.filter((p) => !p.data.featured)]
    : posts
).slice(0, SITE.featuredCount);

const featuredIds = new Set(featured.map((p) => p.id));
const latest = posts.filter((p) => !featuredIds.has(p.id)).slice(0, SITE.postsPerPage);
const recent = posts.slice(0, 4);

const alternates = { fr: localeUrl("fr"), en: localeUrl("en") };

const jsonLd = {
  "@type": "WebSite",
  name: SITE.title,
  description: dict.site.description,
  url: new URL(localeUrl(locale), SITE.url).toString(),
  inLanguage: locale,
  author: { "@type": "Person", name: SITE.author },
};
---

<BaseLayout
  locale={locale}
  title={dict.home.metaTitle}
  description={dict.site.description}
  alternates={alternates}
  isHome
>
  <JsonLd slot="head" data={jsonLd} />

  <section class="home-hero py-10 md:py-16">
    <div class="hero-blob" aria-hidden="true"></div>
    <DemoProfileHero
      locale={locale}
      variant="organique"
      title={SITE.title}
      actions={[
        { href: localeUrl(locale, "blog"), label: dict.nav.blog },
        { href: localeUrl(locale, "certifications"), label: dict.nav.certifications },
        { href: localeUrl(locale, "friends"), label: dict.nav.friends },
        { href: localeUrl(locale, "about"), label: dict.nav.about },
      ]}
    />
  </section>

  <hr class="wave-line" aria-hidden="true" />

  <section id="recent" class="recent-section py-12 md:py-16" aria-labelledby="recent-heading">
    <div class="section-heading">
      <div>
        <p>{dict.home.latest}</p>
        <h2 id="recent-heading" class="type-title">{dict.home.recentCards}</h2>
      </div>
      <a href={localeUrl(locale, "blog")}>{dict.home.allPosts}</a>
    </div>
    <div class="recent-grid">
      {recent.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <hr class="wave-line" aria-hidden="true" />
  <KnowledgeGraph locale={locale} posts={posts} featured={featured} />
  <hr class="wave-line" aria-hidden="true" />
</BaseLayout>

<style is:inline>
  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .section-heading p {
    margin-bottom: 0.35rem;
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 750;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .section-heading > a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    padding: 0.6rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-background);
    font-size: 0.875rem;
    font-weight: 650;
  }

  .recent-grid {
    display: grid;
    column-gap: clamp(1.5rem, 3vw, 2.5rem);
    row-gap: clamp(1.75rem, 3.5vw, 2.75rem);
  }

  @media (min-width: 680px) {
    .recent-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 460px) {
    .section-heading { align-items: start; flex-direction: column; }
  }
</style>
