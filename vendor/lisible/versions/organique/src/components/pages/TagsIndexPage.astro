---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { getAllTags, slugifyTag } from "@/lib/posts";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const tags = await getAllTags(locale);

const maxCount = Math.max(1, ...tags.map((tag) => tag.count));

function hash(text: string): number {
  let h = 0;
  for (let i = 0; i < text.length; i++) h = (h * 31 + text.charCodeAt(i)) | 0;
  return Math.abs(h);
}

const blobShapes = ["blob-r-a", "blob-r-b", "blob-r-c"];

const cloud = tags.map((tag) => {
  const ratio = tag.count / maxCount;
  const size = (1 + ratio * 1.5).toFixed(2);
  const h = hash(tag.slug || slugifyTag(tag.name));
  const rot = ((h % 9) - 4) * 0.7;
  return {
    ...tag,
    size,
    rot: rot.toFixed(1),
    shape: blobShapes[h % blobShapes.length],
  };
});

const alternates = { fr: localeUrl("fr", "tags"), en: localeUrl("en", "tags") };
---

<BaseLayout
  locale={locale}
  title={dict.tags.title}
  description={dict.tags.description}
  alternates={alternates}
>
  <div class="py-12 md:py-16">
    <h1 class="type-mega rise">{dict.tags.title}</h1>
    <p class="rise rise-2 mt-5 max-w-2xl text-muted-foreground md:ml-[8%]">
      {dict.tags.description}
    </p>

    
    <ul class="tag-cloud rise rise-3 mt-16" aria-label={dict.tags.all}>
      {
        cloud.map((tag) => (
          <li>
            <a
              href={localeUrl(locale, `tags/${tag.slug}`)}
              class:list={["tag-cloud-link", tag.shape]}
              style={`--ts: ${tag.size}rem; --rot: ${tag.rot}deg`}
              aria-label={`${tag.name}, ${dict.tags.postsCount(tag.count)}`}
            >
              <span class="tag-hash" aria-hidden="true">#</span>
              {tag.name}
              <span class="tag-count" aria-hidden="true">{tag.count}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
