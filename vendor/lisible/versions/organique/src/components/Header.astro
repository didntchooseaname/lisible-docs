---
import ThemeToggle from "@/components/ThemeToggle.astro";
import AccentPicker from "@/components/AccentPicker.astro";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import { FEATURES, SITE } from "@/site.config";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { cn } from "@/lib/utils";
import { getPublishedPosts } from "@/lib/posts";

interface Props {
  locale: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const { locale, alternates } = Astro.props;
const dict = t(locale);
const hasSeries = FEATURES.series && (await getPublishedPosts(locale)).some((post) => Boolean(post.data.series));

const navItems = [
  { href: localeUrl(locale, "tags"), label: dict.nav.tags },
  ...(FEATURES.archives
    ? [{ href: localeUrl(locale, "archives"), label: dict.nav.archives }]
    : []),
  ...(hasSeries
    ? [{ href: localeUrl(locale, "series"), label: dict.nav.series }]
    : []),
  { href: localeUrl(locale, "certifications"), label: dict.nav.certifications },
  { href: localeUrl(locale, "friends"), label: dict.nav.friends },
  { href: localeUrl(locale, "about"), label: dict.nav.about },
];

const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href);
}
---


<header class="site-dock-wrap sticky top-0 z-40">
  <div
    class="site-dock mx-auto flex min-h-16 w-full max-w-6xl flex-wrap items-center justify-between gap-x-4 gap-y-0 px-4 py-2 md:px-6"
  >
    <a
      href={localeUrl(locale)}
      class="inline-flex min-h-11 items-center gap-2.5 text-lg font-bold tracking-tight transition-colors hover:text-accent"
    >
      <span class="brand-blob" aria-hidden="true"></span>
      <span data-preview-site-title>{SITE.title}</span>
    </a>

    <nav aria-label={dict.nav.main} class="order-last w-full sm:order-none sm:w-auto">
      <ul class="flex items-center justify-start gap-1 overflow-x-auto sm:justify-center">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class={cn(
                  "dock-link inline-flex min-h-11 items-center rounded-full px-3.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground",
                  isActive(item.href) && "text-foreground",
                )}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-1.5">
      <button
        type="button"
        data-search-open
        aria-label={dict.a11y.openSearch}
        class="inline-flex h-11 w-11 items-center justify-center rounded-full text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>
      <LanguageSwitcher locale={locale} alternates={alternates} />
      <AccentPicker locale={locale} />
      <ThemeToggle locale={locale} />
    </div>
  </div>
</header>
