---
import { postLocale, postUrl, type Post } from "@/lib/posts";
import { formatDate, isoDate, readingTime } from "@/lib/utils";
import { t } from "@/i18n/ui";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<ul class="mt-4 divide-y divide-border/70 border-y border-border/70">
  {
    posts.map((post, index) => {
      const locale = postLocale(post);
      const dict = t(locale);
      const minutes = readingTime(post.body ?? "");
      const hexIndex = `0x${index.toString(16).padStart(2, "0").toUpperCase()}`;
      return (
        <li>
          <a
            href={postUrl(post)}
            class="group flex min-h-11 flex-col gap-1 px-2 py-4 transition-colors hover:bg-secondary/40 sm:flex-row sm:items-baseline sm:gap-6"
          >
            <span
              aria-hidden="true"
              class="shrink-0 font-mono text-xs text-accent/80 transition-all group-hover:text-accent group-hover:[text-shadow:var(--glow-sm)]"
            >
              {hexIndex}
            </span>
            <span class="min-w-0 flex-1 font-medium transition-colors group-hover:text-accent">
              {post.data.title}
              {post.data.draft && (
                <span class="ml-2 inline-flex items-center border border-border px-1.5 py-0.5 align-middle font-mono text-xs font-medium uppercase text-muted-foreground">
                  {dict.post.draft}
                </span>
              )}
            </span>
            <span class="flex shrink-0 items-center gap-3 font-mono text-xs uppercase tracking-wider text-muted-foreground">
              <span class="hidden sm:inline">{dict.post.readingTime(minutes)}</span>
              <time datetime={isoDate(post.data.pubDate)}>
                {formatDate(post.data.pubDate, locale, "short")}
              </time>
            </span>
          </a>
        </li>
      );
    })
  }
</ul>
