---
import ThemeToggle from "@/components/ThemeToggle.astro";
import AccentPicker from "@/components/AccentPicker.astro";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import { ScrollProgress } from "@/components/ui/scroll-progress";
import { FEATURES, SITE } from "@/site.config";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { cn } from "@/lib/utils";
import { getPublishedPosts } from "@/lib/posts";

interface Props {
  locale: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const { locale, alternates } = Astro.props;
const dict = t(locale);
const hasSeries = FEATURES.series && (await getPublishedPosts(locale)).some((post) => Boolean(post.data.series));

const navItems = [
  { href: localeUrl(locale, "blog"), label: dict.nav.blog },
  { href: localeUrl(locale, "tags"), label: dict.nav.tags },
  ...(FEATURES.archives
    ? [{ href: localeUrl(locale, "archives"), label: dict.nav.archives }]
    : []),
  ...(hasSeries
    ? [{ href: localeUrl(locale, "series"), label: dict.nav.series }]
    : []),
  { href: localeUrl(locale, "about"), label: dict.nav.about },
];

const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href);
}

const hudPath = currentPath === "/" || currentPath === "/en/" ? "~/home" : `~${currentPath.replace(/\/$/, "")}`;
---

<header class="sticky top-0 z-40 border-b border-border bg-background/80 backdrop-blur-md">
  
  <ScrollProgress
    client:load
    aria-hidden="true"
    className="fixed inset-x-0 top-0 z-50 h-0.5 origin-left bg-[linear-gradient(90deg,var(--neon-25),var(--neon),var(--neon-70))] shadow-[var(--glow-sm)]"
  />

  <div class="mx-auto flex min-h-16 w-full max-w-6xl flex-wrap items-center justify-between gap-x-4 gap-y-0 px-4 py-2 md:px-6">
    <a
      href={localeUrl(locale)}
      class="group inline-flex min-h-11 items-center gap-2 font-display text-base font-bold uppercase tracking-[0.18em] transition-colors hover:text-accent"
    >
      <span aria-hidden="true" class="font-mono text-accent">&gt;_</span>
      <span class="text-glow" data-preview-site-title>{SITE.title}</span>
    </a>

    <nav aria-label={dict.nav.main} class="order-last w-full sm:order-none sm:w-auto">
      <ul class="flex items-center gap-1">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class={cn(
                  "nav-link-hud relative inline-flex min-h-11 items-center rounded-sm px-3 font-medium text-muted-foreground transition-colors hover:bg-secondary/60 hover:text-foreground",
                  isActive(item.href) &&
                    "after:absolute after:inset-x-3 after:bottom-1.5 after:h-px after:bg-accent after:shadow-[var(--glow-sm)]",
                )}
              >
                <span aria-hidden="true" class="mr-1 text-accent/70">[</span>
                {item.label}
                <span aria-hidden="true" class="ml-1 text-accent/70">]</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-1.5">
      <button
        type="button"
        data-search-open
        aria-label={dict.a11y.openSearch}
        class="inline-flex h-11 w-11 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-secondary hover:text-accent"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>
      <LanguageSwitcher locale={locale} alternates={alternates} />
      <AccentPicker locale={locale} />
      <ThemeToggle locale={locale} />
    </div>
  </div>

  
  <div
    aria-hidden="true"
    class="hidden border-t border-border/60 md:block"
  >
    <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-1 font-mono text-[10px] uppercase tracking-[0.14em] text-muted-foreground md:px-6">
      <span class="truncate">
        <span class="text-accent">operator@lisible</span>:<span>{hudPath}</span><span class="terminal-caret"></span>
      </span>
      <span class="flex items-center gap-4">
        <span>{dict.cyber.hud.sys}</span>
        <span>LOC:{locale.toUpperCase()}</span>
      </span>
    </div>
  </div>
</header>
