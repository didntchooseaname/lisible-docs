---
import Cover from "@/components/reading/Cover.astro";
import { FEATURES } from "@/site.config";
import { postLocale, postUrl, type Post } from "@/lib/posts";
import { formatDate, isoDate, readingTime } from "@/lib/utils";
import { t } from "@/i18n/ui";

interface Props {
  post: Post;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const locale = postLocale(post);
const dict = t(locale);
const url = postUrl(post);
const minutes = readingTime(post.body ?? "");
const hexIndex = `0x${index.toString(16).padStart(2, "0").toUpperCase()}`;
const cover = FEATURES.covers ? post.data.cover : undefined;
---

<article class="group relative flex h-full flex-col p-5">
  {
    cover && (
      <div class="card-cover mb-4" aria-hidden="true">
        <Cover
          cover={cover}
          alt=""
          width={720}
          sizes="(min-width: 640px) 50vw, 100vw"
          class="card-cover-img"
        />
      </div>
    )
  }
  <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-muted-foreground">
    <span class="text-accent" aria-hidden="true">{hexIndex}</span>
    <span aria-hidden="true">&nbsp;::&nbsp;</span>
    <time datetime={isoDate(post.data.pubDate)}>{formatDate(post.data.pubDate, locale)}</time>
  </p>
  <h3 class="mt-3 text-lg font-semibold leading-snug tracking-tight">
    <a
      href={url}
      class="after:absolute after:inset-0 group-hover:text-accent"
    >
      {post.data.title}
    </a>
  </h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">
    {post.data.description}
  </p>
  <p class="mt-4 flex items-center gap-2 font-mono text-[11px] uppercase tracking-wider text-muted-foreground">
    <span class="inline-block h-px w-6 bg-accent/60" aria-hidden="true"></span>
    <span>{dict.post.readingTime(minutes)}</span>
    {
      post.data.tags.slice(0, 2).map((tag) => (
        <span class="text-accent/80">#{tag}</span>
      ))
    }
  </p>
</article>
