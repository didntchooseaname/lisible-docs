---
import { WarpBackground } from "@/components/ui/warp-background";
import { ShimmerButton } from "@/components/ui/shimmer-button";
import { t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---


<section aria-labelledby="newsletter-title">
  <WarpBackground
    client:visible
    perspective={120}
    beamsPerSide={2}
    beamDuration={4}
    gridColor="var(--neon-12)"
    className="rounded-none border-border/70 bg-card/40 p-6 md:p-10"
  >
    <div class="hud-corners mx-auto w-full max-w-xl border border-border bg-background/85 p-6 backdrop-blur-sm md:p-8">
      <p class="section-label" aria-hidden="true">{dict.newsletter.title}</p>
      <h2 id="newsletter-title" class="mt-2 font-display text-xl font-bold tracking-wide">
        {dict.newsletter.title}
      </h2>
      <p class="mt-2 max-w-prose text-sm leading-relaxed text-muted-foreground">
        {dict.newsletter.description}
      </p>
      <div class="mt-5 flex w-full max-w-md flex-col gap-2 sm:flex-row">
        <label for="newsletter-email" class="sr-only">{dict.newsletter.emailLabel}</label>
        <input
          id="newsletter-email"
          type="email"
          inputmode="email"
          placeholder={dict.newsletter.placeholder}
          class="h-11 flex-1 border border-input bg-background/80 px-3 font-mono text-sm placeholder:text-muted-foreground focus:border-accent"
        />
        <ShimmerButton
          client:visible
          shimmerColor="var(--color-accent)"
          shimmerSize="0.1em"
          background="color-mix(in oklab, var(--color-accent) 14%, var(--color-background))"
          className="h-11 rounded-none border border-accent/60 px-6 font-mono text-sm font-semibold uppercase tracking-wider text-foreground shadow-none"
        >
          {dict.newsletter.button}
        </ShimmerButton>
      </div>
      <p class="mt-3 text-xs text-muted-foreground">{dict.newsletter.note}</p>
    </div>
  </WarpBackground>
</section>
