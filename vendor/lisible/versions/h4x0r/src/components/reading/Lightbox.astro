---
import lightboxStyles from "@/scripts/image-lightbox.css?raw";
import { t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale).reading.lightbox;
---

<div
  id="image-lightbox"
  class="image-lightbox"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-label={dict.open}
  hidden
>
  <div class="lightbox-toolbar">
    <span
      class="lightbox-counter"
      data-lightbox-counter
      data-counter-template={`{current} / {total}`}
      aria-live="polite"></span>
    <span class="lightbox-actions">
      <button type="button" class="lightbox-btn" data-lightbox-zoom-out aria-label={dict.zoomOut} title={dict.zoomOut}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 21l-4.34-4.34"></path><circle cx="11" cy="11" r="8"></circle><path d="M8 11h6"></path></svg>
      </button>
      <button type="button" class="lightbox-btn" data-lightbox-zoom-in aria-label={dict.zoomIn} title={dict.zoomIn}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 21l-4.34-4.34"></path><circle cx="11" cy="11" r="8"></circle><path d="M8 11h6"></path><path d="M11 8v6"></path></svg>
      </button>
      <button type="button" class="lightbox-btn" data-lightbox-reset aria-label={dict.reset} title={dict.reset}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
      </button>
      <button type="button" class="lightbox-btn" data-lightbox-close aria-label={dict.close} title={dict.close}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
      </button>
    </span>
  </div>

  <div class="lightbox-stage" data-lightbox-stage>
    <img data-lightbox-image alt="" draggable="false" />
  </div>

  <button type="button" class="lightbox-btn lightbox-nav lightbox-nav-prev" data-lightbox-prev aria-label={dict.prev} title={dict.prev}>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
  </button>
  <button type="button" class="lightbox-btn lightbox-nav lightbox-nav-next" data-lightbox-next aria-label={dict.next} title={dict.next}>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
  </button>
</div>

<style is:inline set:html={lightboxStyles} />

<script>
  if (__FEATURE_IMAGE_ZOOM__) import("@/scripts/image-lightbox");
</script>
