---
import { localeUrl, t } from "@/i18n/ui";
import { getSeriesOf, postLocale, postUrl, type Post } from "@/lib/posts";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const locale = postLocale(post);
const strings = t(locale).platform.series;
const series = await getSeriesOf(post);
const index = series ? series.posts.findIndex((p) => p.id === post.id) : -1;
const prev = series && index > 0 ? series.posts[index - 1] : undefined;
const next =
  series && index >= 0 && index < series.posts.length - 1
    ? series.posts[index + 1]
    : undefined;
---

{
  series && index >= 0 && (
    <nav
      class="series-nav hud-corners mt-8 border border-border bg-background/60 p-4"
      aria-label={`${strings.label}: ${series.name}`}
      data-pagefind-ignore
    >
      <p class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">
        <span class="text-accent">{strings.label}</span>
        <span aria-hidden="true">::</span>
        <a
          href={localeUrl(locale, `series/${series.slug}`)}
          class="text-foreground underline decoration-accent underline-offset-4 transition-colors hover:text-accent"
        >
          {series.name}
        </a>
        <span aria-hidden="true">::</span>
        <span>{strings.part(index + 1, series.posts.length)}</span>
      </p>

      <details class="mt-3">
        <summary class="inline-flex min-h-8 cursor-pointer list-none items-center gap-1.5 font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground transition-colors hover:text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="series-chevron">
            <path d="m9 18 6-6-6-6" />
          </svg>
          {strings.episodes}
        </summary>
        <ol class="mt-2 flex flex-col gap-1 border-l border-border pl-4">
          {series.posts.map((episode, episodeIndex) => (
            <li class="text-sm">
              {episode.id === post.id ? (
                <span class="flex items-baseline gap-2 py-1 font-medium text-accent" aria-current="page">
                  <span class="font-mono text-xs" aria-hidden="true">
                    {String(episodeIndex + 1).padStart(2, "0")}
                  </span>
                  {episode.data.title}
                  <span class="font-mono text-[10px] uppercase tracking-wider">[{strings.current}]</span>
                </span>
              ) : (
                <a
                  href={postUrl(episode)}
                  class="flex items-baseline gap-2 py-1 text-muted-foreground transition-colors hover:text-accent"
                >
                  <span class="font-mono text-xs" aria-hidden="true">
                    {String(episodeIndex + 1).padStart(2, "0")}
                  </span>
                  {episode.data.title}
                </a>
              )}
            </li>
          ))}
        </ol>
      </details>

      {(prev || next) && (
        <div class="mt-3 grid gap-2 border-t border-border/70 pt-3 sm:grid-cols-2">
          {prev ? (
            <a href={postUrl(prev)} class="group flex flex-col gap-0.5">
              <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-muted-foreground">
                &lt;- {strings.prev}
              </span>
              <span class="text-sm font-medium transition-colors group-hover:text-accent">{prev.data.title}</span>
            </a>
          ) : (
            <span aria-hidden="true" />
          )}
          {next && (
            <a href={postUrl(next)} class="group flex flex-col gap-0.5 sm:col-start-2 sm:text-right">
              <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-muted-foreground">
                {strings.next} -&gt;
              </span>
              <span class="text-sm font-medium transition-colors group-hover:text-accent">{next.data.title}</span>
            </a>
          )}
        </div>
      )}
    </nav>
  )
}
