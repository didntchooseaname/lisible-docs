---
import { SITE } from "@/site.config";
import { ensureTrailingSlash, t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  title: string;
}

const { locale, title } = Astro.props;
const strings = t(locale).platform.share;

const url = new URL(ensureTrailingSlash(Astro.url.pathname), SITE.url).toString();
const text = `${title} ${url}`;

const xHref = `https://x.com/intent/post?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
const blueskyHref = `https://bsky.app/intent/compose?text=${encodeURIComponent(text)}`;
const linkedinHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;

const iconClass =
  "share-btn inline-flex h-11 w-11 items-center justify-center border border-border bg-background/60 text-muted-foreground transition-colors hover:border-accent/70 hover:text-accent";
---

<div
  class="share-row"
  data-share-row
  data-share-text={text}
  data-share-url={url}
  data-mastodon-prompt={strings.mastodonPrompt}
  data-copied-label={strings.copied}
>
  <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">
    {strings.title}
  </p>
  <ul class="mt-3 flex flex-wrap items-center gap-2">
    <li>
      <a href={xHref} rel="external noopener" target="_blank" aria-label={strings.x} class={iconClass}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.25 2h3.36l-7.34 8.39L22.9 22h-6.76l-5.3-6.93L4.78 22H1.42l7.85-8.97L1 2h6.93l4.79 6.33L18.25 2Zm-1.18 18h1.86L6.92 3.9H4.92L17.07 20Z"></path>
        </svg>
      </a>
    </li>
    <li>
      <a href={blueskyHref} rel="external noopener" target="_blank" aria-label={strings.bluesky} class={iconClass}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M5.2 3.6C7.6 5.4 10.2 9 12 11.4c1.8-2.4 4.4-6 6.8-7.8 1.7-1.3 4.2-2.3 4.2.9 0 .6-.4 5.3-.6 6.1-.7 2.6-3.2 3.3-5.5 2.9 3.9.7 4.9 2.9 2.7 5.1-4 4.2-5.8-1-7.4-2.4-.1-.1-.2-.2-.2-.2s-.1.1-.2.2c-1.6 1.4-3.4 6.6-7.4 2.4-2.2-2.2-1.2-4.4 2.7-5.1-2.3.4-4.8-.3-5.5-2.9-.2-.8-.6-5.5-.6-6.1 0-3.2 2.5-2.2 4.2-.9Z"></path>
        </svg>
      </a>
    </li>
    <li>
      <a href={linkedinHref} rel="external noopener" target="_blank" aria-label={strings.linkedin} class={iconClass}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
          <rect width="4" height="12" x="2" y="9"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </a>
    </li>
    <li>
      <button type="button" data-share-mastodon aria-label={strings.mastodon} class={iconClass}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M21.6 13.8c-.3 1.6-2.9 3.4-5.8 3.7-1.5.2-3 .4-4.6.3-2.6-.1-4.7-.6-4.7-.6v.7c.4 2.5 2.5 2.7 4.6 2.7 2 .1 3.8-.5 3.8-.5l.1 1.8s-1.4.8-4 .9c-1.4.1-3.2-.03-5.2-.6-4.4-1.2-5.2-5.9-5.3-10.7V7.6c0-4.9 3.2-6.3 3.2-6.3C5.3.5 8.1.24 11 .2h.1c2.9.03 5.7.3 7.3 1.1 0 0 3.2 1.4 3.2 6.3 0 0 .04 3.6-.4 6.1l.4.1ZM18.3 8c0-1.2-.3-2.2-.9-2.9-.6-.7-1.5-1-2.5-1-1.2 0-2.1.5-2.7 1.4l-.6 1-.6-1c-.6-.9-1.5-1.4-2.7-1.4-1 0-1.9.3-2.5 1-.6.7-.9 1.7-.9 2.9v6h2.4V8.2c0-1.2.5-1.8 1.5-1.8 1.1 0 1.7.7 1.7 2.1v3.1h2.3v-3c0-1.4.5-2.2 1.6-2.2 1 0 1.5.6 1.5 1.8V14h2.4V8Z"></path>
        </svg>
      </button>
    </li>
    <li>
      <button type="button" data-share-copy aria-label={strings.copyLink} class={iconClass}>
        <svg data-share-copy-icon xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
        </svg>
        <svg data-share-copy-check xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden text-accent">
          <path d="M20 6 9 17l-5-5"></path>
        </svg>
      </button>
    </li>
  </ul>
  <p class="mt-2 hidden font-mono text-[11px] uppercase tracking-[0.18em] text-accent" data-share-feedback aria-live="polite"></p>
</div>

<script>
  function getRow(): HTMLElement | null {
    return document.querySelector<HTMLElement>("[data-share-row]");
  }

  function feedback(row: HTMLElement, message: string): void {
    const zone = row.querySelector<HTMLElement>("[data-share-feedback]");
    if (!zone) return;
    zone.textContent = message;
    zone.classList.remove("hidden");
    window.setTimeout(() => zone.classList.add("hidden"), 2000);
  }

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;
    const row = getRow();
    if (!row) return;

    if (target?.closest("[data-share-mastodon]")) {
      let instance = localStorage.getItem("mastodon-instance");
      if (!instance) {
        const answer = window.prompt(row.dataset.mastodonPrompt ?? "");
        if (!answer) return;
        instance = answer.trim().replace(/^https?:\/\//, "").replace(/\/.*$/, "");
        if (!instance) return;
        localStorage.setItem("mastodon-instance", instance);
      }
      const text = row.dataset.shareText ?? "";
      window.open(
        `https://${instance}/share?text=${encodeURIComponent(text)}`,
        "_blank",
        "noopener",
      );
      return;
    }

    const copyButton = target?.closest<HTMLElement>("[data-share-copy]");
    if (copyButton) {
      void navigator.clipboard
        .writeText(row.dataset.shareUrl ?? "")
        .then(() => {
          feedback(row, row.dataset.copiedLabel ?? "");
          const icon = copyButton.querySelector("[data-share-copy-icon]");
          const check = copyButton.querySelector("[data-share-copy-check]");
          icon?.classList.add("hidden");
          check?.classList.remove("hidden");
          window.setTimeout(() => {
            icon?.classList.remove("hidden");
            check?.classList.add("hidden");
          }, 2000);
        })
        .catch(() => {});
    }
  });
</script>
