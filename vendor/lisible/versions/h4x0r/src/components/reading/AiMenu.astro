---
import { FEATURES, SITE } from "@/site.config";
import { ensureTrailingSlash, t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  markdownPath: string;
}

const { locale, markdownPath } = Astro.props;
const strings = t(locale).platform.ai;

const url = new URL(ensureTrailingSlash(Astro.url.pathname), SITE.url).toString();
const prompt = strings.prompt(url);
const claudeHref = `https://claude.ai/new?q=${encodeURIComponent(prompt)}`;
const chatgptHref = `https://chatgpt.com/?q=${encodeURIComponent(prompt)}`;

const itemClass =
  "flex min-h-11 w-full items-center gap-2.5 px-3 text-left text-sm text-muted-foreground transition-colors hover:bg-secondary/60 hover:text-accent";
---

<details class="ai-menu" data-ai-menu data-md-path={FEATURES.llmsTxt ? markdownPath : ""}>
  <summary
    class="inline-flex min-h-11 cursor-pointer list-none items-center gap-2 border border-border bg-background/60 px-3 font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground transition-colors hover:border-accent/70 hover:text-accent"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 8V4H8"></path>
      <rect width="16" height="12" x="4" y="8" rx="2"></rect>
      <path d="M2 14h2"></path>
      <path d="M20 14h2"></path>
      <path d="M15 13v2"></path>
      <path d="M9 13v2"></path>
    </svg>
    {strings.label}
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="ai-menu-chevron">
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>
  <div class="ai-menu-panel" role="menu">
    {
      FEATURES.llmsTxt && (
        <button
          type="button"
          role="menuitem"
          data-ai-copy
          data-copied-label={strings.copied}
          data-failed-label={strings.copyFailed}
          class={itemClass}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
            <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
          </svg>
          <span data-ai-copy-label>{strings.copyMarkdown}</span>
        </button>
      )
    }
    <a href={claudeHref} rel="external noopener" target="_blank" role="menuitem" class={itemClass}>
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3v3"></path>
        <path d="m5.6 5.6 2.1 2.1"></path>
        <path d="M3 12h3"></path>
        <path d="m5.6 18.4 2.1-2.1"></path>
        <path d="M12 21v-3"></path>
        <path d="m18.4 18.4-2.1-2.1"></path>
        <path d="M21 12h-3"></path>
        <path d="m18.4 5.6-2.1 2.1"></path>
      </svg>
      {strings.openClaude}
    </a>
    <a href={chatgptHref} rel="external noopener" target="_blank" role="menuitem" class={itemClass}>
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
      </svg>
      {strings.openChatgpt}
    </a>
  </div>
</details>

<script>
  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;

    const openMenu = document.querySelector<HTMLDetailsElement>("[data-ai-menu][open]");
    if (openMenu && !target?.closest("[data-ai-menu]")) {
      openMenu.open = false;
    }

    const copyButton = target?.closest<HTMLElement>("[data-ai-copy]");
    if (!copyButton) return;
    const menu = copyButton.closest<HTMLElement>("[data-ai-menu]");
    const path = menu?.dataset.mdPath;
    if (!path) return;
    const label = copyButton.querySelector<HTMLElement>("[data-ai-copy-label]");
    const original = label?.textContent ?? "";
    void fetch(path)
      .then((response) => {
        if (!response.ok) throw new Error(String(response.status));
        return response.text();
      })
      .then((markdown) => navigator.clipboard.writeText(markdown))
      .then(() => {
        if (label) label.textContent = copyButton.dataset.copiedLabel ?? original;
      })
      .catch(() => {
        if (label) label.textContent = copyButton.dataset.failedLabel ?? original;
      })
      .finally(() => {
        window.setTimeout(() => {
          if (label) label.textContent = original;
        }, 2000);
      });
  });

  document.addEventListener("astro:before-swap", () => {
    const menu = document.querySelector<HTMLDetailsElement>("[data-ai-menu][open]");
    if (menu) menu.open = false;
  });
</script>
