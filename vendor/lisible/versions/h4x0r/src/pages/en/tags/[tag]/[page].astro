---
import TagPage from "@/components/pages/TagPage.astro";
import { FEATURES } from "@/site.config";
import { getAllTags, getPostsByTag, pageCount } from "@/lib/posts";

export async function getStaticPaths() {
  if (!FEATURES.pagination.enabled) return [];
  const tags = await getAllTags("en");
  const paths = [];
  for (const tag of tags) {
    const posts = await getPostsByTag("en", tag.slug);
    const total = pageCount(posts.length);
    for (let page = 2; page <= total; page++) {
      paths.push({
        params: { tag: tag.slug, page: String(page) },
        props: { tagName: tag.name, current: page },
      });
    }
  }
  return paths;
}

const { tag } = Astro.params;
const { tagName, current } = Astro.props;
const posts = await getPostsByTag("en", tag);
---

<TagPage locale="en" tagSlug={tag} tagName={tagName} posts={posts} current={current} />
