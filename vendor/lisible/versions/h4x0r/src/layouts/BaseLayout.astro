---
import appCssUrl from "@/styles/app.css?url";
import { ClientRouter } from "astro:transitions";
import LandingLocaleBootstrap from "@shared/components/LandingLocaleBootstrap.astro";
import ExpressiveCodeLabelSpacing from "@shared/components/ExpressiveCodeLabelSpacing.astro";
import AppearanceBootstrap from "@shared/components/AppearanceBootstrap.astro";
import PreviewBridge from "@shared/components/PreviewBridge.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SearchModal from "@/components/SearchModal.astro";
import CyberScene from "@/components/cyber/CyberScene";
import HudDecor from "@/components/cyber/HudDecor.astro";
import BootOverlay from "@/components/cyber/BootOverlay.astro";
import SmartCursor from "@/components/cyber/SmartCursor";
import KonamiEgg from "@/components/cyber/KonamiEgg";
import { SITE } from "@/site.config";
import { ensureTrailingSlash, localeUrl, ogLocales, otherLocale, t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  ogType?: "website" | "article";
  alternates?: Partial<Record<Locale, string>>;
  isHome?: boolean;
  scene?: "intense" | "calm";
  ogImagePath?: string;
  relPrev?: string;
  relNext?: string;
}

const {
  locale,
  title,
  description,
  ogType = "website",
  alternates,
  isHome = false,
  scene = "intense",
  ogImagePath,
  relPrev,
  relNext,
} = Astro.props;

const dict = t(locale);
const pageTitle = isHome ? title : `${title} | ${SITE.title}`;
const canonicalPath = ensureTrailingSlash(Astro.url.pathname);
const canonicalUrl = new URL(canonicalPath, SITE.url);
const ogImage = new URL(ogImagePath ?? "/og-default.png", SITE.url);
const rssPath = localeUrl(locale, "rss.xml");
const hasBothAlternates = Boolean(alternates?.fr && alternates?.en);
const other = otherLocale(locale);
---

<html lang={locale}>
  <head>
    <LandingLocaleBootstrap />
    <ExpressiveCodeLabelSpacing />
    <meta charset="utf-8" />
    <link rel="stylesheet" href={appCssUrl} />
    <AppearanceBootstrap accent={SITE.accent} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <PreviewBridge />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL(rssPath, SITE.url)}
    />


    {relPrev && <link rel="prev" href={new URL(ensureTrailingSlash(relPrev), SITE.url)} />}
    {relNext && <link rel="next" href={new URL(ensureTrailingSlash(relNext), SITE.url)} />}

    {
      hasBothAlternates && (
        <>
          <link rel="alternate" hreflang="fr" href={new URL(ensureTrailingSlash(alternates!.fr!), SITE.url)} />
          <link rel="alternate" hreflang="en" href={new URL(ensureTrailingSlash(alternates!.en!), SITE.url)} />
          <link rel="alternate" hreflang="x-default" href={new URL(ensureTrailingSlash(alternates!.fr!), SITE.url)} />
        </>
      )
    }

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocales[locale]} />
    {hasBothAlternates && <meta property="og:locale:alternate" content={ogLocales[other]} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="flex min-h-dvh flex-col" data-cyber-scene={scene}>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:border focus:border-border focus:bg-background focus:px-4 focus:py-3 focus:font-medium"
    >
      {dict.a11y.skipToContent}
    </a>

    
    <div transition:persist="cyber-scene" aria-hidden="true">
      <CyberScene client:load />
    </div>

    <Header locale={locale} alternates={alternates} />
    <main id="main" class="cyber-content mx-auto w-full max-w-6xl flex-1 px-4 md:px-6">
      <slot />
    </main>
    <Footer locale={locale} />
    <SearchModal locale={locale} alternates={alternates} />

    
    <HudDecor locale={locale} />
    <div transition:persist="cyber-cursor" aria-hidden="true">
      <SmartCursor client:idle />
    </div>
    <div transition:persist="cyber-egg" aria-hidden="true">
      <KonamiEgg client:idle />
    </div>
    <BootOverlay locale={locale} />
    <script>import "@shared/scripts/locale-preference";</script>
    <script>import "@shared/scripts/diagram-fullscreen";</script>
  </body>
</html>
