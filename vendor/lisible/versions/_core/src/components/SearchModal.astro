---
import { FEATURES } from "@/site.config";
import { localeUrl, otherLocale, t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const { locale, alternates } = Astro.props;
const dict = t(locale);
const palette = FEATURES.commandPalette;

const PaletteStyles = __F_COMMAND_PALETTE__
  ? (await import("@/components/runtime/PaletteStyles.astro")).default
  : null;
const other = otherLocale(locale);
const langHref = alternates?.[other] ?? localeUrl(other, "blog");

type Action =
  | { kind: "run"; run: string; icon: string; label: string }
  | { kind: "link"; href: string; icon: string; label: string };

const actions: Action[] = palette
  ? [
      { kind: "run", run: "theme", icon: "theme", label: dict.palette.toggleTheme },
      { kind: "link", href: langHref, icon: "language", label: dict.palette.switchLanguage },
      { kind: "run", run: "accent", icon: "accent", label: dict.palette.resetAccent },
      { kind: "run", run: "copyurl", icon: "copyurl", label: dict.palette.copyUrl },
      { kind: "link", href: localeUrl(locale, "blog"), icon: "blog", label: dict.palette.goBlog },
      { kind: "link", href: localeUrl(locale, "tags"), icon: "tags", label: dict.palette.goTags },
      ...(FEATURES.archives
        ? [{ kind: "link", href: localeUrl(locale, "archives"), icon: "archives", label: dict.palette.goArchives } as Action]
        : []),
      { kind: "link", href: localeUrl(locale, "about"), icon: "about", label: dict.palette.goAbout },
      { kind: "link", href: localeUrl(locale, "rss.xml"), icon: "rss", label: dict.palette.openRss },
    ]
  : [];

const iconPaths: Record<string, string> = {
  theme:
    '<path d="M12 8a2.83 2.83 0 0 0 4 4 4 4 0 1 1-4-4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.9 4.9 1.4 1.4"/><path d="m17.7 17.7 1.4 1.4"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.3 17.7-1.4 1.4"/><path d="m19.1 4.9-1.4 1.4"/>',
  language:
    '<circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/>',
  accent:
    '<path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/>',
  copyurl:
    '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
  blog:
    '<path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/>',
  tags:
    '<path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>',
  archives:
    '<rect width="20" height="5" x="2" y="3" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 12h4"/>',
  about:
    '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
  rss:
    '<path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>',
};
---

{PaletteStyles && <PaletteStyles />}

<dialog
  data-search-modal
  data-palette={palette ? "" : undefined}
  aria-label={palette ? dict.palette.title : dict.search.title}
  data-hint={dict.search.hint}
  data-no-results={dict.search.noResults}
  data-dev-notice={dict.search.devNotice}
  data-url-copied={dict.palette.urlCopied}
>
  <div class="flex items-center gap-2 border-b border-border px-4">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="shrink-0 text-muted-foreground"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <input
      type="search"
      id="search-input"
      name="search"
      data-search-input
      placeholder={dict.search.placeholder}
      aria-label={palette ? dict.palette.title : dict.search.title}
      autocomplete="off"
      class="h-12 w-full bg-transparent text-base outline-none placeholder:text-muted-foreground"
    />
    <button
      type="button"
      data-search-close
      aria-label={dict.a11y.closeSearch}
      class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>

  <div data-palette-scroll class="max-h-[60vh] overflow-y-auto p-2">
    {
      palette && (
        <section data-actions-section>
          <p class="palette-group px-3 pb-1 pt-2">{dict.palette.actionsGroup}</p>
          <ul role="listbox" aria-label={dict.palette.actionsGroup} class="flex flex-col gap-0.5">
            {actions.map((action) => (
              <li data-action-item>
                {action.kind === "run" ? (
                  <button
                    type="button"
                    data-palette-item
                    data-run={action.run}
                    role="option"
                    aria-selected="false"
                    class="palette-item flex w-full items-center gap-2.5 rounded-md px-3 py-2 text-left text-sm"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="15"
                      height="15"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      class="shrink-0 text-muted-foreground"
                      set:html={iconPaths[action.icon]}
                    />
                    <span data-run-label>{action.label}</span>
                  </button>
                ) : (
                  <a
                    href={action.href}
                    data-palette-item
                    role="option"
                    aria-selected="false"
                    class="palette-item flex w-full items-center gap-2.5 rounded-md px-3 py-2 text-left text-sm"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="15"
                      height="15"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      class="shrink-0 text-muted-foreground"
                      set:html={iconPaths[action.icon]}
                    />
                    <span>{action.label}</span>
                  </a>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section data-results-section>
      {palette && <p class="palette-group px-3 pb-1 pt-2" data-results-heading hidden>{dict.palette.resultsGroup}</p>}
      <div data-search-results>
        <p class="px-3 py-6 text-center text-sm text-muted-foreground">{dict.search.hint}</p>
      </div>
    </section>
  </div>
</dialog>

<script>
  type PagefindResult = {
    data: () => Promise<{
      url: string;
      excerpt: string;
      meta: { title?: string };
    }>;
  };

  type PagefindModule = {
    options: (options: Record<string, unknown>) => Promise<void>;
    init: () => void;
    debouncedSearch: (
      query: string,
    ) => Promise<{ results: PagefindResult[] } | null>;
  };

  let pagefind: PagefindModule | null = null;
  let loadFailed = false;
  let activeIndex = -1;

  function getModal(): HTMLDialogElement | null {
    return document.querySelector<HTMLDialogElement>("[data-search-modal]");
  }

  function normalize(value: string): string {
    return value
      .normalize("NFD")
      .replace(/[̀-ͯ]/g, "")
      .toLowerCase()
      .trim();
  }

  function renderMessage(modal: HTMLDialogElement, message: string) {
    const container = modal.querySelector("[data-search-results]");
    if (!container) return;
    container.innerHTML = "";
    const p = document.createElement("p");
    p.className = "px-3 py-6 text-center text-sm text-muted-foreground";
    p.textContent = message;
    container.appendChild(p);
    toggleResultsHeading(modal, false);
  }

  function toggleResultsHeading(modal: HTMLDialogElement, visible: boolean) {
    const heading = modal.querySelector<HTMLElement>("[data-results-heading]");
    if (heading) heading.hidden = !visible;
  }

  function visibleItems(modal: HTMLDialogElement): HTMLElement[] {
    return Array.from(
      modal.querySelectorAll<HTMLElement>("[data-palette-item]"),
    ).filter((el) => el.offsetParent !== null);
  }

  function setActive(modal: HTMLDialogElement, index: number) {
    modal.querySelectorAll<HTMLElement>("[data-palette-item]").forEach((el) => {
      el.removeAttribute("data-active");
      el.setAttribute("aria-selected", "false");
    });
    const items = visibleItems(modal);
    if (items.length === 0) {
      activeIndex = -1;
      return;
    }
    activeIndex = ((index % items.length) + items.length) % items.length;
    const current = items[activeIndex];
    current.setAttribute("data-active", "");
    current.setAttribute("aria-selected", "true");
    current.scrollIntoView({ block: "nearest" });
  }

  function filterActions(modal: HTMLDialogElement, query: string): number {
    const q = normalize(query);
    let shown = 0;
    modal.querySelectorAll<HTMLElement>("[data-action-item]").forEach((li) => {
      const label = normalize(li.textContent ?? "");
      const match = q === "" || label.includes(q);
      li.hidden = !match;
      if (match) shown += 1;
    });
    const section = modal.querySelector<HTMLElement>("[data-actions-section]");
    if (section) section.hidden = shown === 0;
    return shown;
  }

  async function ensurePagefind(): Promise<void> {
    if (pagefind || loadFailed) return;
    try {
      const module = (await import(
        /* @vite-ignore */ "/pagefind/pagefind.js"
      )) as PagefindModule;
      await module.options({ excerptLength: 25 });
      module.init();
      pagefind = module;
    } catch {
      loadFailed = true;
    }
  }

  async function openSearch(): Promise<void> {
    const modal = getModal();
    if (!modal || modal.open) return;
    modal.showModal();
    const input = modal.querySelector<HTMLInputElement>("[data-search-input]");
    if (input) {
      input.value = "";
      input.focus();
    }
    filterActions(modal, "");
    activeIndex = -1;
    setActive(modal, -1);
    const container = modal.querySelector("[data-search-results]");
    if (container) {
      container.innerHTML = "";
      const p = document.createElement("p");
      p.className = "px-3 py-6 text-center text-sm text-muted-foreground";
      p.textContent = modal.dataset.hint ?? "";
      container.appendChild(p);
    }
    toggleResultsHeading(modal, false);
    await ensurePagefind();
    if (loadFailed) renderMessage(modal, modal.dataset.devNotice ?? "");
  }

  async function runSearch(input: HTMLInputElement): Promise<void> {
    const modal = getModal();
    if (!modal) return;
    const query = input.value.trim();
    const actionsShown = filterActions(modal, query);

    if (!query) {
      renderMessage(modal, modal.dataset.hint ?? "");
      setActive(modal, actionsShown > 0 ? 0 : -1);
      return;
    }
    if (loadFailed) {
      renderMessage(modal, modal.dataset.devNotice ?? "");
      setActive(modal, actionsShown > 0 ? 0 : -1);
      return;
    }
    if (!pagefind) {
      setActive(modal, actionsShown > 0 ? 0 : -1);
      return;
    }

    const search = await pagefind.debouncedSearch(query);
    if (!search) return;

    const results = await Promise.all(
      search.results.slice(0, 8).map((result) => result.data()),
    );
    const container = modal.querySelector("[data-search-results]");
    if (!container) return;

    if (results.length === 0) {
      renderMessage(modal, modal.dataset.noResults ?? "");
      setActive(modal, actionsShown > 0 ? 0 : -1);
      return;
    }

    const list = document.createElement("ul");
    list.className = "flex flex-col gap-1";
    for (const result of results) {
      const item = document.createElement("li");
      const link = document.createElement("a");
      link.href = result.url;
      link.setAttribute("data-palette-item", "");
      link.setAttribute("role", "option");
      link.setAttribute("aria-selected", "false");
      link.className = "palette-item block rounded-md px-3 py-2.5";
      const title = document.createElement("span");
      title.className = "block text-sm font-semibold";
      title.textContent = result.meta.title ?? result.url;
      const excerpt = document.createElement("span");
      excerpt.className = "mt-0.5 block text-xs leading-relaxed text-muted-foreground";
      excerpt.innerHTML = result.excerpt;
      link.append(title, excerpt);
      item.appendChild(link);
      list.appendChild(item);
    }
    container.innerHTML = "";
    container.appendChild(list);
    toggleResultsHeading(modal, true);
    setActive(modal, 0);
  }

  function runAction(button: HTMLElement): void {
    const modal = getModal();
    const action = button.dataset.run;
    if (action === "theme") {
      modal?.close();
      requestAnimationFrame(() =>
        document.querySelector<HTMLElement>("[data-theme-toggle]")?.click(),
      );
    } else if (action === "accent") {
      localStorage.removeItem("accent");
      (window as { __applyAccent?: () => void }).__applyAccent?.();
      modal?.close();
    } else if (action === "copyurl") {
      void navigator.clipboard?.writeText(window.location.href);
      const label = button.querySelector<HTMLElement>("[data-run-label]");
      const copied = modal?.dataset.urlCopied ?? "";
      if (label) {
        const original = label.textContent;
        label.textContent = copied;
        window.setTimeout(() => {
          label.textContent = original;
          modal?.close();
        }, 900);
      } else {
        modal?.close();
      }
    }
  }

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;
    if (target?.closest("[data-search-open]")) {
      void openSearch();
      return;
    }
    if (target?.closest("[data-search-close]")) {
      getModal()?.close();
      return;
    }
    const runButton = target?.closest<HTMLElement>("[data-run]");
    if (runButton) {
      runAction(runButton);
      return;
    }
    const modal = getModal();
    if (modal?.open && event.target === modal) {
      modal.close();
    }
  });

  document.addEventListener("keydown", (event) => {
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      const modal = getModal();
      if (modal?.open) modal.close();
      else void openSearch();
      return;
    }

    const modal = getModal();
    if (!modal?.open) return;

    if (event.key === "ArrowDown") {
      event.preventDefault();
      setActive(modal, activeIndex + 1);
    } else if (event.key === "ArrowUp") {
      event.preventDefault();
      setActive(modal, activeIndex - 1);
    } else if (event.key === "Enter") {
      const items = visibleItems(modal);
      const current = items[activeIndex];
      if (current) {
        event.preventDefault();
        current.click();
      }
    }
  });

  document.addEventListener("mousemove", (event) => {
    const target = event.target as HTMLElement | null;
    const item = target?.closest<HTMLElement>("[data-palette-item]");
    const modal = getModal();
    if (!item || !modal?.open) return;
    const items = visibleItems(modal);
    const index = items.indexOf(item);
    if (index >= 0 && index !== activeIndex) setActive(modal, index);
  });

  document.addEventListener("input", (event) => {
    const input = event.target as HTMLInputElement | null;
    if (!input?.matches("[data-search-input]")) return;
    void runSearch(input);
  });

  document.addEventListener("astro:before-swap", () => {
    getModal()?.close();
  });
</script>
