---
import { postUrl, type Post } from "@/lib/posts";
import { formatDate, isoDate, readingTime } from "@/lib/utils";
import { t, type Locale } from "@/i18n/ui";

interface Props {
  posts: Post[];
  locale: Locale;
}

const { posts, locale } = Astro.props;
const dict = t(locale);
---

{
  posts.length > 0 && (
    <section aria-labelledby="related-title" class="mt-14 border-t border-border pt-8">
      <h2 id="related-title" class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        {dict.post.related}
      </h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((related) => (
          <article class="group relative flex flex-col rounded-lg border border-border bg-card p-4 transition-colors hover:border-accent">
            <h3 class="font-semibold leading-snug tracking-tight">
              <a href={postUrl(related)} class="after:absolute after:inset-0 group-hover:text-accent">
                {related.data.title}
              </a>
            </h3>
            <p class="mt-2 line-clamp-2 text-sm text-muted-foreground">{related.data.description}</p>
            <p class="mt-3 flex flex-wrap items-center gap-x-2 text-xs text-muted-foreground">
              <time datetime={isoDate(related.data.pubDate)}>{formatDate(related.data.pubDate, locale, "short")}</time>
              <span aria-hidden="true">&middot;</span>
              <span>{dict.post.readingTime(readingTime(related.body ?? ""))}</span>
            </p>
          </article>
        ))}
      </div>
    </section>
  )
}
