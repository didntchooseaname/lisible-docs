---
import { t, type Locale } from "@/i18n/ui";
import { cn } from "@/lib/utils";

interface Props {
  locale: Locale;
  current: number;
  last: number;
  prevUrl?: string;
  nextUrl?: string;
}

const { locale, current, last, prevUrl, nextUrl } = Astro.props;
const dict = t(locale);

const linkBase =
  "inline-flex min-h-11 items-center gap-1.5 rounded-md border border-border px-4 text-sm font-medium transition-colors";
const linkActive = "text-foreground hover:border-accent hover:text-accent";
const linkDisabled = "pointer-events-none opacity-40 text-muted-foreground";
---

{
  last > 1 && (
    <nav aria-label={dict.pagination.label} class="mt-12 flex items-center justify-between gap-4 border-t border-border pt-6">
      {prevUrl ? (
        <a href={prevUrl} rel="prev" class={cn(linkBase, linkActive)}>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6" />
          </svg>
          {dict.pagination.prev}
        </a>
      ) : (
        <span class={cn(linkBase, linkDisabled)} aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6" />
          </svg>
          {dict.pagination.prev}
        </span>
      )}

      <span class="text-sm text-muted-foreground" aria-current="page">
        {dict.pagination.page(current, last)}
      </span>

      {nextUrl ? (
        <a href={nextUrl} rel="next" class={cn(linkBase, linkActive)}>
          {dict.pagination.next}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </a>
      ) : (
        <span class={cn(linkBase, linkDisabled)} aria-hidden="true">
          {dict.pagination.next}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </span>
      )}
    </nav>
  )
}
