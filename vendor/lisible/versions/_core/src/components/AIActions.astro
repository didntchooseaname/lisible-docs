---
import { t, type Locale } from "@/i18n/ui";
import { FEATURES } from "@/site.config";

interface Props {
  locale: Locale;
  url: string;
  mdUrl?: string;
  markdown: string;
}

const { locale, url, mdUrl, markdown } = Astro.props;
const dict = t(locale);

const prompt = encodeURIComponent(dict.ai.prompt(url));
const claudeUrl = `https://claude.ai/new?q=${prompt}`;
const chatgptUrl = `https://chatgpt.com/?q=${prompt}`;

const mdJson = JSON.stringify(markdown).replace(/</g, "\\u003c");
---

<div
  class="relative"
  data-ai-actions
  data-copied-label={dict.ai.markdownCopied}
  data-copy-label={dict.ai.copyMarkdown}
>
  <script type="application/json" data-ai-markdown set:html={mdJson} is:inline />
  <button
    type="button"
    data-ai-open
    aria-haspopup="menu"
    aria-expanded="false"
    class="inline-flex items-center gap-2 rounded-md border border-border px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:border-accent hover:text-foreground"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3a3 3 0 0 0-3 3v12a3 3 0 0 0 6 0V6a3 3 0 0 0-3-3Z"></path>
      <path d="M9 9h6"></path>
      <path d="M9 15h6"></path>
    </svg>
    {dict.ai.title}
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" data-ai-chevron class="transition-transform">
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </button>

  <div
    role="menu"
    data-ai-menu
    hidden
    class="absolute right-0 z-50 mt-2 w-60 overflow-hidden rounded-lg border border-border bg-popover p-1 text-popover-foreground shadow-xl"
  >
    <button
      type="button"
      role="menuitem"
      data-ai-copy
      class="flex w-full items-center gap-2.5 rounded-md px-3 py-2 text-left text-sm transition-colors hover:bg-secondary"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
      </svg>
      <span data-ai-copy-text>{dict.ai.copyMarkdown}</span>
    </button>

    {
      FEATURES.llmsTxt && mdUrl && (
        <a
          role="menuitem"
          href={mdUrl}
          class="flex items-center gap-2.5 rounded-md px-3 py-2 text-sm transition-colors hover:bg-secondary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <path d="M14 2v6h6" />
          </svg>
          {dict.ai.viewMarkdown}
        </a>
      )
    }

    <a
      role="menuitem"
      href={claudeUrl}
      target="_blank"
      rel="noopener noreferrer external"
      class="flex items-center gap-2.5 rounded-md px-3 py-2 text-sm transition-colors hover:bg-secondary"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground">
        <path d="M7.5 4.5 12 15l4.5-10.5" />
        <path d="M3 19.5 12 3l9 16.5" />
      </svg>
      {dict.ai.openInClaude}
    </a>

    <a
      role="menuitem"
      href={chatgptUrl}
      target="_blank"
      rel="noopener noreferrer external"
      class="flex items-center gap-2.5 rounded-md px-3 py-2 text-sm transition-colors hover:bg-secondary"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-muted-foreground">
        <circle cx="12" cy="12" r="9" />
        <path d="M12 7v10M7 12h10" />
      </svg>
      {dict.ai.openInChatGPT}
    </a>
  </div>
</div>

<script>
  function menu(): HTMLElement | null {
    return document.querySelector<HTMLElement>("[data-ai-menu]");
  }
  function root(): HTMLElement | null {
    return document.querySelector<HTMLElement>("[data-ai-actions]");
  }

  function setOpen(open: boolean): void {
    const m = menu();
    const btn = document.querySelector<HTMLElement>("[data-ai-open]");
    const chevron = document.querySelector<HTMLElement>("[data-ai-chevron]");
    if (!m || !btn) return;
    m.hidden = !open;
    btn.setAttribute("aria-expanded", String(open));
    chevron?.classList.toggle("rotate-180", open);
  }

  async function copyMarkdown(): Promise<void> {
    const holder = document.querySelector<HTMLElement>("[data-ai-markdown]");
    const el = root();
    const label = document.querySelector<HTMLElement>("[data-ai-copy-text]");
    if (!holder || !el || !label) return;
    let markdown = "";
    try {
      markdown = JSON.parse(holder.textContent ?? '""');
    } catch {
      return;
    }
    try {
      await navigator.clipboard.writeText(markdown);
      const original = el.dataset.copyLabel ?? "";
      label.textContent = el.dataset.copiedLabel ?? "";
      window.setTimeout(() => {
        label.textContent = original;
      }, 1600);
    } catch {}
  }

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;
    if (target?.closest("[data-ai-open]")) {
      setOpen(menu()?.hidden ?? true);
      return;
    }
    if (target?.closest("[data-ai-copy]")) {
      void copyMarkdown();
      return;
    }
    if (!target?.closest("[data-ai-actions]")) setOpen(false);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setOpen(false);
  });

  document.addEventListener("astro:before-swap", () => setOpen(false));
</script>
