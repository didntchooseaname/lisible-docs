---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostList from "@/components/PostList.astro";
import Pagination from "@/components/Pagination.astro";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { getPublishedPosts, groupByYear, paginatePosts } from "@/lib/posts";
import { FEATURES } from "@/site.config";

interface Props {
  locale: Locale;
  page?: number;
}

const { locale, page = 1 } = Astro.props;
const dict = t(locale);

const posts = await getPublishedPosts(locale);
const paginationOn = FEATURES.pagination.enabled;

const paged = paginationOn
  ? paginatePosts(posts, FEATURES.pagination.pageSize, page)
  : null;
const years = paginationOn ? [] : groupByYear(posts);

function pageUrl(n: number): string {
  return n <= 1 ? localeUrl(locale, "blog") : localeUrl(locale, `blog/${n}`);
}
const prevUrl = paged && paged.current > 1 ? pageUrl(paged.current - 1) : undefined;
const nextUrl = paged && paged.current < paged.last ? pageUrl(paged.current + 1) : undefined;

const alternates =
  !paged || paged.current === 1
    ? { fr: localeUrl("fr", "blog"), en: localeUrl("en", "blog") }
    : {
        fr: localeUrl("fr", `blog/${paged.current}`),
        en: localeUrl("en", `blog/${paged.current}`),
      };
---

<BaseLayout
  locale={locale}
  title={dict.blog.title}
  description={dict.blog.description}
  alternates={alternates}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
  <div class="py-10 md:py-14">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{dict.blog.title}</h1>
    <p class="mt-3 max-w-2xl text-muted-foreground">{dict.blog.description}</p>

    {
      paged ? (
        <>
          <div class="mt-10">
            <PostList posts={paged.items} />
          </div>
          <Pagination
            locale={locale}
            current={paged.current}
            last={paged.last}
            prevUrl={prevUrl}
            nextUrl={nextUrl}
          />
        </>
      ) : (
        <div class="mt-10 flex flex-col gap-10">
          {years.map(([year, yearPosts]) => (
            <section aria-labelledby={`year-${year}`}>
              <h2
                id={`year-${year}`}
                class="border-b border-border pb-2 text-sm font-semibold uppercase tracking-wider text-muted-foreground"
              >
                {year}
              </h2>
              <PostList posts={yearPosts} />
            </section>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
