---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditOnGitHub from "@/components/EditOnGitHub.astro";
import { SITE, hasGithub } from "@/site.config";
import { localeUrl, t, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

const alternates = { fr: localeUrl("fr", "about"), en: localeUrl("en", "about") };
const editPath = locale === "en" ? "src/pages/en/about.astro" : "src/pages/about.astro";
---

<BaseLayout
  locale={locale}
  title={dict.about.title}
  description={dict.about.description}
  alternates={alternates}
>
  <div class="py-10 md:py-14">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{dict.about.title}</h1>
    <div class="prose mt-8">
      {dict.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      <p>
        {hasGithub && (
          <>
            <a href={SITE.social.github}>GitHub</a> &middot;{" "}
          </>
        )}
        <a href={localeUrl(locale, "rss.xml")}>RSS</a>
      </p>
    </div>
    <div class="mt-8 border-t border-border pt-6">
      <EditOnGitHub path={editPath} locale={locale} />
    </div>
  </div>
</BaseLayout>
