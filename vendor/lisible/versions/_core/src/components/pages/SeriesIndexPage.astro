---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { localeUrl, t, type Locale } from "@/i18n/ui";
import { getAllSeries } from "@/lib/series";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const series = await getAllSeries(locale);
const alternates = {
  fr: localeUrl("fr", "series"),
  en: localeUrl("en", "series"),
};
---

<BaseLayout
  locale={locale}
  title={dict.series.listTitle}
  description={dict.series.listDescription}
  alternates={alternates}
>
  <div class="py-10 md:py-14">
    <p class="text-xs font-semibold uppercase tracking-wide text-accent">
      {dict.series.label}
    </p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight md:text-4xl">
      {dict.series.listTitle}
    </h1>
    <p class="mt-3 max-w-2xl text-muted-foreground">
      {dict.series.listDescription}
    </p>

    {
      series.length > 0 ? (
        <ul class="mt-10 grid gap-4 sm:grid-cols-2">
          {series.map((entry) => (
            <li>
              <a
                href={localeUrl(locale, `series/${entry.slug}`)}
                class="block rounded-lg border border-border p-5 transition-colors hover:border-accent"
              >
                <strong class="block text-lg">{entry.title}</strong>
                <span class="mt-2 block text-sm text-muted-foreground">
                  {dict.archives.count(entry.count)} · {dict.series.cumulative(entry.totalMinutes)}
                </span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="mt-10 rounded-lg border border-dashed border-border p-6 text-muted-foreground">
          {dict.series.empty}
        </p>
      )
    }
  </div>
</BaseLayout>
