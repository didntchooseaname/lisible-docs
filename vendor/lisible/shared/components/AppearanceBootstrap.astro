---
interface Props {
  accent: string;
}

const { accent } = Astro.props;
---

<script is:inline define:vars={{ defaultAccent: accent }}>
  (() => {
    const root = document.documentElement;
    const media = window.matchMedia("(prefers-color-scheme: dark)");

    function luminance(rgb) {
      const channels = rgb.map((value) => {
        value /= 255;
        return value <= 0.03928 ? value / 12.92 : Math.pow((value + 0.055) / 1.055, 2.4);
      });
      return 0.2126 * channels[0] + 0.7152 * channels[1] + 0.0722 * channels[2];
    }

    function contrast(a, b) {
      return (Math.max(a, b) + 0.05) / (Math.min(a, b) + 0.05);
    }

    function applyTheme() {
      let stored = null;
      try { stored = localStorage.getItem("theme"); } catch {}
      const theme = stored === "light" || stored === "dark" ? stored : "system";
      const dark = theme === "dark" || (theme === "system" && media.matches);
      root.classList.toggle("dark", dark);
      root.dataset.theme = theme;
      root.dataset.resolvedTheme = dark ? "dark" : "light";
      root.style.colorScheme = dark ? "dark" : "light";
      return dark;
    }

    function applyAccent() {
      let stored = null;
      try { stored = localStorage.getItem("accent"); } catch {}
      const hex = stored && /^#[0-9a-f]{6}$/i.test(stored) ? stored : defaultAccent;
      const value = parseInt(hex.slice(1), 16);
      let rgb = [(value >> 16) & 255, (value >> 8) & 255, value & 255];
      const dark = root.classList.contains("dark");
      for (let index = 0; index < 60; index += 1) {
        if (dark ? contrast(luminance(rgb), 0) >= 3 : contrast(luminance(rgb), 1) >= 4.5) break;
        rgb = rgb.map((channel) => dark
          ? Math.min(255, Math.round(channel + (255 - channel) * 0.06) + 1)
          : Math.max(0, Math.round(channel * 0.94) - 1));
      }
      const accent = `rgb(${rgb.join(" ")})`;
      root.style.setProperty("--accent", accent);
      root.style.setProperty("--accent-foreground", contrast(luminance(rgb), 0) >= 4.5 ? "#000000" : "#ffffff");
      root.style.setProperty("--ring", accent);
    }

    function applyPreferences() {
      applyTheme();
      applyAccent();
    }

    function syncStorage(event) {
      if (event.key === "theme" || event.key === "accent" || event.key === null) applyPreferences();
    }

    function syncSystemTheme() {
      let stored = null;
      try { stored = localStorage.getItem("theme"); } catch {}
      if (stored !== "light" && stored !== "dark") applyPreferences();
    }

    window.__lisibleAppearanceCleanup?.();
    const observer = new MutationObserver(applyAccent);
    observer.observe(root, { attributes: true, attributeFilter: ["class"] });
    media.addEventListener("change", syncSystemTheme);
    window.addEventListener("storage", syncStorage);
    document.addEventListener("astro:after-swap", applyPreferences);
    document.addEventListener("astro:page-load", applyPreferences);
    window.__lisibleAppearanceCleanup = () => {
      observer.disconnect();
      media.removeEventListener("change", syncSystemTheme);
      window.removeEventListener("storage", syncStorage);
      document.removeEventListener("astro:after-swap", applyPreferences);
      document.removeEventListener("astro:page-load", applyPreferences);
    };
    window.__applyAccent = applyAccent;
    window.applyAccent = applyAccent;
    applyPreferences();
  })();
</script>
