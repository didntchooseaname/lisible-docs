{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "bun": "1.3.11",
    "node": "22"
  },
  "caches": {
    "bun": {
      "directory": "/root/.bun/install/cache",
      "type": "shared"
    },
    "previews": {
      "directory": "/app/.cache/lisible-previews",
      "type": "shared"
    }
  },
  "steps": {
    "build": {
      "commands": [
        {
          "cmd": "bun run check:all",
          "customName": "Validate and build the documentation"
        }
      ],
      "caches": ["bun", "previews"]
    }
  },
  "deploy": {
    "startCommand": "bun run start",
    "variables": {
      "NODE_ENV": "production",
      "STATIC_ROOT": "dist"
    }
  }
}
