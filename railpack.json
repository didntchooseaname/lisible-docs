{
  "$schema": "https://schema.railpack.com",
  "provider": "staticfile",
  "caches": {
    "bun": {
      "directory": "/root/.bun/install/cache",
      "type": "shared"
    },
    "previews": {
      "directory": "/app/.cache/lisible-previews",
      "type": "shared"
    }
  },
  "steps": {
    "build": {
      "commands": [
        {
          "image": "oven/bun:1.3.11",
          "src": "/usr/local/bin/bun",
          "dest": "/usr/local/bin/bun"
        },
        "...",
        {
          "cmd": "bun install --frozen-lockfile",
          "customName": "Install documentation dependencies"
        },
        {
          "cmd": "bun run check:all",
          "customName": "Validate and build the documentation"
        }
      ],
      "variables": {
        "ASTRO_TELEMETRY_DISABLED": "1",
        "CI": "true"
      },
      "caches": ["bun", "previews"],
      "deployOutputs": [
        {
          "include": ["dist"]
        }
      ]
    }
  },
  "deploy": {
    "inputs": [
      {
        "step": "packages:caddy",
        "include": ["/railpack/caddy"]
      },
      {
        "step": "build",
        "include": ["Caddyfile", "dist"]
      }
    ],
    "variables": {
      "LANG": "en_US.UTF-8",
      "LC_ALL": "en_US.UTF-8"
    }
  }
}
