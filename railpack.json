{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "bun": "1.3.11",
    "node": "22"
  },
  "steps": {
    "build": {
      "commands": [
        {
          "cmd": "bun run check:all",
          "customName": "Validate and build the documentation"
        }
      ]
    }
  },
  "deploy": {
    "startCommand": "bun run start",
    "variables": {
      "NODE_ENV": "production",
      "STATIC_ROOT": "dist"
    }
  }
}
